---
interface Props {
  title?: string;
  /** Optional breadcrumb tail — page can override the auto-derived crumb */
  crumb?: string;
}
const { title = 'Admin', crumb } = Astro.props;
const pathname = Astro.url.pathname;

// Sidebar definition — single source of truth
const NAV: Array<{
  href: string;
  label: string;
  icon: string;
  badge?: string;
}> = [
  { href: '/admin',              label: 'Πίνακας',    icon: '🏠' },
  { href: '/admin/agencies',     label: 'Γραφεία',    icon: '🏢' },
  { href: '/admin/tours',        label: 'Εκδρομές',   icon: '🧳' },
  { href: '/admin/destinations', label: 'Προορισμοί', icon: '📍' },
  { href: '/admin/places',       label: 'Places',     icon: '🗺️' },
  { href: '/admin/hotels',       label: 'Ξενοδοχεία', icon: '🏨' },
  { href: '/admin/periods',      label: 'Περίοδοι',   icon: '📅' },
  { href: '/admin/articles',     label: 'Άρθρα',      icon: '📰' },
];
const TOOLS_NAV: Array<{ href: string; label: string; icon: string }> = [
  { href: '/admin/site',             label: 'Ρυθμίσεις site',  icon: '⚙️' },
  { href: '/admin/scrape',           label: 'Scrape από URL',  icon: '↓' },
  { href: '/admin/bulk-regenerate',  label: 'Bulk regenerate', icon: '🔄' },
];

const isActive = (href: string) =>
  href === '/admin' ? pathname === '/admin' : pathname === href || pathname.startsWith(href + '/');

// Auto-breadcrumb from path
function buildCrumbs() {
  const out: { label: string; href?: string }[] = [{ label: 'Admin', href: '/admin' }];
  const labels: Record<string, string> = {
    agencies: 'Γραφεία', tours: 'Εκδρομές', destinations: 'Προορισμοί',
    places: 'Places', hotels: 'Ξενοδοχεία', periods: 'Περίοδοι',
    articles: 'Άρθρα', site: 'Ρυθμίσεις', scrape: 'Scrape',
    'bulk-regenerate': 'Bulk regen', new: 'Νέο',
  };
  const parts = pathname.replace(/^\/admin\/?/, '').split('/').filter(Boolean);
  let path = '/admin';
  for (let i = 0; i < parts.length; i++) {
    path += '/' + parts[i];
    const isLast = i === parts.length - 1;
    out.push({
      label: labels[parts[i]] || decodeURIComponent(parts[i]),
      href: isLast ? undefined : path,
    });
  }
  if (crumb) out[out.length - 1] = { label: crumb };
  return out;
}
const crumbs = buildCrumbs();
---
<!doctype html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Ταξιδιάρης Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        --brand-50:  #eef5fa;
        --brand-100: #d6e8f3;
        --brand-200: #a9cde2;
        --brand-500: #2b87b8;
        --brand-600: #176ba0;
        --brand-700: #13496e;
        --brand-800: #0e3552;
        --brand-900: #0a233a;

        --accent-500: #f97a07;
        --accent-600: #d65f00;

        --ink-50:  #f8fafc;
        --ink-100: #f1f5f9;
        --ink-200: #e2e8f0;
        --ink-300: #cbd5e0;
        --ink-400: #a0aec0;
        --ink-500: #718096;
        --ink-600: #4a5568;
        --ink-700: #2d3748;
        --ink-800: #1a202c;
        --ink-900: #0f172a;

        --green-50:  #d1fae5;
        --green-500: #10b981;
        --green-700: #047857;
        --amber-50:  #fef3c7;
        --amber-500: #f59e0b;
        --amber-700: #92400e;
        --red-50:    #fee2e2;
        --red-500:   #ef4444;
        --red-700:   #991b1b;

        --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04);
        --shadow:    0 1px 3px rgba(15, 23, 42, 0.06), 0 1px 2px rgba(15, 23, 42, 0.04);
        --shadow-md: 0 4px 6px -1px rgba(15, 23, 42, 0.08), 0 2px 4px -2px rgba(15, 23, 42, 0.05);
        --radius:    8px;
        --radius-lg: 12px;

        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, system-ui, sans-serif;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--ink-50);
        color: var(--ink-800);
        font-size: 14px;
        line-height: 1.5;
      }
      a { color: var(--brand-600); text-decoration: none; }
      a:hover { text-decoration: underline; }

      input, textarea, select, button { font: inherit; }
      input[type=text], input[type=password], input[type=email], input[type=url],
      input[type=tel], input[type=number], input[type=date], input[type=search],
      textarea, select {
        width: 100%;
        padding: 0.55rem 0.75rem;
        border: 1px solid var(--ink-300);
        border-radius: var(--radius);
        background: white;
        color: var(--ink-800);
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      input:focus, textarea:focus, select:focus {
        outline: none;
        border-color: var(--brand-600);
        box-shadow: 0 0 0 3px rgba(23, 107, 160, 0.12);
      }
      textarea { font-family: ui-monospace, 'SF Mono', Menlo, Monaco, Consolas, monospace; font-size: 0.9rem; resize: vertical; }

      .btn {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.55rem 1rem;
        border-radius: var(--radius); border: 1px solid transparent;
        cursor: pointer; font-weight: 500; font-size: 0.875rem;
        transition: background 0.15s, border-color 0.15s, transform 0.05s;
      }
      .btn:active { transform: translateY(1px); }
      .btn:disabled { opacity: 0.5; cursor: not-allowed; }
      .btn-primary { background: var(--brand-600); color: white; }
      .btn-primary:hover:not(:disabled) { background: var(--brand-700); }
      .btn-secondary { background: white; color: var(--ink-800); border-color: var(--ink-300); }
      .btn-secondary:hover:not(:disabled) { background: var(--ink-50); border-color: var(--brand-500); }
      .btn-ai { background: linear-gradient(135deg, var(--accent-500), #ed8936); color: white; }
      .btn-ai:hover:not(:disabled) { filter: brightness(1.05); }
      .btn-danger { background: var(--red-500); color: white; }
      .btn-danger:hover:not(:disabled) { background: var(--red-700); }
      .btn-success { background: var(--green-500); color: white; }
      .btn-success:hover:not(:disabled) { background: var(--green-700); }
      .btn-sm { padding: 0.35rem 0.7rem; font-size: 0.8rem; }
      .btn-link { background: transparent; color: var(--brand-600); padding: 0.25rem 0.5rem; }
      .btn-link:hover { text-decoration: underline; }

      .card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 1.25rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--ink-200);
      }
      .card-tight { padding: 1rem; }

      .field { margin-bottom: 1rem; }
      .field label { display: block; font-weight: 600; font-size: 0.825rem; margin-bottom: 0.35rem; color: var(--ink-700); }
      .field .hint { font-size: 0.75rem; color: var(--ink-500); margin-top: 0.3rem; }
      .row { display: flex; gap: 1rem; }
      .row > * { flex: 1; }

      .badge {
        display: inline-flex; align-items: center; gap: 0.25rem;
        padding: 0.15rem 0.5rem; border-radius: 999px;
        font-size: 0.72rem; font-weight: 600;
      }
      .badge-draft { background: var(--amber-50); color: var(--amber-700); }
      .badge-published, .badge-active { background: var(--green-50); color: var(--green-700); }
      .badge-pending { background: var(--amber-50); color: var(--amber-700); }
      .badge-suspended { background: var(--red-50); color: var(--red-700); }
      .badge-region-ellada { background: #dbeafe; color: #1e3a8a; }
      .badge-region-europi { background: #ede9fe; color: #5b21b6; }
      .badge-region-kosmos { background: #fee2e2; color: #991b1b; }

      .table { width: 100%; border-collapse: collapse; }
      .table th, .table td { padding: 0.7rem 0.85rem; text-align: left; border-bottom: 1px solid var(--ink-200); font-size: 0.875rem; }
      .table th { font-weight: 600; color: var(--ink-600); background: var(--ink-50); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; }
      .table tr:last-child td { border-bottom: none; }
      .table tr:hover td { background: var(--ink-50); }

      /* ─── Sidebar layout ─────────────────────────────────────────── */
      .admin-shell { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }
      @media (max-width: 880px) { .admin-shell { grid-template-columns: 1fr; } }

      .sidebar {
        background: var(--brand-900);
        color: white;
        padding: 1rem 0.75rem;
        position: sticky; top: 0; height: 100vh; overflow-y: auto;
        display: flex; flex-direction: column; gap: 1rem;
      }
      @media (max-width: 880px) {
        .sidebar { position: static; height: auto; }
        .sidebar.collapsed .sidebar-nav { display: none; }
      }
      .sidebar-brand {
        display: flex; align-items: center; gap: 0.6rem;
        padding: 0.4rem 0.75rem 0.9rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        font-weight: 700; font-size: 1.05rem; color: white;
      }
      .sidebar-brand:hover { text-decoration: none; }
      .sidebar-brand .plane {
        display: inline-flex; align-items: center; justify-content: center;
        size: 30px; width: 30px; height: 30px; border-radius: 8px;
        background: var(--accent-500); color: white;
      }
      .sidebar-section-label {
        font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em;
        text-transform: uppercase; color: rgba(255,255,255,0.45);
        padding: 0.4rem 0.75rem 0.25rem;
      }
      .sidebar-nav { display: flex; flex-direction: column; gap: 0.1rem; }
      .nav-item {
        display: flex; align-items: center; gap: 0.6rem;
        padding: 0.55rem 0.75rem;
        border-radius: var(--radius);
        color: rgba(255,255,255,0.78);
        font-weight: 500; font-size: 0.875rem;
        transition: background 0.15s, color 0.15s;
      }
      .nav-item:hover { background: rgba(255,255,255,0.06); color: white; text-decoration: none; }
      .nav-item.active { background: var(--brand-600); color: white; }
      .nav-item .icon { font-size: 1.05rem; line-height: 1; }
      .nav-item .badge-count {
        margin-left: auto; padding: 0.05rem 0.45rem;
        border-radius: 999px; background: var(--accent-500); color: white;
        font-size: 0.68rem; font-weight: 700;
      }

      .sidebar-foot {
        margin-top: auto; padding: 0.75rem; border-top: 1px solid rgba(255,255,255,0.1);
        font-size: 0.78rem; color: rgba(255,255,255,0.55);
      }
      .sidebar-foot a { color: rgba(255,255,255,0.85); }
      .sidebar-foot form { display: inline; }
      .sidebar-foot button {
        background: rgba(255,255,255,0.06); color: white;
        border: 1px solid rgba(255,255,255,0.15);
        padding: 0.35rem 0.7rem; border-radius: var(--radius); font-size: 0.78rem;
        cursor: pointer; width: 100%; margin-top: 0.5rem;
      }
      .sidebar-foot button:hover { background: rgba(255,255,255,0.12); }

      .sidebar-toggle {
        display: none;
      }
      @media (max-width: 880px) {
        .sidebar-toggle {
          display: inline-flex; align-items: center; gap: 0.4rem;
          margin-left: auto; padding: 0.3rem 0.6rem;
          background: rgba(255,255,255,0.1); color: white;
          border: 1px solid rgba(255,255,255,0.2); border-radius: 6px;
          font-size: 0.85rem; cursor: pointer;
        }
      }

      /* ─── Topbar + Main ──────────────────────────────────────────── */
      .topbar {
        background: white;
        border-bottom: 1px solid var(--ink-200);
        padding: 0.7rem 1.5rem;
        display: flex; align-items: center; gap: 1rem;
        position: sticky; top: 0; z-index: 5;
      }
      .breadcrumbs {
        display: flex; align-items: center; gap: 0.4rem;
        font-size: 0.85rem; color: var(--ink-500);
        flex: 1; min-width: 0; overflow: hidden;
      }
      .breadcrumbs a { color: var(--ink-600); }
      .breadcrumbs a:hover { color: var(--brand-600); }
      .breadcrumbs .sep { color: var(--ink-300); }
      .breadcrumbs .current { color: var(--ink-800); font-weight: 600; }
      .topbar-actions { display: flex; align-items: center; gap: 0.5rem; }
      .topbar a { color: var(--ink-600); font-size: 0.85rem; }
      .topbar a:hover { color: var(--brand-600); }

      main.admin-main {
        padding: 1.5rem;
        max-width: 1280px;
        margin: 0 auto;
        width: 100%;
      }

      h1 { margin: 0 0 1rem; font-size: 1.5rem; color: var(--ink-900); }
      h2 { margin: 0 0 0.75rem; font-size: 1.1rem; color: var(--ink-800); }
      h3 { margin: 0 0 0.5rem; font-size: 0.95rem; color: var(--ink-700); }

      .toast {
        position: fixed; bottom: 1rem; right: 1rem;
        padding: 0.75rem 1.25rem; border-radius: var(--radius);
        color: white; font-weight: 500; z-index: 100;
        box-shadow: var(--shadow-md); animation: slideIn 0.2s;
      }
      .toast-success { background: var(--green-500); }
      .toast-error { background: var(--red-500); }
      .toast-info { background: var(--brand-600); }
      @keyframes slideIn { from { transform: translateY(100%); opacity: 0 } to { transform: none; opacity: 1 } }
      .spinner {
        display: inline-block; width: 1rem; height: 1rem;
        border: 2px solid currentColor; border-top-color: transparent;
        border-radius: 50%; animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg) } }
    </style>
  </head>
  <body>
    <div class="admin-shell">
      <aside class="sidebar" id="sidebar">
        <a href="/admin" class="sidebar-brand">
          <span class="plane">✈</span>
          <span>Ταξιδιάρης</span>
        </a>

        <div>
          <div class="sidebar-section-label">Διαχείριση</div>
          <nav class="sidebar-nav">
            {NAV.map((item) => (
              <a href={item.href} class:list={['nav-item', { active: isActive(item.href) }]}>
                <span class="icon">{item.icon}</span>
                <span>{item.label}</span>
                {item.badge && <span class="badge-count">{item.badge}</span>}
              </a>
            ))}
          </nav>
        </div>

        <div>
          <div class="sidebar-section-label">Εργαλεία</div>
          <nav class="sidebar-nav">
            {TOOLS_NAV.map((item) => (
              <a href={item.href} class:list={['nav-item', { active: isActive(item.href) }]}>
                <span class="icon">{item.icon}</span>
                <span>{item.label}</span>
              </a>
            ))}
          </nav>
        </div>

        <div class="sidebar-foot">
          <a href="/" target="_blank" rel="noopener">Δες site →</a>
          <form method="POST" action="/api/admin/logout">
            <button type="submit">Αποσύνδεση</button>
          </form>
        </div>
      </aside>

      <div>
        <header class="topbar">
          <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle menu">
            ☰
          </button>
          <nav class="breadcrumbs" aria-label="Breadcrumb">
            {crumbs.map((c, i) => (
              <>
                {i > 0 && <span class="sep">/</span>}
                {c.href ? <a href={c.href}>{c.label}</a> : <span class="current">{c.label}</span>}
              </>
            ))}
          </nav>
          <div class="topbar-actions">
            <a href="/admin/agencies?status=pending" title="Εκκρεμή γραφεία">⏳</a>
            <a href="/" target="_blank" rel="noopener">Site ↗</a>
          </div>
        </header>

        <main class="admin-main">
          <slot />
        </main>
      </div>
    </div>

    <script is:inline>
      window.toast = (msg, type = 'info') => {
        const el = document.createElement('div');
        el.className = `toast toast-${type}`;
        el.textContent = msg;
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 3000);
      };
      // Mobile sidebar toggle
      document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        document.getElementById('sidebar')?.classList.toggle('collapsed');
      });
    </script>
  </body>
</html>
