---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { SITE } from '@lib/site';
import { breadcrumbJsonLd } from '@lib/seo';

const subjectFromQuery = Astro.url.searchParams.get('subject') ?? '';

const crumbs = [
  { name: 'Αρχική', url: '/' },
  { name: 'Επικοινωνία', url: '/epikoinonia' },
];
---
<BaseLayout
  title="Επικοινωνία"
  description="Επικοινωνήστε μαζί μας τηλεφωνικά ή με τη φόρμα. Σας απαντάμε άμεσα από έμπειρους ταξιδιωτικούς συμβούλους."
  jsonLd={breadcrumbJsonLd(crumbs)}
>
  <Hero
    eyebrow="Επικοινωνία"
    title="Πες μας τι ψάχνεις — θα σου προτείνουμε το ιδανικό ταξίδι"
    subtitle="Στείλε μας μήνυμα ή κάλεσέ μας. Θα σου απαντήσουμε άμεσα από έμπειρο ταξιδιωτικό σύμβουλο."
  >
    <Breadcrumbs slot="breadcrumbs" items={crumbs} />
  </Hero>

  <section class="section">
    <div class="container-x grid lg:grid-cols-3 gap-8">
      <!-- Contact info -->
      <aside class="lg:col-span-1 space-y-4">
        <div class="card p-6 bg-gradient-to-br from-brand-50 to-white">
          <h3 class="text-lg font-semibold mb-4">Στοιχεία επικοινωνίας</h3>
          <ul class="space-y-4 text-sm">
            <li class="flex gap-3">
              <span class="size-10 rounded-lg bg-brand-100 text-brand-800 inline-flex items-center justify-center shrink-0">
                <svg class="size-5" viewBox="0 0 20 20" fill="currentColor"><path d="M2 4.5C2 3.12 3.12 2 4.5 2h1.86c.5 0 .94.34 1.06.83l.92 3.7a1.1 1.1 0 0 1-.3 1.06L6.6 9.04a11 11 0 0 0 4.36 4.36l1.45-1.45c.27-.27.68-.39 1.06-.3l3.7.92c.49.12.83.56.83 1.06v1.86c0 1.38-1.12 2.5-2.5 2.5h-.5C8.39 18 2 11.61 2 3.5v-.5z"/></svg>
              </span>
              <div>
                <p class="text-ink-500 text-xs">Τηλέφωνο</p>
                <a href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`} class="font-semibold text-ink-900 hover:text-brand-700">
                  {SITE.contact.phoneDisplay}
                </a>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="size-10 rounded-lg bg-brand-100 text-brand-800 inline-flex items-center justify-center shrink-0">
                <svg class="size-5" viewBox="0 0 20 20" fill="currentColor"><path d="M2.5 5.75A1.75 1.75 0 0 1 4.25 4h11.5A1.75 1.75 0 0 1 17.5 5.75v8.5A1.75 1.75 0 0 1 15.75 16H4.25a1.75 1.75 0 0 1-1.75-1.75v-8.5zm2.18.25l5.32 4.18 5.32-4.18H4.68z"/></svg>
              </span>
              <div>
                <p class="text-ink-500 text-xs">Email</p>
                <a href={`mailto:${SITE.contact.email}`} class="font-semibold text-ink-900 hover:text-brand-700 break-all">
                  {SITE.contact.email}
                </a>
              </div>
            </li>
          </ul>
        </div>

        <div class="card p-6">
          <h3 class="text-lg font-semibold mb-2">Ώρες λειτουργίας</h3>
          <ul class="text-sm space-y-1 text-ink-700">
            <li class="flex justify-between"><span>Δευτέρα – Παρασκευή</span><span class="font-medium">09:00 – 19:00</span></li>
            <li class="flex justify-between"><span>Σάββατο</span><span class="font-medium">10:00 – 14:00</span></li>
            <li class="flex justify-between"><span>Κυριακή</span><span class="font-medium">Κλειστά</span></li>
          </ul>
        </div>
      </aside>

      <!-- Contact form -->
      <div class="lg:col-span-2">
        <div class="card p-6 md:p-8">
          <h2 class="text-2xl font-bold mb-2">Στείλτε μας μήνυμα</h2>
          <p class="text-ink-700 text-sm mb-6">Συμπληρώστε τα στοιχεία σας — απαντάμε εντός 24 ωρών εργάσιμων ημερών.</p>

          <form
            method="POST"
            action="https://formspree.io/f/YOUR_FORM_ID"
            class="space-y-4"
          >
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-ink-800 mb-1.5">Ονοματεπώνυμο *</label>
                <input id="name" name="name" type="text" required class="form-input" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-ink-800 mb-1.5">Τηλέφωνο *</label>
                <input id="phone" name="phone" type="tel" required class="form-input" />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-ink-800 mb-1.5">Email *</label>
              <input id="email" name="email" type="email" required class="form-input" />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-ink-800 mb-1.5">Θέμα / Προορισμός</label>
              <input id="subject" name="subject" type="text" value={subjectFromQuery} class="form-input" />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-ink-800 mb-1.5">Μήνυμα *</label>
              <textarea id="message" name="message" rows="5" required class="form-input"></textarea>
            </div>

            <label class="flex items-start gap-3 text-sm text-ink-700">
              <input type="checkbox" required class="mt-1 size-4 rounded border-ink-300 text-brand-700 focus:ring-brand-600" />
              <span>Συμφωνώ με την <a href="/privacy" class="link-underline">πολιτική απορρήτου</a> και την επεξεργασία των στοιχείων μου για επικοινωνία.</span>
            </label>

            <button type="submit" class="btn-primary w-full sm:w-auto">Αποστολή Μηνύματος</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <style>
    .form-input {
      @apply w-full rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm text-ink-900 placeholder:text-ink-400 focus:border-brand-600 focus:ring-2 focus:ring-brand-600/20 focus:outline-none transition-colors;
    }
  </style>
</BaseLayout>
