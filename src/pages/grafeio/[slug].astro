---
// SSR — agency tour list reflects DB state instantly (no rebuild on tour add/remove).
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import TourCard from '@components/TourCard.astro';
import { breadcrumbJsonLd, agencyJsonLd } from '@lib/seo';
import { readAgencyPublic } from '@lib/agencies-db';
import { listToursByAgency } from '@lib/tours-db';
import { isTourExpired } from '@lib/tour-status';

const agencySlug = String(Astro.params.slug || '');
const agency = agencySlug ? await readAgencyPublic(agencySlug) : null;

// Agency not found / suspended / pending → bounce back to the agency directory.
if (!agency) {
  return Astro.redirect('/grafeia');
}

// All tours for this agency, fetched directly from Postgres. Drafts are
// excluded so an agency can stage work-in-progress without it leaking publicly.
const allOwnedTours = await listToursByAgency(agency.id);
const publishedTours = allOwnedTours.filter((t) => !t.data.draft);
// Split into active (still bookable) vs completed (all departures passed).
// The active list is what the page promotes; completed tours appear lower
// as portfolio for the agency.
const ownedTours = publishedTours
  .filter((t) => !isTourExpired(t.data.dates))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'el'));
const completedTours = publishedTours
  .filter((t) => isTourExpired(t.data.dates))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'el'));

const tourCount = ownedTours.length;
const tourWord = tourCount === 1 ? '1 εκδρομή' : `${tourCount} εκδρομές`;

const crumbs = [
  { name: 'Αρχική', url: '/' },
  { name: 'Γραφεία', url: '/grafeia' },
  { name: agency.name, url: `/grafeio/${agency.slug}` },
];

const title = `${agency.name} — Ταξιδιωτικό Γραφείο${agency.city ? ` στη ${agency.city}` : ''}`;
const description =
  agency.description ||
  `Δείτε όλες τις οργανωμένες εκδρομές του γραφείου ${agency.name}` +
    `${agency.city ? ` στη ${agency.city}` : ''}. ` +
    `${tourCount > 0 ? `${tourWord} διαθέσιμες.` : ''} ` +
    `Επικοινωνήστε απευθείας μαζί τους για κρατήσεις.`;

const ld = [
  breadcrumbJsonLd(crumbs),
  agencyJsonLd({
    name: agency.name,
    description: agency.description,
    url: `/grafeio/${agency.slug}`,
    logo: agency.logoUrl,
    phone: agency.phone,
    email: agency.email,
    website: agency.website,
    address: agency.address,
    city: agency.city,
    vat: agency.vat,
  }),
];
---
<BaseLayout
  title={title}
  description={description}
  ogImage={agency.logoUrl || undefined}
  jsonLd={ld}
>
  <Hero
    eyebrow="Ταξιδιωτικό γραφείο"
    title={agency.name}
    subtitle={agency.description || (agency.city ? `Με έδρα τη ${agency.city}.` : 'Οργανωμένες εκδρομές')}
  >
    <Breadcrumbs slot="breadcrumbs" items={crumbs} />
    {agency.phone && (
      <a slot="cta" href={`tel:${agency.phone.replace(/\s+/g, '')}`} class="btn-accent">
        📞 {agency.phone}
      </a>
    )}
  </Hero>

  <section class="section">
    <div class="container-x grid lg:grid-cols-[1fr_320px] gap-10 items-start">
      <div class="min-w-0">
        <h2 class="mb-6">Εκδρομές του γραφείου</h2>
        {tourCount === 0 ? (
          <div class="card p-8 text-center">
            <p class="text-ink-600 mb-4">Το γραφείο δεν έχει αυτή τη στιγμή ενεργές εκδρομές στον Ταξιδιάρη.</p>
            <a href="/ekdromi" class="btn-secondary inline-block">Δες όλες τις εκδρομές</a>
          </div>
        ) : (
          <div class="grid sm:grid-cols-2 gap-5">
            {ownedTours.map((entry) => <TourCard entry={entry} />)}
          </div>
        )}

        {completedTours.length > 0 && (
          <section class="mt-12 pt-10 border-t border-ink-100">
            <h2 class="mb-2">Παλαιότερες εκδρομές</h2>
            <p class="text-sm text-ink-600 mb-6">Εκδρομές που έχουν ολοκληρωθεί. Παραμένουν εδώ ως portfolio του γραφείου.</p>
            <div class="grid sm:grid-cols-2 gap-5 opacity-80">
              {completedTours.map((entry) => <TourCard entry={entry} />)}
            </div>
          </section>
        )}
      </div>

      <aside>
        <div class="sticky top-24 space-y-4">
          {agency.logoUrl && (
            <div class="card p-6 text-center">
              <img src={agency.logoUrl} alt={agency.name} width="200" height="200" loading="eager" decoding="async" class="mx-auto max-w-[160px] max-h-[160px] object-contain" />
              <p class="mt-3 text-sm font-semibold text-ink-950">{agency.name}</p>
              {agency.city && <p class="text-xs text-ink-600 mt-0.5">📍 {agency.city}</p>}
            </div>
          )}
          <div class="card p-6">
            <h3 class="text-sm font-bold text-ink-950 uppercase tracking-wider mb-3">Επικοινωνία</h3>
            <dl class="text-sm space-y-3">
              {agency.phone && (
                <div>
                  <dt class="text-xs text-ink-500 uppercase tracking-wide font-medium">Τηλέφωνο</dt>
                  <dd class="mt-0.5">
                    <a href={`tel:${agency.phone.replace(/\s+/g, '')}`} class="text-brand-700 font-semibold hover:underline">
                      {agency.phone}
                    </a>
                  </dd>
                </div>
              )}
              {agency.email && (
                <div>
                  <dt class="text-xs text-ink-500 uppercase tracking-wide font-medium">Email</dt>
                  <dd class="mt-0.5">
                    <a href={`mailto:${agency.email}`} class="text-brand-700 hover:underline break-all">
                      {agency.email}
                    </a>
                  </dd>
                </div>
              )}
              {agency.website && (
                <div>
                  <dt class="text-xs text-ink-500 uppercase tracking-wide font-medium">Website</dt>
                  <dd class="mt-0.5">
                    <a href={agency.website} target="_blank" rel="noopener noreferrer" class="text-brand-700 hover:underline break-all">
                      {agency.website.replace(/^https?:\/\//, '')} ↗
                    </a>
                  </dd>
                </div>
              )}
              {agency.address && (
                <div>
                  <dt class="text-xs text-ink-500 uppercase tracking-wide font-medium">Διεύθυνση</dt>
                  <dd class="mt-0.5 text-ink-800">{agency.address}</dd>
                </div>
              )}
              {agency.city && !agency.address && (
                <div>
                  <dt class="text-xs text-ink-500 uppercase tracking-wide font-medium">Πόλη</dt>
                  <dd class="mt-0.5 text-ink-800">{agency.city}</dd>
                </div>
              )}
            </dl>
            {!agency.phone && !agency.email && !agency.website && (
              <p class="text-sm text-ink-600">
                Στείλτε μήνυμα μέσω της <a href="/epikoinonia" class="text-brand-700 hover:underline">φόρμας επικοινωνίας</a>.
              </p>
            )}
          </div>

          {(agency.vat || agency.eotLicense) && (
            <div class="card p-5 text-xs text-ink-600">
              <h4 class="font-semibold text-ink-700 mb-1.5 uppercase tracking-wide">Νομικά</h4>
              {agency.vat && <p>ΑΦΜ: <span class="font-mono text-ink-800">{agency.vat}</span></p>}
              {agency.eotLicense && <p>Άδεια ΕΟΤ: <span class="font-mono text-ink-800">{agency.eotLicense}</span></p>}
            </div>
          )}

          <a href="/grafeia" class="block text-center text-sm text-brand-700 hover:underline">
            ← Όλα τα γραφεία
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
