---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import DestinationCard from '@components/DestinationCard.astro';
import PeriodCard from '@components/PeriodCard.astro';
import TourCard from '@components/TourCard.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { destinationsByRegion, DESTINATIONS } from '@lib/destinations';
import { PERIODS } from '@lib/periods';
import { SITE, REGION_LABEL, REGION_INTRO } from '@lib/site';

const featured = ['santorini', 'mykonos', 'paris', 'rome', 'japan', 'maldives', 'london', 'kos']
  .map((slug) => DESTINATIONS.find((d) => d.slug === slug))
  .filter((d): d is NonNullable<typeof d> => Boolean(d));

const upcomingPeriods = PERIODS.slice(0, 4);
const regions: Array<'ellada' | 'europi' | 'kosmos'> = ['ellada', 'europi', 'kosmos'];

// Πιο πρόσφατες εκδρομές (max 6) — ταξινόμηση κατά updatedAt φθίνουσα.
const allTours = await getCollection('tours', ({ data }) => !data.draft);
const tourStamp = (d: Date | string | undefined): string => {
  if (!d) return '';
  return d instanceof Date ? d.toISOString() : String(d);
};
const featuredTours = allTours
  .sort((a, b) => tourStamp(b.data.updatedAt).localeCompare(tourStamp(a.data.updatedAt)))
  .slice(0, 6);
---
<BaseLayout
  title={SITE.name}
  description={SITE.description}
>
  <Hero
    variant="home"
    eyebrow="Ταξιδιωτικό Γραφείο & Οδηγός"
    title="Ταξίδια που σου μένουν αξέχαστα — από την Ελλάδα μέχρι τον Κόσμο"
    subtitle="Οργανωμένες εκδρομές σε δεκάδες προορισμούς. Αναλυτικοί ταξιδιωτικοί οδηγοί για να ξέρεις τι να δεις, πότε να πας και πώς."
  >
    <a slot="cta" href="/proorismoi" class="btn-accent">Εξερεύνηση Προορισμών</a>
    <a slot="cta" href="/ekdromes" class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-colors">
      Εκδρομές για Αργίες
    </a>
  </Hero>

  <!-- Trust strip -->
  <section class="border-b border-brand-100 bg-white">
    <div class="container-x py-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { n: '70+', l: 'Προορισμοί' },
        { n: '10', l: 'Περίοδοι Εκδρομών' },
        { n: '20+', l: 'Χρόνια Εμπειρίας' },
        { n: '4.9★', l: 'Αξιολογήσεις' },
      ].map((s) => (
        <div>
          <div class="font-display text-2xl md:text-3xl font-bold text-brand-800">{s.n}</div>
          <div class="text-xs md:text-sm text-ink-600 mt-1">{s.l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured tours (carousel-style scroll on mobile, grid on desktop) -->
  {featuredTours.length > 0 && (
    <section class="section">
      <div class="container-x">
        <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
          <div>
            <p class="chip mb-3">Επόμενες Εκδρομές</p>
            <h2 class="text-balance">Δες πού πάμε αυτή τη σεζόν</h2>
            <p class="mt-3 text-ink-700 max-w-2xl text-pretty">Αναλυτικό πρόγραμμα, ξενοδοχεία και τιμές ανά πόλη αναχώρησης — όλα έτοιμα για να επιλέξεις.</p>
          </div>
          <a href="/ekdromi" class="hidden md:inline-flex items-center gap-1 text-sm font-semibold text-brand-700 hover:text-brand-900">
            Όλες οι εκδρομές
            <svg class="size-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        {/* Mobile: horizontal swipe-able strip. Desktop: grid. */}
        <div class="md:hidden -mx-4 px-4 overflow-x-auto snap-x snap-mandatory">
          <div class="flex gap-4 pb-2" style="width: max-content;">
            {featuredTours.map((t) => (
              <div class="snap-start shrink-0 w-[80%] max-w-xs">
                <TourCard entry={t} />
              </div>
            ))}
          </div>
        </div>
        <div class="hidden md:grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredTours.map((t) => <TourCard entry={t} />)}
        </div>

        <div class="mt-6 md:hidden text-center">
          <a href="/ekdromi" class="inline-flex items-center gap-1 text-sm font-semibold text-brand-700">
            Όλες οι εκδρομές
            <svg class="size-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Featured destinations -->
  <section class="section">
    <div class="container-x">
      <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
        <div>
          <p class="chip mb-3">Δημοφιλείς Επιλογές</p>
          <h2 class="text-balance">Προορισμοί που αγαπήθηκαν</h2>
          <p class="mt-3 text-ink-700 max-w-2xl text-pretty">Από τα ελληνικά νησιά μέχρι τις πιο όμορφες ευρωπαϊκές πρωτεύουσες και εξωτικούς παραδείσους.</p>
        </div>
        <a href="/proorismoi" class="hidden md:inline-flex items-center gap-1 text-sm font-semibold text-brand-700 hover:text-brand-900">
          Όλοι οι προορισμοί
          <svg class="size-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {featured.map((d) => <DestinationCard destination={d} />)}
      </div>
    </div>
  </section>

  <!-- Upcoming periods -->
  <section class="section bg-brand-50/40">
    <div class="container-x">
      <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
        <div>
          <p class="chip mb-3">Επόμενες Αργίες</p>
          <h2 class="text-balance">Επιλογή για κάθε εορταστική περίοδο</h2>
        </div>
        <a href="/ekdromes" class="hidden md:inline-flex items-center gap-1 text-sm font-semibold text-brand-700 hover:text-brand-900">
          Όλες οι εκδρομές
          <svg class="size-4" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {upcomingPeriods.map((p) => <PeriodCard period={p} />)}
      </div>
    </div>
  </section>

  <!-- Regions -->
  <section class="section">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <p class="chip mb-3">Εξερεύνηση κατά περιοχή</p>
        <h2 class="text-balance">Ελλάδα, Ευρώπη & Κόσμος</h2>
        <p class="mt-3 text-ink-700 text-pretty">Πιάστε τον προορισμό που σας ταιριάζει — από κοντινές αποδράσεις μέχρι μακρινά ταξίδια ζωής.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {regions.map((r) => {
          const items = destinationsByRegion(r);
          return (
            <a href={`/proorismoi/${r}`} class="card group p-6 md:p-8 bg-gradient-to-br from-white to-brand-50/40 hover:from-brand-50/30 hover:to-brand-100/30">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-2xl font-bold text-ink-950 group-hover:text-brand-700 transition-colors">{REGION_LABEL[r]}</h3>
                <span class="chip">{items.length} προορισμοί</span>
              </div>
              <p class="text-ink-700 text-sm leading-relaxed">{REGION_INTRO[r]}</p>
              <div class="mt-5 flex flex-wrap gap-1.5">
                {items.slice(0, 6).map((d) => (
                  <span class="text-xs px-2 py-1 rounded-md bg-white border border-brand-100 text-ink-700">{d.name}</span>
                ))}
                <span class="text-xs px-2 py-1 rounded-md bg-brand-700 text-white">+{Math.max(0, items.length - 6)}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="section bg-ink-950 text-white">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="text-accent-300 text-sm font-semibold uppercase tracking-wider mb-3">Γιατί εμάς</p>
        <h2 class="text-white text-balance">Έμπειροι ταξιδιωτικοί σύμβουλοι, διαφανείς τιμές</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            t: 'Επιλεγμένα Προγράμματα',
            d: 'Κάθε εκδρομή σχεδιάζεται από έμπειρους συνοδούς με γνώση του προορισμού.',
            icon: '<path d="M10 2l2.39 4.84L18 8l-4 3.9.94 5.5L10 14.77 5.06 17.4 6 11.9 2 8l5.61-1.16L10 2z" fill="currentColor"/>',
          },
          {
            t: 'Καλύτερες Τιμές',
            d: 'Εγγυημένα ανταγωνιστικές τιμές, χωρίς κρυφές χρεώσεις. Ευέλικτα πακέτα.',
            icon: '<path d="M10 2C5.58 2 2 5.58 2 10s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zm1 13h-2v-2h2v2zm2.07-7.75l-.9.92C11.45 9.9 11 10.5 11 12H9v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41a2 2 0 1 0-4 0H6a4 4 0 0 1 8 0c0 .88-.36 1.68-.93 2.25z" fill="currentColor"/>',
          },
          {
            t: 'Προσωπική Εξυπηρέτηση',
            d: 'Σας απαντάμε άμεσα τηλεφωνικά ή με μήνυμα. Είμαστε δίπλα σας πριν, κατά και μετά το ταξίδι.',
            icon: '<path d="M10 2a8 8 0 1 0 0 16 8 8 0 0 0 0-16zm0 4a3 3 0 1 1 0 6 3 3 0 0 1 0-6zm0 14c-2.4 0-4.5-1.2-5.8-3 0-2 4-3.1 5.8-3.1s5.8 1.1 5.8 3.1c-1.3 1.8-3.4 3-5.8 3z" fill="currentColor"/>',
          },
        ].map((b) => (
          <div class="rounded-2xl bg-white/5 backdrop-blur p-6 border border-white/10">
            <div class="size-12 rounded-xl bg-accent-500/20 text-accent-300 flex items-center justify-center mb-4">
              <svg class="size-6" viewBox="0 0 20 20" set:html={b.icon} />
            </div>
            <h3 class="text-white text-lg font-semibold mb-2">{b.t}</h3>
            <p class="text-ink-300 text-sm leading-relaxed">{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA
    title="Ένα τηλεφώνημα μακριά από το επόμενο ταξίδι σας"
    text="Πέστε μας τι ψάχνετε και θα σας προτείνουμε τον ιδανικό προορισμό, με αναλυτικό πρόγραμμα και προσφορά κομμένη στα μέτρα σας."
  />
</BaseLayout>
