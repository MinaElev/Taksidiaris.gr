---
// SSR — read tours from Postgres on every request so agency edits go live
// without a Vercel rebuild.
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import TourCard from '@components/TourCard.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { breadcrumbJsonLd } from '@lib/seo';
import { REGION_LABEL } from '@lib/site';
import { listDepartureCities } from '@lib/departure-cities';
import { listToursPublic } from '@lib/tours-db';
import { isTourExpired } from '@lib/tour-status';

const all = await listToursPublic();
// Hide tours whose last departure date has passed.
const active = all.filter((t) => !isTourExpired(t.data.dates));
const sorted = active.sort((a, b) => a.data.title.localeCompare(b.data.title, 'el'));

const byRegion = {
  ellada: sorted.filter((t) => t.data.region === 'ellada'),
  europi: sorted.filter((t) => t.data.region === 'europi'),
  kosmos: sorted.filter((t) => t.data.region === 'kosmos'),
};

const departureCities = await listDepartureCities();

const crumbs = [
  { name: 'Αρχική', url: '/' },
  { name: 'Εκδρομές', url: '/ekdromi' },
];
---
<BaseLayout
  title="Οργανωμένες Εκδρομές"
  description="Οργανωμένες εκδρομές σε Ελλάδα, Ευρώπη και κόσμο. Αεροπορικές, οδικές και ακτοπλοϊκές με αναλυτικό πρόγραμμα και τιμές ανά πόλη αναχώρησης."
  jsonLd={breadcrumbJsonLd(crumbs)}
>
  <Hero
    eyebrow="Όλες οι εκδρομές"
    title="Οργανωμένες Εκδρομές με τον Ταξιδιάρη"
    subtitle="Αεροπορικά πακέτα, εκδρομές με πούλμαν, διακοπές νησιά. Επιλέξτε προορισμό και ξεκινήστε."
  >
    <Breadcrumbs slot="breadcrumbs" items={crumbs} />
    <a slot="cta" href="/epikoinonia" class="btn-accent">Επικοινωνία</a>
  </Hero>

  {departureCities.length > 0 && (
    <section class="bg-brand-50/60 border-y border-brand-100">
      <div class="container-x py-6">
        <div class="flex flex-col md:flex-row md:items-center gap-3">
          <label for="city-filter" class="font-semibold text-ink-900 shrink-0">
            🚌 Από ποια πόλη φεύγετε;
          </label>
          <select
            id="city-filter"
            class="flex-1 rounded-lg border border-brand-200 bg-white px-3 py-2 text-ink-900 focus:outline-none focus:ring-2 focus:ring-brand-500"
            onchange="if(this.value) window.location.href = this.value"
          >
            <option value="">— Επιλέξτε πόλη αναχώρησης —</option>
            {departureCities.map((c) => (
              <option value={`/anaxoriseis/${c.slug}`}>
                {c.name} ({c.tours.length === 1 ? '1 εκδρομή' : `${c.tours.length} εκδρομές`})
              </option>
            ))}
          </select>
          <a href="/anaxoriseis" class="text-sm font-semibold text-brand-700 hover:text-brand-900 whitespace-nowrap">
            Όλες οι πόλεις →
          </a>
        </div>
      </div>
    </section>
  )}

  {sorted.length === 0 ? (
    <section class="section">
      <div class="container-x text-center">
        <p class="text-lg text-ink-700">Σύντομα νέες εκδρομές. Επικοινωνήστε για διαθέσιμα προγράμματα.</p>
      </div>
    </section>
  ) : (
    <section class="section">
      <div class="container-x space-y-12">
        {(['ellada', 'europi', 'kosmos'] as const).map((region) => (
          byRegion[region].length > 0 && (
            <div>
              <h2 class="mb-6">{REGION_LABEL[region]}</h2>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                {byRegion[region].map((entry) => <TourCard entry={entry} />)}
              </div>
            </div>
          )
        ))}
      </div>
    </section>
  )}

  <ContactCTA context="οργανωμένες εκδρομές" />
</BaseLayout>
