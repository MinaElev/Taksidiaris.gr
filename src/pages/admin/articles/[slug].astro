---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { readArticle } from '@lib/content-io';

const slug = Astro.params.slug as string;

let entry;
try {
  entry = await readArticle(slug);
} catch {
  return Astro.redirect('/admin/articles');
}

const d = entry.data;
---
<AdminLayout title={`Επεξεργασία: ${d.title}`}>
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
    <a href="/admin/articles" style="color: #718096;">← Πίσω</a>
    <h1 style="margin: 0; font-size: 1.4rem; flex: 1;">{d.title}</h1>
    <a href={`/blog/${slug}`} target="_blank" class="btn btn-secondary">Δες στο site →</a>
  </div>

  <form id="editForm">
    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem;">
      <div style="display: flex; flex-direction: column; gap: 1rem;">

        <div class="card">
          <div class="field">
            <label>Τίτλος</label>
            <input type="text" name="title" value={d.title} required />
          </div>
          <div class="field">
            <label style="display: flex; align-items: center; justify-content: space-between;">
              <span>SEO Description (140-180 χαρακτήρες)</span>
              <button type="button" class="btn-ai-mini" data-rewrite-target="description" data-rewrite-kind="description">✨ Βελτίωση</button>
            </label>
            <textarea name="description" rows="2" required>{d.description}</textarea>
            <div class="hint" id="descCount"></div>
          </div>
          <div class="row">
            <div class="field">
              <label>Cover image URL</label>
              <input type="text" name="cover" value={d.cover || ''} placeholder="/images/uploads/..." />
            </div>
            <div class="field">
              <label>Ημ/νία δημοσίευσης</label>
              <input type="date" name="publishedAt" value={String(d.publishedAt || '').slice(0, 10)} />
            </div>
          </div>
          <div class="field">
            <label>Tags (1 ανά γραμμή)</label>
            <textarea name="tags" rows="3">{(d.tags || []).join('\n')}</textarea>
          </div>
        </div>

        <div class="card">
          <div class="field">
            <label style="display: flex; align-items: center; justify-content: space-between;">
              <span>Σώμα άρθρου (Markdown)</span>
              <button type="button" class="btn-ai-mini" data-rewrite-target="body" data-rewrite-kind="body">✨ Βελτίωση με AI</button>
            </label>
            <textarea name="body" rows="26" style="font-family: ui-monospace, Menlo, monospace; font-size: 0.85rem;">{entry.body}</textarea>
            <div class="hint">Markdown. ## για headers, ![](url) για εικόνες.</div>
          </div>
        </div>

        <div class="card">
          <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem;">📷 Upload εικόνας</h3>
          <input type="file" id="imgFile" accept="image/*" />
          <div id="uploadStatus" style="margin-top: 0.5rem; font-size: 0.85rem;"></div>
          <div class="hint" style="margin-top: 0.4rem;">Μετά το upload, αντιγράφεται το markdown της εικόνας στο clipboard.</div>
        </div>

      </div>

      <aside style="display: flex; flex-direction: column; gap: 1rem;">
        <div class="card" style="position: sticky; top: 1rem;">
          <div class="field">
            <label>
              <input type="checkbox" name="draft" checked={d.draft} style="width: auto; margin-right: 0.5rem;" />
              Draft
            </label>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
            💾 Αποθήκευση
          </button>
          <div style="margin-top: 0.5rem;" id="status"></div>
        </div>

        <div class="card">
          <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem;">Στοιχεία</h3>
          <div style="font-size: 0.85rem; color: #4a5568;">
            <div><strong>Slug:</strong> {slug}</div>
            <div><strong>URL:</strong> /blog/{slug}</div>
            {d.updatedAt && <div><strong>Ενημερώθηκε:</strong> {String(d.updatedAt).slice(0,10)}</div>}
          </div>
        </div>
      </aside>
    </div>
  </form>

  <style>
    .btn-ai-mini {
      background: linear-gradient(135deg, #f97a07, #ed8936);
      color: white;
      border: none;
      padding: 0.25rem 0.6rem;
      border-radius: 5px;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }
    .btn-ai-mini:hover { filter: brightness(1.05); }
    .btn-ai-mini:disabled { opacity: 0.6; cursor: not-allowed; }
  </style>

  <script is:inline src="/admin-sse.js"></script>
  <script is:inline src="/admin-rewrite.js"></script>
  <script is:inline define:vars={{ slug }}>
    const form = document.getElementById('editForm');
    const descTa = form.querySelector('[name=description]');
    const descCount = document.getElementById('descCount');
    function updateDesc() {
      const n = descTa.value.length;
      const ok = n >= 140 && n <= 180;
      descCount.textContent = `${n} χαρακτήρες ${ok ? '✓' : '(ιδανικά 140-180)'}`;
      descCount.style.color = ok ? '#10b981' : '#718096';
    }
    descTa.addEventListener('input', updateDesc);
    updateDesc();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const status = document.getElementById('status');
      status.innerHTML = '<span class="spinner"></span> Αποθήκευση...';
      const payload = {
        title: fd.get('title'),
        description: fd.get('description'),
        cover: fd.get('cover') || undefined,
        publishedAt: fd.get('publishedAt') || undefined,
        tags: String(fd.get('tags') || '').split('\n').map(s => s.trim()).filter(Boolean),
        draft: fd.has('draft'),
        body: fd.get('body'),
      };
      const r = await fetch(`/api/admin/article/${slug}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (r.ok) {
        status.innerHTML = '<span style="color: #10b981;">✓ Αποθηκεύτηκε</span>';
        setTimeout(() => status.innerHTML = '', 2500);
        toast('Αποθηκεύτηκε', 'success');
      } else {
        status.innerHTML = '<span style="color: #c53030;">✗ Σφάλμα</span>';
        toast('Σφάλμα: ' + (await r.text()).slice(0, 100), 'error');
      }
    });

    // Image upload
    document.getElementById('imgFile').addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const status = document.getElementById('uploadStatus');
      status.innerHTML = '<span class="spinner"></span> Upload...';
      const fd = new FormData();
      fd.append('file', file);
      try {
        const r = await fetch('/api/admin/upload', { method: 'POST', body: fd });
        if (!r.ok) throw new Error(await r.text());
        const data = await r.json();
        const md = `![](${data.url})`;
        try {
          await navigator.clipboard.writeText(md);
          status.innerHTML = `<span style="color:#10b981;">✓ ${data.url} (markdown στο clipboard)</span>`;
        } catch {
          status.innerHTML = `<span style="color:#10b981;">✓ ${md}</span>`;
        }
        toast('Εικόνα ανέβηκε', 'success');
      } catch (err) {
        status.innerHTML = `<span style="color:#c53030;">✗ ${String(err.message || err).slice(0, 150)}</span>`;
      } finally {
        e.target.value = '';
      }
    });
  </script>
</AdminLayout>
