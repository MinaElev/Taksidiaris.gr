---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { listDestinations } from '@lib/content-io';
import { listToursAdmin } from '@lib/tours-db';
import { REGION_LABEL } from '@lib/site';

const allDestinations = (await listDestinations()).filter((dst) => !dst.data.draft);
const destinationsByRegion = {
  ellada: allDestinations.filter((dst) => dst.data.region === 'ellada').sort((a, b) => a.data.title.localeCompare(b.data.title, 'el')),
  europi: allDestinations.filter((dst) => dst.data.region === 'europi').sort((a, b) => a.data.title.localeCompare(b.data.title, 'el')),
  kosmos: allDestinations.filter((dst) => dst.data.region === 'kosmos').sort((a, b) => a.data.title.localeCompare(b.data.title, 'el')),
};
const destinationRegionMap = JSON.stringify(
  Object.fromEntries(allDestinations.map((dst) => [dst.data.title, dst.data.region])),
);

// ---------------------------------------------------------------------------
// Optional prefill from /admin/hotels orphan panel:
//   ?name=...&slug=...&destination=...&region=...&city=...&stars=...&tourSlugs=a,b,c
// When tourSlugs is present, look them up to (a) show "mentioned in" context to
// the admin and (b) ship them to the AI endpoint as grounding.
// ---------------------------------------------------------------------------
const url = Astro.url;
const prefillName = url.searchParams.get('name') || '';
const prefillSlug = url.searchParams.get('slug') || '';
const prefillDestination = url.searchParams.get('destination') || '';
const prefillRegion = url.searchParams.get('region') || '';
const prefillCity = url.searchParams.get('city') || '';
const prefillStars = url.searchParams.get('stars') || '';
const tourSlugsCsv = url.searchParams.get('tourSlugs') || '';

const referencedTourSlugs = tourSlugsCsv.split(',').map((s) => s.trim()).filter(Boolean);
let referencedTours: { slug: string; title: string; destination: string; nights?: number; board?: string }[] = [];
if (referencedTourSlugs.length) {
  const allTours = await listToursAdmin();
  const bySlug = new Map(allTours.map((t) => [t.slug, t]));
  for (const ts of referencedTourSlugs) {
    const t = bySlug.get(ts);
    if (!t) continue;
    // Find this hotel's mention in the tour to grab nights/board hints.
    const normalize = (s: string) => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
    const mention = (t.data.hotels || []).find((h) => normalize(h.name) === normalize(prefillName));
    referencedTours.push({
      slug: t.slug,
      title: t.data.title,
      destination: t.data.destination,
      nights: mention?.nights,
      board: mention?.board,
    });
  }
}

const referencedToursJson = JSON.stringify(referencedTours);
const isAiPrefill = Boolean(prefillName && referencedTours.length);
---
<AdminLayout title="Νέο ξενοδοχείο">
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
    <a href="/admin/hotels" style="color: #718096;">← Πίσω</a>
    <h1 style="margin: 0; font-size: 1.5rem;">Νέο ξενοδοχείο</h1>
  </div>

  <div style="max-width: 720px;">
    {isAiPrefill && (
      <div class="card" style="margin-bottom: 1rem; border-left: 4px solid #f97a07; background: #fffaf0;">
        <h2 style="margin: 0 0 0.4rem; font-size: 1rem; color: #c05621;">
          🔗 Αυτό το ξενοδοχείο αναφέρεται από {referencedTours.length} εκδρομ{referencedTours.length === 1 ? 'ή' : 'ές'}
        </h2>
        <ul style="margin: 0 0 0.6rem 1.2rem; padding: 0; font-size: 0.85rem; color: #78350f;">
          {referencedTours.map((t) => (
            <li>
              <a href={`/admin/tours/${t.slug}`} style="color: #c05621;">{t.title}</a>
              <span style="color: #a16207;"> · {t.destination}{t.nights ? ` · ${t.nights} νύχτες` : ''}{t.board ? ` · ${t.board}` : ''}</span>
            </li>
          ))}
        </ul>
        <p style="margin: 0; font-size: 0.82rem; color: #92400e;">
          Πάτα <strong>"✨ Δημιουργία με AI"</strong> παρακάτω για να γεμίσει αυτόματα η φόρμα. Μόλις δημοσιευτεί η καταχώρηση,
          οι παραπάνω εκδρομές θα συνδέσουν αυτόματα το όνομα του ξενοδοχείου με hyperlink.
        </p>
      </div>
    )}

    <div class="card">
      <p style="margin: 0 0 1rem; color: #4a5568; font-size: 0.95rem;">
        Δώσε τα βασικά στοιχεία του ξενοδοχείου. Μετά τη δημιουργία θα μπορείς να συμπληρώσεις λεπτομέρειες (gallery, παροχές, δωμάτια κτλ.).
      </p>

      <form id="newForm">
        <div class="field">
          <label>Slug (URL)</label>
          <input type="text" name="slug" required placeholder="π.χ. mdc-cave-hotel-cappadocia" pattern="[a-z0-9-]+" value={prefillSlug} />
          <div class="hint">Μόνο πεζά λατινικά γράμματα, αριθμοί, παύλες. Θα γίνει: /ksenodoxeia/[slug]</div>
        </div>

        <div class="field">
          <label>
            Όνομα ξενοδοχείου
            {prefillName && (
              <button type="button" id="aiBtn" class="btn btn-ai" style="margin-left: 0.75rem; padding: 0.25rem 0.75rem; font-size: 0.8rem;">
                ✨ Δημιουργία με AI
              </button>
            )}
          </label>
          <input type="text" name="name" required placeholder="π.χ. MDC Cave Hotel Cappadocia" value={prefillName} />
        </div>

        <div class="field">
          <label>SEO Description (140-180 χαρακτήρες)</label>
          <textarea name="description" rows="2" required placeholder="Σύντομη περιγραφή για search engines"></textarea>
          <div class="hint" id="descCount"></div>
        </div>

        <div class="row">
          <div class="field">
            <label>Προορισμός</label>
            <input
              type="text"
              name="destination"
              id="destinationInput"
              list="destinationOptions"
              required
              placeholder="π.χ. Σαντορίνη, Παρίσι..."
              value={prefillDestination}
              autocomplete="off"
            />
            <datalist id="destinationOptions">
              {(['ellada', 'europi', 'kosmos'] as const).map((r) => (
                destinationsByRegion[r].map((dst) => (
                  <option value={dst.data.title} data-region={dst.data.region}>{REGION_LABEL[r]}</option>
                ))
              ))}
            </datalist>
            <div class="hint">
              Πληκτρολόγησε ή διάλεξε από τη λίστα. Επιτρέπεται και ελεύθερο κείμενο.
            </div>
          </div>
          <div class="field">
            <label>Περιοχή</label>
            <select name="region" id="regionSelect" required>
              <option value="ellada" selected={prefillRegion === 'ellada'}>Ελλάδα</option>
              <option value="europi" selected={prefillRegion === 'europi'}>Ευρώπη</option>
              <option value="kosmos" selected={prefillRegion === 'kosmos' || !prefillRegion}>Κόσμος</option>
            </select>
            <div class="hint">Αλλάζει αυτόματα όταν επιλέξεις από τη λίστα.</div>
          </div>
        </div>

        <div class="row">
          <div class="field">
            <label>Πόλη</label>
            <input type="text" name="city" placeholder="π.χ. Ürgüp" value={prefillCity} />
          </div>
          <div class="field">
            <label>Αστέρια</label>
            <input type="number" name="stars" min="1" max="5" placeholder="1-5" value={prefillStars} />
          </div>
          <div class="field">
            <label>Κατηγορία</label>
            <input type="text" name="category" placeholder="π.χ. Boutique, Luxury, Cave" />
          </div>
        </div>

        <div class="field">
          <label>Hero image URL (προαιρετικά)</label>
          <input type="text" name="hero" id="heroInput" placeholder="/images/hotels/..." />
        </div>

        <!-- Image picker — populated after AI returns _imageCandidates -->
        <div id="imagePickerPanel" style="display: none; margin-bottom: 1rem; padding: 0.75rem; background: #f0fdf4; border: 1px solid #86efac; border-radius: 6px;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;">
            <label style="font-weight: 600; color: #166534; font-size: 0.9rem; margin: 0;">
              📸 Εικόνες από το επίσημο site (<span id="imagePickerCount">0</span>)
            </label>
            <span style="font-size: 0.75rem; color: #166534;">Κλικ → ορίζεται ως hero · διπλό κλικ → προστίθεται στο gallery</span>
          </div>
          <div id="imagePickerGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.4rem; max-height: 320px; overflow-y: auto;"></div>
          <div id="galleryStatus" style="margin-top: 0.5rem; font-size: 0.78rem; color: #166534;"></div>
        </div>

        <!-- Sources — URLs Claude consulted -->
        <div id="sourcesPanel" style="display: none; margin-bottom: 1rem; padding: 0.6rem 0.75rem; background: #eff6ff; border-left: 3px solid #3b82f6; border-radius: 4px; font-size: 0.8rem;">
          <div style="font-weight: 600; color: #1e40af; margin-bottom: 0.3rem;">🔗 Πηγές από web_search</div>
          <ul id="sourcesList" style="margin: 0 0 0 1rem; padding: 0; color: #1e3a8a;"></ul>
        </div>

        <!-- Missing fields warning -->
        <div id="missingPanel" style="display: none; margin-bottom: 1rem; padding: 0.6rem 0.75rem; background: #fffbeb; border-left: 3px solid #d97706; border-radius: 4px; font-size: 0.85rem;">
          <div style="font-weight: 600; color: #92400e; margin-bottom: 0.25rem;">⚠ Δεν βρέθηκαν στο web</div>
          <span id="missingList" style="color: #78350f;"></span>
          <div style="margin-top: 0.3rem; font-size: 0.78rem; color: #92400e;">Συμπλήρωσέ τα χειροκίνητα ή άφησέ τα κενά.</div>
        </div>

        <div id="aiPreview" style="display: none; margin-bottom: 1rem; padding: 0.75rem; background: #1a202c; color: #e2e8f0; border-radius: 6px; font-family: ui-monospace, Menlo, monospace; font-size: 0.78rem; max-height: 240px; overflow: auto; white-space: pre-wrap;"></div>

        <div style="display: flex; gap: 0.75rem; align-items: center;">
          <button type="submit" class="btn btn-primary" id="saveBtn">Δημιουργία</button>
        </div>
        <div style="margin-top: 0.75rem;" id="status"></div>
      </form>
    </div>
  </div>

  <script is:inline define:vars={{ destinationRegionMap }}>
    // Destination → region auto-fill. Works with text input + datalist:
    // 'input' fires on every keystroke OR datalist pick. We look up the
    // current value in the map; if it matches a known destination, set the
    // region accordingly. If it's a free-text/new destination, leave region
    // alone so the admin keeps whatever they prefilled.
    (() => {
      const destEl = document.getElementById('destinationInput');
      const regionSel = document.getElementById('regionSelect');
      if (!destEl || !regionSel) return;
      const map = JSON.parse(destinationRegionMap);
      const updateRegion = () => {
        const r = map[destEl.value.trim()];
        if (r) regionSel.value = r;
      };
      destEl.addEventListener('input', updateRegion);
      destEl.addEventListener('change', updateRegion);
      // Run once on load (covers the prefill case)
      updateRegion();
    })();
  </script>

  <script is:inline src="/admin-sse.js"></script>

  <script is:inline define:vars={{ referencedToursJson }}>
    const form = document.getElementById('newForm');
    const descTa = form.querySelector('[name=description]');
    const descCount = document.getElementById('descCount');
    function updateDesc() {
      const n = descTa.value.length;
      const ok = n >= 140 && n <= 180;
      descCount.textContent = `${n} χαρακτήρες ${ok ? '✓' : '(ιδανικά 140-180)'}`;
      descCount.style.color = ok ? '#10b981' : '#718096';
    }
    descTa.addEventListener('input', updateDesc);
    updateDesc();

    // Holds the rich AI-generated payload (amenities, roomTypes, distances,
    // faqs, body, etc.) that the basic form doesn't display. Submitted
    // alongside the form values on save.
    let aiExtras = null;
    // Gallery URLs the user has explicitly added via double-click on a
    // candidate thumbnail. Submitted as `gallery` in the payload.
    let pickedGallery = [];

    const aiBtn = document.getElementById('aiBtn');
    const aiPreview = document.getElementById('aiPreview');
    const status = document.getElementById('status');
    const heroInput = document.getElementById('heroInput');
    const imagePickerPanel = document.getElementById('imagePickerPanel');
    const imagePickerGrid = document.getElementById('imagePickerGrid');
    const imagePickerCount = document.getElementById('imagePickerCount');
    const galleryStatus = document.getElementById('galleryStatus');
    const sourcesPanel = document.getElementById('sourcesPanel');
    const sourcesList = document.getElementById('sourcesList');
    const missingPanel = document.getElementById('missingPanel');
    const missingList = document.getElementById('missingList');
    const referencedTours = JSON.parse(referencedToursJson);

    const MISSING_LABEL = {
      address: 'διεύθυνση',
      stars: 'αστέρια',
      breakfast: 'τύπος πρωινού',
      checkIn: 'check-in',
      checkOut: 'check-out',
      coordinates: 'συντεταγμένες',
      officialWebsite: 'επίσημο website',
      amenities: 'παροχές',
      roomTypes: 'τύποι δωματίων',
      city: 'πόλη',
    };

    function renderImagePicker(urls) {
      if (!Array.isArray(urls) || urls.length === 0) {
        imagePickerPanel.style.display = 'none';
        return;
      }
      imagePickerPanel.style.display = '';
      imagePickerCount.textContent = urls.length;
      imagePickerGrid.innerHTML = '';
      urls.forEach((src) => {
        const wrap = document.createElement('div');
        wrap.style.cssText = 'position: relative; aspect-ratio: 4/3; background: #f7fafc; border-radius: 4px; overflow: hidden; cursor: pointer; border: 2px solid transparent;';
        wrap.title = 'Κλικ: hero · Διπλό κλικ: προσθήκη στο gallery';

        const img = document.createElement('img');
        img.src = src;
        img.style.cssText = 'width: 100%; height: 100%; object-fit: cover; display: block;';
        img.loading = 'lazy';
        img.onerror = () => { wrap.style.display = 'none'; };
        wrap.appendChild(img);

        const badge = document.createElement('div');
        badge.style.cssText = 'position: absolute; top: 4px; right: 4px; padding: 1px 5px; background: rgba(255,255,255,0.9); color: #166534; font-size: 0.7rem; font-weight: 700; border-radius: 3px; display: none;';
        wrap.appendChild(badge);

        const updateBadge = () => {
          const isHero = heroInput.value === src;
          const inGallery = pickedGallery.includes(src);
          if (isHero && inGallery) {
            badge.textContent = 'HERO + GAL';
            badge.style.display = '';
            wrap.style.borderColor = '#16a34a';
          } else if (isHero) {
            badge.textContent = 'HERO';
            badge.style.display = '';
            wrap.style.borderColor = '#0ea5e9';
          } else if (inGallery) {
            badge.textContent = 'GAL';
            badge.style.display = '';
            wrap.style.borderColor = '#16a34a';
          } else {
            badge.style.display = 'none';
            wrap.style.borderColor = 'transparent';
          }
        };

        wrap.addEventListener('click', (e) => {
          if (e.detail > 1) return; // wait for dblclick
          heroInput.value = src;
          // Re-render all to clear previous HERO badge
          imagePickerGrid.querySelectorAll('div[data-img-wrap]').forEach((el) => {
            const evt = new Event('refresh-badge'); el.dispatchEvent(evt);
          });
          updateBadge();
        });
        wrap.addEventListener('dblclick', (e) => {
          e.preventDefault();
          if (pickedGallery.includes(src)) {
            pickedGallery = pickedGallery.filter((u) => u !== src);
          } else {
            pickedGallery.push(src);
          }
          galleryStatus.textContent = pickedGallery.length
            ? `${pickedGallery.length} εικόν${pickedGallery.length === 1 ? 'α' : 'ες'} στο gallery`
            : '';
          updateBadge();
        });
        wrap.dataset.imgWrap = '1';
        wrap.addEventListener('refresh-badge', updateBadge);

        imagePickerGrid.appendChild(wrap);
        updateBadge();
      });
    }

    function renderSources(urls) {
      if (!Array.isArray(urls) || urls.length === 0) {
        sourcesPanel.style.display = 'none';
        return;
      }
      sourcesPanel.style.display = '';
      sourcesList.innerHTML = '';
      urls.slice(0, 8).forEach((u) => {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = u; a.target = '_blank'; a.rel = 'noopener';
        a.textContent = u.length > 80 ? u.slice(0, 77) + '...' : u;
        a.style.color = '#1e40af';
        li.appendChild(a);
        sourcesList.appendChild(li);
      });
    }

    function renderMissing(missing) {
      if (!Array.isArray(missing) || missing.length === 0) {
        missingPanel.style.display = 'none';
        return;
      }
      missingPanel.style.display = '';
      missingList.textContent = missing.map((k) => MISSING_LABEL[k] || k).join(', ');
    }

    if (aiBtn) {
      aiBtn.addEventListener('click', async () => {
        const name = form.querySelector('[name=name]').value.trim();
        if (!name) {
          window.toast('Δώσε πρώτα όνομα ξενοδοχείου', 'error');
          return;
        }
        const slug = form.querySelector('[name=slug]').value.trim();
        if (!slug || !/^[a-z0-9-]+$/.test(slug)) {
          window.toast('Συμπλήρωσε έγκυρο slug πριν τρέξεις AI (πεζά λατινικά + παύλες)', 'error');
          form.querySelector('[name=slug]').focus();
          return;
        }
        const destination = form.querySelector('[name=destination]').value.trim();
        if (!destination) {
          window.toast('Δώσε πρώτα προορισμό — αλλιώς το save θα αποτύχει και θα χάσεις τα AI credits', 'error');
          form.querySelector('[name=destination]').focus();
          return;
        }
        const region = form.querySelector('[name=region]').value;
        if (!['ellada','europi','kosmos'].includes(region)) {
          window.toast('Επίλεξε περιοχή πριν τρέξεις AI', 'error');
          return;
        }
        const city = form.querySelector('[name=city]').value;
        const starsStr = form.querySelector('[name=stars]').value;

        aiBtn.disabled = true;
        aiBtn.textContent = '⏳ Δημιουργία...';
        aiPreview.style.display = '';
        aiPreview.textContent = '';
        status.innerHTML = '<span class="spinner"></span> Streaming από Claude... (30-90 δευτ.)';

        let buffer = '';
        try {
          await window.streamSSE('/api/admin/ai/hotel', {
            name,
            destination: destination || undefined,
            region: region || undefined,
            city: city || undefined,
            stars: starsStr ? Number(starsStr) : undefined,
            contextTours: referencedTours.map((t) => ({
              title: t.title,
              destination: t.destination,
              nights: t.nights,
              board: t.board,
            })),
          }, {
            token: (chunk) => {
              buffer += chunk;
              aiPreview.textContent = buffer.slice(-2000);
              aiPreview.scrollTop = aiPreview.scrollHeight;
            },
            status: (msg) => {
              status.innerHTML = `<span class="spinner"></span> ${String(msg)}...`;
            },
            done: (data) => {
              aiExtras = data;
              // Fill all the visible form fields the AI returned.
              if (data.name) form.querySelector('[name=name]').value = data.name;
              if (data.description) {
                form.querySelector('[name=description]').value = data.description;
                updateDesc();
              }
              if (data.destination) {
                const destSel = form.querySelector('[name=destination]');
                const opt = Array.from(destSel.options).find((o) => o.value === data.destination);
                if (opt) destSel.value = data.destination;
              }
              if (data.region && ['ellada','europi','kosmos'].includes(data.region)) {
                form.querySelector('[name=region]').value = data.region;
              }
              if (data.city) form.querySelector('[name=city]').value = data.city;
              if (data.stars) form.querySelector('[name=stars]').value = data.stars;
              if (data.category) form.querySelector('[name=category]').value = data.category;

              // Render the new panels: image candidates, sources, missing fields.
              renderImagePicker(data._imageCandidates || []);
              renderSources(data.sources || []);
              renderMissing(data._missing || []);

              const imgCount = (data._imageCandidates || []).length;
              const srcCount = (data.sources || []).length;
              status.innerHTML = `<span style="color:#10b981;">✓ AI + ${srcCount} πηγές + ${imgCount} εικόνες. Διάλεξε hero και πάτα Δημιουργία.</span>`;
              aiPreview.style.display = 'none';
            },
            error: (err) => {
              status.innerHTML = `<span style="color:#c53030;">✗ AI: ${String(err.message || err).slice(0, 200)}</span>`;
              aiPreview.style.display = 'none';
            },
          });
        } catch (e) {
          status.innerHTML = `<span style="color:#c53030;">✗ ${String(e.message || e).slice(0, 200)}</span>`;
          aiPreview.style.display = 'none';
        } finally {
          aiBtn.disabled = false;
          aiBtn.textContent = '✨ Ξανά με AI';
        }
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const slug = String(fd.get('slug') || '').trim();
      if (!slug || !/^[a-z0-9-]+$/.test(slug)) {
        const msg = 'Slug: μόνο πεζά λατινικά, αριθμούς, παύλες.';
        status.innerHTML = `<span style="color:#c53030;">${msg}</span>`;
        window.toast(msg, 'error');
        form.querySelector('[name=slug]').focus();
        return;
      }
      // Pre-flight: confirm destination + name to avoid silent 400s
      const destValue = String(fd.get('destination') || '').trim();
      const nameValue = String(fd.get('name') || '').trim();
      const descValue = String(fd.get('description') || '').trim();
      if (!nameValue || !descValue || !destValue) {
        const missing = [];
        if (!nameValue) missing.push('όνομα');
        if (!descValue) missing.push('SEO description');
        if (!destValue) missing.push('προορισμός');
        const msg = 'Λείπουν υποχρεωτικά πεδία: ' + missing.join(', ');
        status.innerHTML = `<span style="color:#c53030;">${msg}</span>`;
        window.toast(msg, 'error');
        return;
      }

      const stars = fd.get('stars') ? Number(fd.get('stars')) : undefined;

      // Merge the basic form values with the rich AI extras (if any). Form
      // values win — admin may have edited them after AI fill.
      const payload = {
        name: fd.get('name'),
        description: fd.get('description'),
        destination: fd.get('destination'),
        region: fd.get('region'),
        city: fd.get('city') || undefined,
        category: fd.get('category') || undefined,
        stars,
        hero: fd.get('hero') || undefined,
        // Gallery: user-picked thumbnails from AI image candidates.
        gallery: pickedGallery,
        // From AI extras (or empty if no AI was used):
        aliases: aiExtras?.aliases || [],
        intro: aiExtras?.intro || undefined,
        amenities: aiExtras?.amenities || [],
        roomTypes: aiExtras?.roomTypes || [],
        distances: aiExtras?.distances || [],
        breakfast: aiExtras?.breakfast || undefined,
        checkIn: aiExtras?.checkIn || undefined,
        checkOut: aiExtras?.checkOut || undefined,
        // Prompt asks for `officialWebsite` (more specific than `website`) but
        // accept either — older runs returned `website`.
        website: aiExtras?.officialWebsite || aiExtras?.website || undefined,
        coordinates: aiExtras?.coordinates || undefined,
        faqs: aiExtras?.faqs || [],
        keywords: aiExtras?.keywords || [],
        sources: aiExtras?.sources || [],
        // Address might come from AI too:
        address: aiExtras?.address || undefined,
        draft: true,
        body: aiExtras?._body || '',
      };

      status.innerHTML = '<span class="spinner"></span> Δημιουργία...';
      const saveBtnEl = document.getElementById('saveBtn');
      saveBtnEl.disabled = true;
      try {
        const r = await fetch(`/api/admin/hotel/${slug}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!r.ok) {
          const errText = await r.text();
          // Surface the actual server error so admin understands what failed.
          // Common causes: missing GITHUB_TOKEN env, 422 from GitHub, 400
          // validation (name/description/destination).
          throw new Error(`HTTP ${r.status}: ${errText.slice(0, 300)}`);
        }
        status.innerHTML = '<span style="color:#10b981;">✓ Δημιουργήθηκε! Ανακατεύθυνση...</span>';
        window.toast('Δημιουργήθηκε ✓ — ανακατεύθυνση στο νέο ξενοδοχείο', 'success');
        // Vercel triggers a rebuild on the new GitHub commit. The hotel page
        // may 404 for ~60s until the redeploy finishes. Warn the admin.
        setTimeout(() => location.href = `/admin/hotels/${slug}`, 800);
      } catch (e) {
        const msg = String(e.message || e);
        status.innerHTML = `<span style="color:#c53030;">✗ ${msg.slice(0, 400)}</span>`;
        window.toast('Σφάλμα αποθήκευσης: ' + msg.slice(0, 200), 'error');
        // AI extras (aiExtras) stay in memory — admin can fix and retry without
        // burning credits again.
        status.scrollIntoView({ behavior: 'smooth', block: 'center' });
        saveBtnEl.disabled = false;
      }
    });
  </script>
</AdminLayout>
