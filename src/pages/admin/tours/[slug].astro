---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
// Tour reads now go to Postgres. listDestinations stays on the markdown
// content collection (destinations are still file-based).
import { listDestinations } from '@lib/content-io';
import { readTourAdmin } from '@lib/tours-db';
import { REGION_LABEL } from '@lib/site';
import { listAgenciesAdmin } from '@lib/agencies-db';
import { getAgencyForTourSlugAdmin } from '@lib/tour-agency';

const slug = String(Astro.params.slug || '');

const entry = await readTourAdmin(slug);
if (!entry) {
  return Astro.redirect('/admin/tours');
}

const d = entry.data;
const initialJson = JSON.stringify({ ...d, _body: entry.body });

const allDestinations = (await listDestinations()).filter((dst) => !dst.data.draft);
const destinationsByRegion = {
  ellada: allDestinations.filter((dst) => dst.data.region === 'ellada').sort((a, b) => a.data.title.localeCompare(b.data.title, 'el')),
  europi: allDestinations.filter((dst) => dst.data.region === 'europi').sort((a, b) => a.data.title.localeCompare(b.data.title, 'el')),
  kosmos: allDestinations.filter((dst) => dst.data.region === 'kosmos').sort((a, b) => a.data.title.localeCompare(b.data.title, 'el')),
};
const destinationRegionMap = JSON.stringify(
  Object.fromEntries(allDestinations.map((dst) => [dst.data.title, dst.data.region])),
);

// Agency assignment (independent of the rest of the form — it's a DB-only update)
let allAgencies: Awaited<ReturnType<typeof listAgenciesAdmin>> = [];
let currentAgencyId: string | null = null;
try {
  [allAgencies, currentAgencyId] = await Promise.all([
    listAgenciesAdmin(),
    getAgencyForTourSlugAdmin(slug).then((a) => a?.id ?? null),
  ]);
} catch (e) {
  console.error('[admin/tours] agency lookup failed:', e);
}
---
<AdminLayout title={`Επεξεργασία: ${d.title}`}>
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
    <a href="/admin/tours" style="color: #718096;">← Πίσω</a>
    <h1 style="margin: 0; font-size: 1.4rem; flex: 1;">{d.title}</h1>
    <a href={`/ekdromi/${slug}`} target="_blank" class="btn btn-secondary">Δες στο site →</a>
  </div>

  <!-- Ανάθεση γραφείου — DB-only, ξεχωριστό από το main form -->
  <div class="card" style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
    <span style="font-weight: 600; font-size: 0.9rem; color: #4a5568;">🏢 Ανάθεση σε γραφείο:</span>
    <select id="agencySelect" style="flex: 1; min-width: 220px; max-width: 360px; padding: 0.4rem 0.6rem; border: 1px solid #cbd5e0; border-radius: 6px;">
      <option value="" selected={currentAgencyId === null}>— Legacy / Mina-managed —</option>
      {allAgencies.map((a) => (
        <option value={a.id} selected={a.id === currentAgencyId}>
          {a.name}{a.status !== 'active' ? ` (${a.status})` : ''}
        </option>
      ))}
    </select>
    <button type="button" id="assignBtn" class="btn btn-primary" style="padding: 0.4rem 0.9rem; font-size: 0.85rem;">Αποθήκευση ανάθεσης</button>
    <a href="/admin/agencies" style="font-size: 0.8rem; color: #718096;">+ Νέο γραφείο</a>
  </div>

  <form id="editForm">
    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem;">
      <div style="display: flex; flex-direction: column; gap: 1rem;">

        <!-- Basics -->
        <div class="card">
          <div class="field">
            <label>Τίτλος</label>
            <input type="text" name="title" value={d.title} required />
          </div>
          <div class="field">
            <label>SEO Description (140-180 χαρακτήρες)</label>
            <textarea name="description" rows="2" required>{d.description}</textarea>
            <div class="hint" id="descCount"></div>
          </div>
          <div class="row">
            <div class="field">
              <label>Προορισμός</label>
              <select name="destination" id="destinationSelect" required>
                <option value="" disabled>— Επιλέξτε προορισμό —</option>
                {(['ellada', 'europi', 'kosmos'] as const).map((r) => (
                  destinationsByRegion[r].length > 0 && (
                    <optgroup label={REGION_LABEL[r]}>
                      {destinationsByRegion[r].map((dst) => (
                        <option value={dst.data.title} data-region={dst.data.region} selected={dst.data.title === d.destination}>
                          {dst.data.title}
                        </option>
                      ))}
                    </optgroup>
                  )
                ))}
                {!allDestinations.some((dst) => dst.data.title === d.destination) && d.destination && (
                  <option value={d.destination} selected>{d.destination} (μη καταχωρημένος)</option>
                )}
              </select>
              <div class="hint">
                <a href="/admin/destinations" target="_blank">Διαχείριση προορισμών →</a>
              </div>
            </div>
            <div class="field">
              <label>Περιοχή</label>
              <select name="region" id="regionSelect" required>
                <option value="ellada" selected={d.region === 'ellada'}>Ελλάδα</option>
                <option value="europi" selected={d.region === 'europi'}>Ευρώπη</option>
                <option value="kosmos" selected={d.region === 'kosmos'}>Κόσμος</option>
              </select>
              <div class="hint">Συμπληρώνεται αυτόματα από τον προορισμό.</div>
            </div>
          </div>
          <div class="row">
            <div class="field">
              <label>Διάρκεια — ημέρες</label>
              <input type="number" name="days" value={d.duration.days} min="1" required />
            </div>
            <div class="field">
              <label>Διάρκεια — νύχτες</label>
              <input type="number" name="nights" value={d.duration.nights} min="0" required />
            </div>
            <div class="field">
              <label>Μεταφορά</label>
              <select name="transport">
                <option value="αεροπορικώς" selected={d.transport === 'αεροπορικώς'}>αεροπορικώς</option>
                <option value="οδικώς" selected={d.transport === 'οδικώς'}>οδικώς</option>
                <option value="ακτοπλοϊκώς" selected={d.transport === 'ακτοπλοϊκώς'}>ακτοπλοϊκώς</option>
                <option value="συνδυαστικά" selected={d.transport === 'συνδυαστικά'}>συνδυαστικά</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="field">
              <label>Τιμή από</label>
              <input type="number" name="priceFrom" value={d.priceFrom || ''} step="1" />
            </div>
            <div class="field">
              <label>Νόμισμα</label>
              <input type="text" name="currency" value={d.currency || '€'} />
            </div>
            <div class="field">
              <label>Period (slug)</label>
              <input type="text" name="period" value={d.period || ''} placeholder="π.χ. pasxa" />
            </div>
          </div>
          <div class="field">
            <label>Hero image</label>
            <div style="display: flex; gap: 0.5rem; align-items: stretch;">
              <input type="text" name="hero" value={d.hero || ''} placeholder="URL ή πάτα Upload" style="flex: 1;" />
              <input type="file" id="heroUpload" accept="image/*" style="display: none;" />
              <button type="button" id="heroUploadBtn" class="btn btn-secondary" style="white-space: nowrap;">📷 Upload</button>
            </div>
            {d.hero && <img src={d.hero} alt="" style="margin-top: 0.5rem; max-height: 120px; border-radius: 6px;" />}
            <div class="hint" id="heroUploadStatus"></div>
          </div>
          <div class="field">
            <label>Intro</label>
            <textarea name="intro" rows="3">{d.intro || ''}</textarea>
          </div>
          <div class="field">
            <label>Gallery (1 URL ανά γραμμή)</label>
            <textarea name="gallery" rows="4">{(d.gallery || []).join('\n')}</textarea>
            <div style="display: flex; gap: 0.5rem; align-items: center; margin-top: 0.5rem;">
              <input type="file" id="galleryUpload" accept="image/*" multiple style="display: none;" />
              <button type="button" id="galleryUploadBtn" class="btn btn-secondary">📷 Upload εικόνες</button>
              <span class="hint" id="galleryUploadStatus"></span>
            </div>
          </div>
        </div>

        <!-- Departure cities -->
        <div class="card">
          <div class="field">
            <label>Πόλεις αναχώρησης (1 ανά γραμμή)</label>
            <textarea name="departureCities" rows="4">{(d.departureCities || []).join('\n')}</textarea>
          </div>
        </div>

        <!-- Pickup schedule -->
        <div class="card">
          <label style="font-weight: 600; font-size: 0.85rem; color: #4a5568; display: block; margin-bottom: 0.5rem;">
            Ώρες & σημεία αναχώρησης
          </label>
          <div id="pickupContainer"></div>
          <button type="button" id="addPickup" class="btn btn-secondary" style="margin-top: 0.5rem;">+ Προσθήκη σημείου</button>
        </div>

        <!-- Dates -->
        <div class="card">
          <label style="font-weight: 600; font-size: 0.85rem; color: #4a5568; display: block; margin-bottom: 0.5rem;">
            Ημερομηνίες αναχωρήσεων
          </label>
          <div id="datesContainer"></div>
          <button type="button" id="addDate" class="btn btn-secondary" style="margin-top: 0.5rem;">+ Προσθήκη ημερομηνίας</button>
        </div>

        <!-- Itinerary -->
        <div class="card">
          <label style="font-weight: 600; font-size: 0.85rem; color: #4a5568; display: block; margin-bottom: 0.5rem;">
            Πρόγραμμα ημέρας-ημέρας
          </label>
          <div id="itineraryContainer"></div>
          <button type="button" id="addDay" class="btn btn-secondary" style="margin-top: 0.5rem;">+ Προσθήκη ημέρας</button>
        </div>

        <!-- Hotels -->
        <div class="card">
          <label style="font-weight: 600; font-size: 0.85rem; color: #4a5568; display: block; margin-bottom: 0.5rem;">
            Ξενοδοχεία
          </label>
          <div id="hotelsContainer"></div>
          <button type="button" id="addHotel" class="btn btn-secondary" style="margin-top: 0.5rem;">+ Προσθήκη ξενοδοχείου</button>
        </div>

        <!-- Pricing -->
        <div class="card">
          <label style="font-weight: 600; font-size: 0.85rem; color: #4a5568; display: block; margin-bottom: 0.5rem;">
            Τιμές ανά πόλη αναχώρησης
          </label>
          <div id="pricingContainer"></div>
          <button type="button" id="addPrice" class="btn btn-secondary" style="margin-top: 0.5rem;">+ Προσθήκη γραμμής τιμής</button>
        </div>

        <!-- Includes / Not includes -->
        <div class="row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="card">
            <div class="field" style="margin: 0;">
              <label>Περιλαμβάνει (1 ανά γραμμή)</label>
              <textarea name="includes" rows="8">{(d.includes || []).join('\n')}</textarea>
            </div>
          </div>
          <div class="card">
            <div class="field" style="margin: 0;">
              <label>Δεν περιλαμβάνει (1 ανά γραμμή)</label>
              <textarea name="notIncludes" rows="8">{(d.notIncludes || []).join('\n')}</textarea>
            </div>
          </div>
        </div>

        <!-- Booking / cancellation / notes -->
        <div class="card">
          <div class="field">
            <label>Διαδικασία κράτησης (1 βήμα ανά γραμμή)</label>
            <textarea name="bookingProcess" rows="4">{(d.bookingProcess || []).join('\n')}</textarea>
          </div>
          <div class="field">
            <label>Πολιτική ακύρωσης (1 ανά γραμμή)</label>
            <textarea name="cancellationPolicy" rows="4">{(d.cancellationPolicy || []).join('\n')}</textarea>
          </div>
          <div class="field">
            <label>Σημειώσεις (1 ανά γραμμή)</label>
            <textarea name="notes" rows="4">{(d.notes || []).join('\n')}</textarea>
          </div>
        </div>

        <!-- FAQs -->
        <div class="card">
          <label style="font-weight: 600; font-size: 0.85rem; color: #4a5568; display: block; margin-bottom: 0.5rem;">
            Συχνές ερωτήσεις
          </label>
          <div id="faqsContainer"></div>
          <button type="button" id="addFaq" class="btn btn-secondary" style="margin-top: 0.5rem;">+ Προσθήκη FAQ</button>
        </div>

        <!-- SEO + body -->
        <div class="card">
          <div class="field">
            <label>SEO Keywords (1 ανά γραμμή)</label>
            <textarea name="keywords" rows="4">{(d.keywords || []).join('\n')}</textarea>
          </div>
          <div class="field">
            <label>Κύριο σώμα (Markdown)</label>
            <textarea name="body" rows="18" style="font-family: ui-monospace, Menlo, monospace; font-size: 0.85rem;">{entry.body}</textarea>
            <div class="hint">## για headers, **bold**, - για λίστες.</div>
          </div>
        </div>

      </div>

      <aside style="display: flex; flex-direction: column; gap: 1rem;">
        <div class="card" style="position: sticky; top: 1rem;">
          <div class="field">
            <label>
              <input type="checkbox" name="draft" checked={d.draft} style="width: auto; margin-right: 0.5rem;" />
              Draft
            </label>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
            💾 Αποθήκευση
          </button>
          <div style="margin-top: 0.5rem;" id="status"></div>
        </div>

        <div class="card">
          <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem;">🤖 Δημιουργία με AI</h3>
          <p style="margin: 0 0 0.75rem; font-size: 0.85rem; color: #718096;">
            Το AI θα γεμίσει όλα τα πεδία με βάση τα στοιχεία πάνω αριστερά.
          </p>
          <button type="button" id="aiGenerate" class="btn btn-ai" style="width: 100%; justify-content: center;">
            ✨ Γέμισε με AI
          </button>
          <div style="margin-top: 0.5rem;" id="aiStatus"></div>
        </div>

        <div class="card">
          <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem;">Στοιχεία</h3>
          <div style="font-size: 0.85rem; color: #4a5568;">
            <div><strong>Slug:</strong> {slug}</div>
            <div><strong>URL:</strong> /ekdromi/{slug}</div>
          </div>
        </div>
      </aside>
    </div>
  </form>

  <script is:inline define:vars={{ destinationRegionMap }}>
    (() => {
      const destSel = document.getElementById('destinationSelect');
      const regionSel = document.getElementById('regionSelect');
      if (!destSel || !regionSel) return;
      const map = JSON.parse(destinationRegionMap);
      destSel.addEventListener('change', () => {
        const r = map[destSel.value];
        if (r) regionSel.value = r;
      });
    })();
  </script>
  <script is:inline define:vars={{ slug }}>
    (() => {
      const sel = document.getElementById('agencySelect');
      const btn = document.getElementById('assignBtn');
      if (!sel || !btn) return;
      btn.addEventListener('click', async () => {
        const original = btn.textContent;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span> Αποθήκευση...';
        try {
          const r = await fetch(`/api/admin/tour/${slug}/agency`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ agencyId: sel.value || null }),
          });
          if (!r.ok) {
            let msg = `Σφάλμα ${r.status}`;
            try {
              const j = await r.json();
              msg = j.error ? `${j.error}${j.detail ? ' — ' + j.detail : ''}` : msg;
            } catch {}
            window.toast(msg.slice(0, 400), 'error');
          } else {
            window.toast(sel.value ? 'Αναθέθηκε στο γραφείο ✓' : 'Έγινε legacy (Mina-managed) ✓', 'success');
          }
        } catch (err) {
          window.toast('Σφάλμα δικτύου: ' + (err.message || err), 'error');
        } finally {
          btn.disabled = false;
          btn.textContent = original;
        }
      });
    })();
  </script>
  <script is:inline define:vars={{ slug, initialJson }}>
    const initial = JSON.parse(initialJson);
    const form = document.getElementById('editForm');

    // ===== Generic repeater helpers =====
    function makeRepeater(containerId, html, fillFn) {
      const container = document.getElementById(containerId);
      function render(data = {}) {
        const div = document.createElement('div');
        div.className = 'repeater-item';
        div.style.cssText = 'border: 1px solid #e2e8f0; border-radius: 6px; padding: 0.75rem; margin-bottom: 0.5rem; background: #f7fafc;';
        div.innerHTML = html + '<button type="button" data-remove style="margin-top: 0.4rem; background: none; border: none; color: #c53030; font-size: 0.8rem; cursor: pointer;">× Αφαίρεση</button>';
        fillFn(div, data);
        div.querySelector('[data-remove]').addEventListener('click', () => div.remove());
        container.appendChild(div);
        return div;
      }
      return { render, container };
    }

    // ===== Pickup =====
    const pickup = makeRepeater('pickupContainer', `
      <div style="display: grid; grid-template-columns: 1fr 1.5fr 90px; gap: 0.5rem;">
        <input type="text" placeholder="Πόλη" data-field="city" />
        <input type="text" placeholder="Σημείο" data-field="location" />
        <input type="text" placeholder="04:30" data-field="time" />
      </div>
    `, (div, data) => {
      div.querySelector('[data-field=city]').value = data.city || '';
      div.querySelector('[data-field=location]').value = data.location || '';
      div.querySelector('[data-field=time]').value = data.time || '';
    });
    (initial.pickupSchedule || []).forEach(p => pickup.render(p));
    document.getElementById('addPickup').addEventListener('click', () => pickup.render());

    // ===== Dates =====
    const dates = makeRepeater('datesContainer', `
      <div style="display: grid; grid-template-columns: 1fr 1fr 1.5fr; gap: 0.5rem;">
        <input type="date" data-field="from" />
        <input type="date" data-field="to" />
        <input type="text" placeholder="Ετικέτα (π.χ. 1-7 Ιουλίου 2026)" data-field="label" />
      </div>
    `, (div, data) => {
      div.querySelector('[data-field=from]').value = data.from || '';
      div.querySelector('[data-field=to]').value = data.to || '';
      div.querySelector('[data-field=label]').value = data.label || '';
    });
    (initial.dates || []).forEach(p => dates.render(p));
    document.getElementById('addDate').addEventListener('click', () => dates.render());

    // ===== Itinerary =====
    const itinerary = makeRepeater('itineraryContainer', `
      <div style="display: grid; grid-template-columns: 60px 1fr; gap: 0.5rem; margin-bottom: 0.4rem;">
        <input type="number" placeholder="Ημ." data-field="day" min="1" />
        <input type="text" placeholder="Τίτλος ημέρας" data-field="title" />
      </div>
      <textarea placeholder="Περιγραφή ημέρας" rows="3" data-field="description"></textarea>
    `, (div, data) => {
      div.querySelector('[data-field=day]').value = data.day || '';
      div.querySelector('[data-field=title]').value = data.title || '';
      div.querySelector('[data-field=description]').value = data.description || '';
    });
    (initial.itinerary || []).forEach(p => itinerary.render(p));
    document.getElementById('addDay').addEventListener('click', () => {
      const next = (itinerary.container.querySelectorAll('.repeater-item').length || 0) + 1;
      itinerary.render({ day: next });
    });

    // ===== Hotels =====
    const hotels = makeRepeater('hotelsContainer', `
      <div style="display: grid; grid-template-columns: 1.4fr 1fr 70px 70px 1fr; gap: 0.5rem;">
        <input type="text" placeholder="Όνομα" data-field="name" />
        <input type="text" placeholder="Πόλη" data-field="location" />
        <input type="number" placeholder="Νύχτες" data-field="nights" min="0" />
        <input type="number" placeholder="Αστέρια" data-field="stars" min="1" max="5" />
        <input type="text" placeholder="Διατροφή (π.χ. Πρωινό)" data-field="board" />
      </div>
    `, (div, data) => {
      div.querySelector('[data-field=name]').value = data.name || '';
      div.querySelector('[data-field=location]').value = data.location || '';
      div.querySelector('[data-field=nights]').value = data.nights || '';
      div.querySelector('[data-field=stars]').value = data.stars || '';
      div.querySelector('[data-field=board]').value = data.board || '';
    });
    (initial.hotels || []).forEach(p => hotels.render(p));
    document.getElementById('addHotel').addEventListener('click', () => hotels.render());

    // ===== Pricing =====
    const pricing = makeRepeater('pricingContainer', `
      <div style="display: grid; grid-template-columns: 1fr 100px 110px 1.3fr; gap: 0.5rem;">
        <input type="text" placeholder="Πόλη" data-field="fromCity" />
        <input type="number" placeholder="€/άτομο" data-field="perPerson" />
        <input type="number" placeholder="Επιβ. μονόκλ." data-field="singleSupplement" />
        <input type="text" placeholder="Έκπτωση παιδιού" data-field="childDiscount" />
      </div>
    `, (div, data) => {
      div.querySelector('[data-field=fromCity]').value = data.fromCity || '';
      div.querySelector('[data-field=perPerson]').value = data.perPerson || '';
      div.querySelector('[data-field=singleSupplement]').value = data.singleSupplement || '';
      div.querySelector('[data-field=childDiscount]').value = data.childDiscount || '';
    });
    (initial.pricing || []).forEach(p => pricing.render(p));
    document.getElementById('addPrice').addEventListener('click', () => pricing.render());

    // ===== FAQs =====
    const faqs = makeRepeater('faqsContainer', `
      <input type="text" placeholder="Ερώτηση" style="margin-bottom: 0.4rem;" data-field="q" />
      <textarea placeholder="Απάντηση" rows="3" data-field="a"></textarea>
    `, (div, data) => {
      div.querySelector('[data-field=q]').value = data.q || '';
      div.querySelector('[data-field=a]').value = data.a || '';
    });
    (initial.faqs || []).forEach(f => faqs.render(f));
    document.getElementById('addFaq').addEventListener('click', () => faqs.render());

    // ===== Description char counter =====
    const descTa = form.querySelector('[name=description]');
    const descCount = document.getElementById('descCount');
    function updateDesc() {
      const n = descTa.value.length;
      const ok = n >= 140 && n <= 180;
      descCount.textContent = `${n} χαρακτήρες ${ok ? '✓' : '(ιδανικά 140-180)'}`;
      descCount.style.color = ok ? '#10b981' : '#718096';
    }
    descTa.addEventListener('input', updateDesc);
    updateDesc();

    // ===== Image uploads =====
    async function uploadFile(file, folder) {
      const fd = new FormData();
      fd.append('file', file);
      fd.append('folder', folder);
      const r = await fetch('/api/admin/upload', { method: 'POST', body: fd });
      if (!r.ok) throw new Error(await r.text());
      return (await r.json()).url;
    }

    document.getElementById('heroUploadBtn').addEventListener('click', () => document.getElementById('heroUpload').click());
    document.getElementById('heroUpload').addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const status = document.getElementById('heroUploadStatus');
      status.innerHTML = '<span class="spinner"></span> Upload...';
      try {
        const url = await uploadFile(file, 'tours');
        form.querySelector('[name=hero]').value = url;
        status.innerHTML = `<span style="color:#10b981;">✓ ${url}</span>`;
        toast('Hero ανέβηκε — μην ξεχάσεις Αποθήκευση', 'success');
      } catch (err) {
        status.innerHTML = `<span style="color:#c53030;">✗ ${String(err.message || err).slice(0, 200)}</span>`;
      } finally {
        e.target.value = '';
      }
    });

    document.getElementById('galleryUploadBtn').addEventListener('click', () => document.getElementById('galleryUpload').click());
    document.getElementById('galleryUpload').addEventListener('change', async (e) => {
      const files = Array.from(e.target.files || []);
      if (!files.length) return;
      const ta = form.querySelector('[name=gallery]');
      const status = document.getElementById('galleryUploadStatus');
      let done = 0;
      status.innerHTML = `<span class="spinner"></span> Upload (0/${files.length})...`;
      for (const file of files) {
        try {
          const url = await uploadFile(file, 'tours');
          ta.value = (ta.value.trim() ? ta.value.trim() + '\n' : '') + url;
          done++;
          status.innerHTML = `<span class="spinner"></span> Upload (${done}/${files.length})...`;
        } catch (err) {
          status.innerHTML = `<span style="color:#c53030;">✗ ${String(err.message || err).slice(0, 200)}</span>`;
          break;
        }
      }
      if (done === files.length) {
        status.innerHTML = `<span style="color:#10b981;">✓ Ανέβηκαν ${done} εικόνες — μην ξεχάσεις Αποθήκευση</span>`;
        toast(`Ανέβηκαν ${done} εικόνες`, 'success');
      }
      e.target.value = '';
    });

    function collectRepeater(container, fields) {
      return Array.from(container.querySelectorAll('.repeater-item')).map(div => {
        const obj = {};
        for (const f of fields) {
          const el = div.querySelector(`[data-field=${f}]`);
          if (!el) continue;
          const v = el.value.trim();
          if (v !== '') obj[f] = el.type === 'number' ? Number(v) : v;
        }
        return obj;
      });
    }

    function gatherPayload() {
      const fd = new FormData(form);
      return {
        title: fd.get('title'),
        description: fd.get('description'),
        destination: fd.get('destination'),
        region: fd.get('region'),
        period: fd.get('period') || undefined,
        priceFrom: fd.get('priceFrom') ? Number(fd.get('priceFrom')) : undefined,
        currency: fd.get('currency') || '€',
        duration: { days: Number(fd.get('days')), nights: Number(fd.get('nights')) },
        transport: fd.get('transport'),
        hero: fd.get('hero') || undefined,
        intro: fd.get('intro') || undefined,
        gallery: String(fd.get('gallery') || '').split('\n').map(s => s.trim()).filter(Boolean),
        departureCities: String(fd.get('departureCities') || '').split('\n').map(s => s.trim()).filter(Boolean),
        pickupSchedule: collectRepeater(pickup.container, ['city', 'location', 'time']).filter(p => p.city),
        dates: collectRepeater(dates.container, ['from', 'to', 'label']).filter(p => p.from && p.to),
        itinerary: collectRepeater(itinerary.container, ['day', 'title', 'description']).filter(p => p.title || p.description),
        hotels: collectRepeater(hotels.container, ['name', 'location', 'nights', 'board', 'stars']).filter(p => p.name),
        pricing: collectRepeater(pricing.container, ['fromCity', 'perPerson', 'singleSupplement', 'childDiscount']).filter(p => p.fromCity && p.perPerson !== undefined),
        includes: String(fd.get('includes') || '').split('\n').map(s => s.trim()).filter(Boolean),
        notIncludes: String(fd.get('notIncludes') || '').split('\n').map(s => s.trim()).filter(Boolean),
        bookingProcess: String(fd.get('bookingProcess') || '').split('\n').map(s => s.trim()).filter(Boolean),
        cancellationPolicy: String(fd.get('cancellationPolicy') || '').split('\n').map(s => s.trim()).filter(Boolean),
        notes: String(fd.get('notes') || '').split('\n').map(s => s.trim()).filter(Boolean),
        faqs: collectRepeater(faqs.container, ['q', 'a']).filter(f => f.q && f.a),
        keywords: String(fd.get('keywords') || '').split('\n').map(s => s.trim()).filter(Boolean),
        draft: fd.has('draft'),
        body: fd.get('body'),
      };
    }

    function fillForm(data) {
      if (data.title !== undefined) form.querySelector('[name=title]').value = data.title;
      if (data.description !== undefined) form.querySelector('[name=description]').value = data.description;
      if (data.intro !== undefined) form.querySelector('[name=intro]').value = data.intro || '';
      if (data.includes !== undefined) form.querySelector('[name=includes]').value = (data.includes || []).join('\n');
      if (data.notIncludes !== undefined) form.querySelector('[name=notIncludes]').value = (data.notIncludes || []).join('\n');
      if (data.bookingProcess !== undefined) form.querySelector('[name=bookingProcess]').value = (data.bookingProcess || []).join('\n');
      if (data.cancellationPolicy !== undefined) form.querySelector('[name=cancellationPolicy]').value = (data.cancellationPolicy || []).join('\n');
      if (data.notes !== undefined) form.querySelector('[name=notes]').value = (data.notes || []).join('\n');
      if (data.keywords !== undefined) form.querySelector('[name=keywords]').value = (data.keywords || []).join('\n');
      if (data._body !== undefined) form.querySelector('[name=body]').value = data._body;
      if (data.itinerary !== undefined) {
        itinerary.container.innerHTML = '';
        (data.itinerary || []).forEach(p => itinerary.render(p));
      }
      if (data.hotels !== undefined) {
        hotels.container.innerHTML = '';
        (data.hotels || []).forEach(p => hotels.render(p));
      }
      if (data.pricing !== undefined) {
        pricing.container.innerHTML = '';
        (data.pricing || []).forEach(p => pricing.render(p));
      }
      if (data.pickupSchedule !== undefined) {
        pickup.container.innerHTML = '';
        (data.pickupSchedule || []).forEach(p => pickup.render(p));
      }
      if (data.faqs !== undefined) {
        faqs.container.innerHTML = '';
        (data.faqs || []).forEach(f => faqs.render(f));
      }
      updateDesc();
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = document.getElementById('status');
      status.innerHTML = '<span class="spinner"></span> Αποθήκευση...';
      const r = await fetch(`/api/admin/tour/${slug}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(gatherPayload()),
      });
      if (r.ok) {
        status.innerHTML = '<span style="color: #10b981;">✓ Αποθηκεύτηκε</span>';
        setTimeout(() => status.innerHTML = '', 2500);
        toast('Αποθηκεύτηκε', 'success');
      } else {
        status.innerHTML = '<span style="color: #c53030;">✗ Σφάλμα</span>';
        toast('Σφάλμα: ' + (await r.text()).slice(0, 120), 'error');
      }
    });

    document.getElementById('aiGenerate').addEventListener('click', async () => {
      if (!confirm('Το AI θα αντικαταστήσει το περιεχόμενο. Συνέχεια;')) return;
      const btn = document.getElementById('aiGenerate');
      const status = document.getElementById('aiStatus');
      btn.disabled = true;
      status.innerHTML = '<span class="spinner"></span> Δημιουργία... (60-120 δευτ.)';
      try {
        const fd = new FormData(form);
        const r = await fetch('/api/admin/ai/tour', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            destination: fd.get('destination'),
            region: fd.get('region'),
            duration: { days: Number(fd.get('days')), nights: Number(fd.get('nights')) },
            departureCities: String(fd.get('departureCities') || '').split('\n').map(s => s.trim()).filter(Boolean),
            transport: fd.get('transport'),
            priceFrom: fd.get('priceFrom') ? Number(fd.get('priceFrom')) : undefined,
          }),
        });
        if (!r.ok) throw new Error(await r.text());
        const data = await r.json();
        fillForm(data);
        status.innerHTML = '<span style="color: #10b981;">✓ Έτοιμο! Έλεγξε και πάτα Αποθήκευση.</span>';
        toast('Νέο περιεχόμενο δημιουργήθηκε', 'success');
      } catch (err) {
        status.innerHTML = `<span style="color: #c53030;">✗ ${err.message.slice(0, 120)}</span>`;
        toast('AI σφάλμα', 'error');
      } finally {
        btn.disabled = false;
      }
    });
  </script>
</AdminLayout>
