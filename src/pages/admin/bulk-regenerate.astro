---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { listToursAdmin } from '@lib/tours-db';
import { listArticles, readArticle, listDestinations, readDestination } from '@lib/content-io';

// Bulk regenerate — when the style guide changes, you want to refresh existing
// drafts (or even published items) so they conform to the new rules.
//
// This page only LISTS what's regen-eligible and provides a UI to fire calls
// one-by-one in the browser. It does NOT do server-side batch processing —
// that would require background jobs (out of scope for this iteration). The
// UI runs through the queue sequentially so we don't blow up the API rate
// limit or your wallet.
const tours = (await listToursAdmin()).filter((t) => t.data.draft);
const articleSummaries = (await listArticles()).filter((a) => a.data.draft);
// listArticles only returns frontmatter; we need bodies for the rewrite call,
// so fetch them in parallel. This is N+1 but the draft set is small (typically
// <10), and a single bulk-regen visit is rare.
const articles = await Promise.all(
  articleSummaries.map(async (a) => {
    const full = await readArticle(a.slug);
    return { slug: a.slug, data: full.data, body: full.body };
  }),
);

// Destinations — load ALL of them and detect stubs (placeholder bodies the
// generator scaffolded but never filled in). The marker phrase is unique to
// the scaffolding template, so a substring check is enough.
const destinationsAll = await listDestinations();
const destinationDetails = await Promise.all(
  destinationsAll.map(async (d) => {
    const full = await readDestination(d.region, d.slug);
    const body = full.body || '';
    const isStub = /Συμπληρώστε εδώ|Σημείο 1|Σημείο 2|Σημείο 3/.test(body);
    return {
      slug: d.slug,
      region: d.region,
      title: full.data.title,
      hero: full.data.hero || null,
      draft: Boolean(full.data.draft),
      bytes: body.length,
      isStub,
    };
  }),
);
// Sort: stubs first (most urgent), then by region, then alphabetical title.
destinationDetails.sort((a, b) => {
  if (a.isStub !== b.isStub) return a.isStub ? -1 : 1;
  if (a.region !== b.region) return a.region.localeCompare(b.region);
  return a.title.localeCompare(b.title, 'el');
});
const stubCount = destinationDetails.filter((d) => d.isStub).length;

// Preserve fields the AI doesn't generate (hero, gallery, dates, period,
// related) so bulk-regen doesn't wipe them — the tour PUT replaces these
// wholesale and missing = cleared.
const tourItems = tours.map((t) => ({
  slug: t.slug,
  title: t.data.title,
  destination: t.data.destination,
  region: t.data.region,
  days: t.data.duration.days,
  nights: t.data.duration.nights,
  transport: t.data.transport || 'αεροπορικώς',
  priceFrom: t.data.priceFrom,
  currency: t.data.currency || '€',
  period: t.data.period || null,
  departureCities: t.data.departureCities || [],
  hero: t.data.hero || null,
  gallery: t.data.gallery || [],
  dates: t.data.dates || [],
  related: t.data.related || [],
  body: t.body,
}));

// Include description/tags/cover/related so bulk-regen doesn't wipe them
// (the article PUT endpoint replaces these fields wholesale; omitting any
// non-required field clears it).
const articleItems = articles.map((a) => ({
  slug: a.slug,
  title: a.data.title,
  description: a.data.description,
  cover: a.data.cover || null,
  tags: a.data.tags || [],
  related: a.data.related || [],
  body: a.body,
}));
---
<AdminLayout title="Bulk regenerate">
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
    <a href="/admin" style="color: #718096;">← Πίνακας</a>
    <h1 style="margin: 0; font-size: 1.4rem;">🔄 Bulk regenerate</h1>
  </div>

  <div class="card" style="margin-bottom: 1rem; background: #fffbeb; border-left: 3px solid #f59e0b;">
    <h2 style="margin: 0 0 0.5rem; font-size: 1rem; color: #92400e;">Πότε χρησιμεύει</h2>
    <p style="margin: 0 0 0.5rem; font-size: 0.9rem; color: #78350f; line-height: 1.5;">
      Άλλαξες το <strong>style guide</strong> (βλ. <code>src/lib/ai-prompts.ts</code>) και θες όλα τα drafts να ξαναγραφτούν με τους νέους κανόνες. Η σελίδα τρέχει τα regen ένα-ένα στον browser — κλείσε καρτέλα = σταμάτημα.
    </p>
    <p style="margin: 0; font-size: 0.85rem; color: #78350f;">
      <strong>Κόστος:</strong> ~$0.30-0.60 ανά εκδρομή/άρθρο (εξαρτάται από μέγεθος). Δες τη συνολική εκτίμηση παρακάτω πριν ξεκινήσεις.
    </p>
  </div>

  <!-- DESTINATIONS -->
  <div class="card" style="margin-bottom: 1rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; flex-wrap: wrap; gap: 0.5rem;">
      <h2 style="margin: 0; font-size: 1.05rem;">
        Προορισμοί ({destinationDetails.length})
        {stubCount > 0 && (
          <span style="margin-left: 0.5rem; background: #fef3c7; color: #92400e; padding: 0.15rem 0.5rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">
            📝 {stubCount} stubs
          </span>
        )}
      </h2>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <button type="button" id="destSelectStubs" class="btn btn-secondary" style="padding: 0.3rem 0.7rem; font-size: 0.8rem;">📝 Μόνο stubs</button>
        <button type="button" id="destSelectAll" class="btn btn-secondary" style="padding: 0.3rem 0.7rem; font-size: 0.8rem;">Όλα</button>
        <button type="button" id="destSelectNone" class="btn btn-secondary" style="padding: 0.3rem 0.7rem; font-size: 0.8rem;">Κανένα</button>
        <button type="button" id="destRunBtn" class="btn btn-ai" style="padding: 0.3rem 0.9rem; font-size: 0.85rem;">▶ Regenerate επιλεγμένους (web_search)</button>
      </div>
    </div>
    <p style="margin: 0 0 0.75rem; font-size: 0.8rem; color: #718096; line-height: 1.5;">
      Το AI κάνει 4-6 web_search queries ανά προορισμό, παίρνει context τα ξενοδοχεία/εκδρομές της βάσης μας, και ξαναγράφει το body με πραγματικά αξιοθέατα/τιμές/ώρες.
      Σειριακά (~60-90 δευτ./προορισμός) — μην κλείσεις την καρτέλα. Το hero διατηρείται όπως είναι.
    </p>
    {destinationDetails.length === 0 ? (
      <p style="margin: 0; color: #718096; font-size: 0.9rem;">Κανένας προορισμός στη βάση.</p>
    ) : (
      <table style="width: 100%; font-size: 0.85rem; border-collapse: collapse;">
        <thead>
          <tr style="text-align: left; border-bottom: 1px solid #e2e8f0;">
            <th style="padding: 0.4rem; width: 40px;"><input type="checkbox" id="destMaster" /></th>
            <th style="padding: 0.4rem;">Τίτλος</th>
            <th style="padding: 0.4rem; width: 90px;">Περιοχή</th>
            <th style="padding: 0.4rem; width: 90px;">Body</th>
            <th style="padding: 0.4rem; width: 220px;">Status</th>
          </tr>
        </thead>
        <tbody id="destTbody">
          {destinationDetails.map((d) => (
            <tr data-dest-row data-slug={d.slug} data-region={d.region} data-stub={String(d.isStub)} style="border-bottom: 1px solid #f7fafc;">
              <td style="padding: 0.4rem;">
                <input type="checkbox" data-dest-cb data-slug={d.slug} data-stub={String(d.isStub)} />
              </td>
              <td style="padding: 0.4rem;">
                <a href={`/admin/destinations/${d.region}/${d.slug}`} target="_blank">{d.title}</a>
                {d.isStub && (
                  <span style="margin-left: 0.4rem; background: #fef3c7; color: #92400e; padding: 0.05rem 0.4rem; border-radius: 4px; font-size: 0.7rem; font-weight: 600;">stub</span>
                )}
                {d.draft && (
                  <span style="margin-left: 0.3rem; background: #e2e8f0; color: #4a5568; padding: 0.05rem 0.4rem; border-radius: 4px; font-size: 0.7rem;">draft</span>
                )}
              </td>
              <td style="padding: 0.4rem; color: #4a5568;">{d.region}</td>
              <td style="padding: 0.4rem; color: #4a5568;">{(d.bytes / 1024).toFixed(1)} KB</td>
              <td style="padding: 0.4rem;" data-dest-status></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <!-- TOURS -->
  <div class="card" style="margin-bottom: 1rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
      <h2 style="margin: 0; font-size: 1.05rem;">Drafts εκδρομών ({tours.length})</h2>
      <div style="display: flex; gap: 0.5rem;">
        <button type="button" id="tourSelectAll" class="btn btn-secondary" style="padding: 0.3rem 0.7rem; font-size: 0.8rem;">Όλα</button>
        <button type="button" id="tourSelectNone" class="btn btn-secondary" style="padding: 0.3rem 0.7rem; font-size: 0.8rem;">Κανένα</button>
        <button type="button" id="tourRunBtn" class="btn btn-ai" style="padding: 0.3rem 0.9rem; font-size: 0.85rem;">▶ Regenerate επιλεγμένα</button>
      </div>
    </div>
    {tours.length === 0 ? (
      <p style="margin: 0; color: #718096; font-size: 0.9rem;">Δεν υπάρχουν drafts εκδρομών.</p>
    ) : (
      <table style="width: 100%; font-size: 0.85rem; border-collapse: collapse;">
        <thead>
          <tr style="text-align: left; border-bottom: 1px solid #e2e8f0;">
            <th style="padding: 0.4rem; width: 40px;"><input type="checkbox" id="tourMaster" /></th>
            <th style="padding: 0.4rem;">Τίτλος</th>
            <th style="padding: 0.4rem;">Προορισμός</th>
            <th style="padding: 0.4rem; width: 80px;">Διάρκεια</th>
            <th style="padding: 0.4rem; width: 200px;">Status</th>
          </tr>
        </thead>
        <tbody id="tourTbody">
          {tourItems.map((t) => (
            <tr data-tour-row data-slug={t.slug} style="border-bottom: 1px solid #f7fafc;">
              <td style="padding: 0.4rem;"><input type="checkbox" data-tour-cb data-slug={t.slug} /></td>
              <td style="padding: 0.4rem;">
                <a href={`/admin/tours/${t.slug}`} target="_blank">{t.title}</a>
              </td>
              <td style="padding: 0.4rem; color: #4a5568;">{t.destination}</td>
              <td style="padding: 0.4rem; color: #4a5568;">{t.days}/{t.nights}</td>
              <td style="padding: 0.4rem;" data-tour-status></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <!-- ARTICLES -->
  <div class="card">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
      <h2 style="margin: 0; font-size: 1.05rem;">Drafts άρθρων ({articles.length})</h2>
      <div style="display: flex; gap: 0.5rem;">
        <button type="button" id="artSelectAll" class="btn btn-secondary" style="padding: 0.3rem 0.7rem; font-size: 0.8rem;">Όλα</button>
        <button type="button" id="artSelectNone" class="btn btn-secondary" style="padding: 0.3rem 0.7rem; font-size: 0.8rem;">Κανένα</button>
        <button type="button" id="artRunBtn" class="btn btn-ai" style="padding: 0.3rem 0.9rem; font-size: 0.85rem;">▶ Βελτίωση body επιλεγμένων</button>
      </div>
    </div>
    {articles.length === 0 ? (
      <p style="margin: 0; color: #718096; font-size: 0.9rem;">Δεν υπάρχουν drafts άρθρων.</p>
    ) : (
      <table style="width: 100%; font-size: 0.85rem; border-collapse: collapse;">
        <thead>
          <tr style="text-align: left; border-bottom: 1px solid #e2e8f0;">
            <th style="padding: 0.4rem; width: 40px;"><input type="checkbox" id="artMaster" /></th>
            <th style="padding: 0.4rem;">Τίτλος</th>
            <th style="padding: 0.4rem; width: 200px;">Status</th>
          </tr>
        </thead>
        <tbody id="artTbody">
          {articleItems.map((a) => (
            <tr data-art-row data-slug={a.slug} style="border-bottom: 1px solid #f7fafc;">
              <td style="padding: 0.4rem;"><input type="checkbox" data-art-cb data-slug={a.slug} /></td>
              <td style="padding: 0.4rem;">
                <a href={`/admin/articles/${a.slug}`} target="_blank">{a.title}</a>
              </td>
              <td style="padding: 0.4rem;" data-art-status></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <script is:inline src="/admin-sse.js"></script>
  <script is:inline define:vars={{ tourItems, articleItems, destinationDetails }}>
    // ---- helpers ----
    function setStatus(td, html) { if (td) td.innerHTML = html; }

    // ---- selection toggles ----
    function bindSelect(masterId, cbAttr, allBtnId, noneBtnId) {
      const master = document.getElementById(masterId);
      const allBtn = document.getElementById(allBtnId);
      const noneBtn = document.getElementById(noneBtnId);
      const cbs = () => Array.from(document.querySelectorAll(`[${cbAttr}]`));
      master?.addEventListener('change', () => cbs().forEach((c) => c.checked = master.checked));
      allBtn?.addEventListener('click', () => { cbs().forEach((c) => c.checked = true); if (master) master.checked = true; });
      noneBtn?.addEventListener('click', () => { cbs().forEach((c) => c.checked = false); if (master) master.checked = false; });
    }
    bindSelect('tourMaster', 'data-tour-cb', 'tourSelectAll', 'tourSelectNone');
    bindSelect('artMaster', 'data-art-cb', 'artSelectAll', 'artSelectNone');
    bindSelect('destMaster', 'data-dest-cb', 'destSelectAll', 'destSelectNone');

    // Extra: "Stubs only" — picks just the placeholder destinations.
    document.getElementById('destSelectStubs')?.addEventListener('click', () => {
      document.querySelectorAll('[data-dest-cb]').forEach((c) => {
        c.checked = c.dataset.stub === 'true';
      });
      const m = document.getElementById('destMaster');
      if (m) m.checked = false;
    });

    // ---- DESTINATION regeneration: SSE call to /api/admin/ai/destination, then PUT ----
    document.getElementById('destRunBtn')?.addEventListener('click', async () => {
      const checked = Array.from(document.querySelectorAll('[data-dest-cb]:checked'));
      if (checked.length === 0) { alert('Επίλεξε τουλάχιστον έναν προορισμό.'); return; }
      // Each call: web_search 4-6 ($0.04-0.06) + Opus 4.7 tokens (~$0.40-0.50) ≈ $0.50.
      const est = (checked.length * 0.50).toFixed(2);
      if (!confirm(`Θα γίνει regenerate σε ${checked.length} προορισμούς με web_search.\n\nΕκτιμώμενο κόστος: ~$${est}\nΕκτιμώμενος χρόνος: ${Math.ceil(checked.length * 75 / 60)} λεπτά (σειριακά).\n\nΣυνέχεια;`)) return;

      const slugs = checked.map((c) => c.dataset.slug);
      let okCount = 0;
      let failCount = 0;

      for (const slug of slugs) {
        const item = destinationDetails.find((d) => d.slug === slug);
        if (!item) continue;
        const tr = document.querySelector(`[data-dest-row][data-slug="${slug}"]`);
        const td = tr?.querySelector('[data-dest-status]');
        setStatus(td, '<span class="spinner"></span> AI ψάχνει στο web…');
        let charCount = 0;
        let lastStatus = '';

        try {
          await window.streamSSE('/api/admin/ai/destination', {
            region: item.region,
            slug: item.slug,
            name: item.title,
          }, {
            status: (msg) => {
              lastStatus = typeof msg === 'string' ? msg : JSON.stringify(msg);
              setStatus(td, '<span class="spinner"></span> ' + lastStatus.slice(0, 60));
            },
            token: (delta) => {
              charCount += String(delta).length;
              setStatus(td, '<span class="spinner"></span> AI γράφει… ' + charCount + ' chars');
            },
            done: async (data) => {
              setStatus(td, '<span class="spinner"></span> Αποθήκευση…');
              // PUT only the AI-touched fields. Preserve hero + draft state.
              const payload = {
                title: data.title || item.title,
                description: data.description || '',
                region: item.region,
                hero: item.hero || undefined, // preserve manually-curated hero
                intro: data.intro,
                bestTime: data.bestTime,
                duration: data.duration,
                highlights: Array.isArray(data.highlights) ? data.highlights : [],
                faqs: Array.isArray(data.faqs) ? data.faqs : [],
                keywords: Array.isArray(data.keywords) ? data.keywords : [],
                draft: item.draft, // preserve current published/draft state
                body: data._body || '',
              };
              const r = await fetch(`/api/admin/destination/${item.region}/${encodeURIComponent(slug)}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
              });
              if (r.ok) {
                const missing = Array.isArray(data._missing) && data._missing.length
                  ? ` <span style="color:#c05621; font-size:0.75rem;">(${data._missing.length} missing)</span>`
                  : '';
                setStatus(td, `<span style="color:#10b981;">✓ Έγινε${missing}</span>`);
                okCount++;
                tr?.setAttribute('data-stub', 'false');
              } else {
                const errTxt = await r.text().catch(() => '');
                setStatus(td, `<span style="color:#c53030;">✗ Save ${r.status}: ${errTxt.slice(0, 60)}</span>`);
                failCount++;
              }
            },
            error: (errData) => {
              setStatus(td, '<span style="color:#c53030;">✗ ' + String(errData.message || 'AI error').slice(0, 100) + '</span>');
              failCount++;
            },
          });
        } catch (e) {
          setStatus(td, '<span style="color:#c53030;">✗ ' + String(e.message || e).slice(0, 100) + '</span>');
          failCount++;
        }
      }

      window.toast?.(`Bulk regenerate ολοκληρώθηκε: ✓${okCount} ✗${failCount}`, failCount === 0 ? 'success' : 'error');
    });

    // ---- TOUR regeneration: full SSE call to /api/admin/ai/tour, then PUT to save ----
    document.getElementById('tourRunBtn')?.addEventListener('click', async () => {
      const checked = Array.from(document.querySelectorAll('[data-tour-cb]:checked'));
      if (checked.length === 0) { alert('Επίλεξε τουλάχιστον μία εκδρομή.'); return; }
      if (!confirm(`Θα γίνει regenerate σε ${checked.length} εκδρομές. Αυτό κοστίζει ~$${(checked.length * 0.45).toFixed(2)}. Συνέχεια;`)) return;
      const slugs = checked.map((c) => c.dataset.slug);
      for (const slug of slugs) {
        const item = tourItems.find((t) => t.slug === slug);
        if (!item) continue;
        const tr = document.querySelector(`[data-tour-row][data-slug="${slug}"]`);
        const td = tr?.querySelector('[data-tour-status]');
        setStatus(td, '<span class="spinner"></span> AI γράφει…');
        let streamed = '';
        try {
          await window.streamSSE('/api/admin/ai/tour', {
            destination: item.destination,
            region: item.region,
            duration: { days: item.days, nights: item.nights },
            departureCities: item.departureCities,
            transport: item.transport,
            priceFrom: item.priceFrom,
          }, {
            token: (delta) => {
              streamed += delta;
              setStatus(td, '<span class="spinner"></span> ' + streamed.length + ' chars');
            },
            done: async (data) => {
              setStatus(td, '<span class="spinner"></span> Αποθήκευση…');
              // PUT only the AI-touched fields, leave structural ones alone.
              const payload = {
                title: data.title || item.title,
                description: data.description,
                destination: item.destination,
                region: item.region,
                period: item.period || undefined,
                duration: { days: item.days, nights: item.nights },
                transport: item.transport,
                priceFrom: item.priceFrom,
                currency: item.currency,
                departureCities: item.departureCities,
                // Preserve manually-curated fields the AI doesn't touch.
                hero: item.hero || undefined,
                gallery: item.gallery,
                dates: item.dates,
                related: item.related,
                intro: data.intro,
                itinerary: data.itinerary || [],
                hotels: data.hotels || [],
                pricing: data.pricing || [],
                includes: data.includes || [],
                notIncludes: data.notIncludes || [],
                bookingProcess: data.bookingProcess || [],
                cancellationPolicy: data.cancellationPolicy || [],
                notes: data.notes || [],
                pickupSchedule: data.pickupSchedule || [],
                faqs: data.faqs || [],
                keywords: data.keywords || [],
                draft: true, // regenerated content stays in draft
                body: data._body || '',
              };
              const r = await fetch('/api/admin/tour/' + encodeURIComponent(slug), {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
              });
              if (r.ok) setStatus(td, '<span style="color:#10b981;">✓ Έγινε</span>');
              else setStatus(td, '<span style="color:#c53030;">✗ Save ' + r.status + '</span>');
            },
            error: (errData) => {
              setStatus(td, '<span style="color:#c53030;">✗ ' + String(errData.message || 'AI error').slice(0, 100) + '</span>');
            },
          });
        } catch (e) {
          setStatus(td, '<span style="color:#c53030;">✗ ' + String(e.message || e).slice(0, 100) + '</span>');
        }
      }
      window.toast?.('Bulk regenerate ολοκληρώθηκε', 'success');
    });

    // ---- ARTICLE regeneration: rewrite the body via /api/admin/ai/rewrite, then PUT to save ----
    document.getElementById('artRunBtn')?.addEventListener('click', async () => {
      const checked = Array.from(document.querySelectorAll('[data-art-cb]:checked'));
      if (checked.length === 0) { alert('Επίλεξε τουλάχιστον ένα άρθρο.'); return; }
      if (!confirm(`Θα γίνει βελτίωση body σε ${checked.length} άρθρα. Αυτό κοστίζει ~$${(checked.length * 0.20).toFixed(2)}. Συνέχεια;`)) return;
      const slugs = checked.map((c) => c.dataset.slug);
      for (const slug of slugs) {
        const item = articleItems.find((a) => a.slug === slug);
        if (!item) continue;
        const tr = document.querySelector(`[data-art-row][data-slug="${slug}"]`);
        const td = tr?.querySelector('[data-art-status]');
        setStatus(td, '<span class="spinner"></span> AI γράφει…');
        let newBody = '';
        try {
          await window.streamSSE('/api/admin/ai/rewrite', {
            text: item.body,
            kind: 'body',
            context: 'Άρθρο: ' + item.title,
          }, {
            token: (delta) => {
              newBody += delta;
              setStatus(td, '<span class="spinner"></span> ' + newBody.length + ' chars');
            },
            done: async (data) => {
              setStatus(td, '<span class="spinner"></span> Αποθήκευση…');
              const finalBody = (data && data.text) || newBody;
              const r = await fetch('/api/admin/article/' + encodeURIComponent(slug), {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  title: item.title,
                  description: item.description,
                  cover: item.cover || undefined,
                  tags: item.tags,
                  related: item.related,
                  body: finalBody,
                  draft: true,
                }),
              });
              if (r.ok) setStatus(td, '<span style="color:#10b981;">✓ Έγινε</span>');
              else setStatus(td, '<span style="color:#c53030;">✗ Save ' + r.status + '</span>');
            },
            error: (errData) => {
              setStatus(td, '<span style="color:#c53030;">✗ ' + String(errData.message || 'AI error').slice(0, 100) + '</span>');
            },
          });
        } catch (e) {
          setStatus(td, '<span style="color:#c53030;">✗ ' + String(e.message || e).slice(0, 100) + '</span>');
        }
      }
      window.toast?.('Bulk improve ολοκληρώθηκε', 'success');
    });
  </script>
</AdminLayout>
