---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
// Tours moved to Postgres (`listToursAdmin`); destinations/periods/articles/
// hotels still live in markdown content collections.
import { listDestinations, listPeriods, listArticles, listHotels } from '@lib/content-io';
import { listToursAdmin } from '@lib/tours-db';
import { listAgenciesAdmin } from '@lib/agencies-db';

// Each list is wrapped so a failure in one (e.g. malformed YAML) does not 500
// the whole dashboard. Errors are collected and shown in a diagnostic card.
type Box<T> = { ok: true; value: T } | { ok: false; error: string };
async function safe<T>(p: Promise<T>): Promise<Box<T>> {
  try { return { ok: true, value: await p }; }
  catch (e: any) { return { ok: false, error: String(e?.stack || e?.message || e) }; }
}

const [dRes, pRes, aRes, tRes, hRes, agRes] = await Promise.all([
  safe(listDestinations()),
  safe(listPeriods()),
  safe(listArticles()),
  safe(listToursAdmin()),
  safe(listHotels()),
  safe(listAgenciesAdmin()),
]);

const dests    = dRes.ok ? dRes.value : [];
const periods  = pRes.ok ? pRes.value : [];
const articles = aRes.ok ? aRes.value : [];
const tours    = tRes.ok ? tRes.value : [];
const hotels   = hRes.ok ? hRes.value : [];
const agencies = agRes.ok ? agRes.value : [];

const errors: { name: string; error: string }[] = [];
if (!dRes.ok)  errors.push({ name: 'listDestinations', error: dRes.error });
if (!pRes.ok)  errors.push({ name: 'listPeriods', error: pRes.error });
if (!aRes.ok)  errors.push({ name: 'listArticles', error: aRes.error });
if (!tRes.ok)  errors.push({ name: 'listTours', error: tRes.error });
if (!hRes.ok)  errors.push({ name: 'listHotels', error: hRes.error });
if (!agRes.ok) errors.push({ name: 'listAgenciesAdmin', error: agRes.error });

const activeAgencies   = agencies.filter((a) => a.status === 'active').length;
const pendingAgencies  = agencies.filter((a) => a.status === 'pending').length;

const draftDests = dests.filter((d) => d.data.draft).length;
const draftArticles = articles.filter((a) => a.data.draft).length;
const draftTours = tours.filter((t) => t.data.draft).length;
const draftHotels = hotels.filter((h) => h.data.draft).length;
---
<AdminLayout title="Πίνακας">
  <h1 style="margin: 0 0 1.5rem; font-size: 1.5rem;">Καλώς ήρθες</h1>

  {errors.length > 0 && (
    <div class="card" style="border: 2px solid #c53030; background: #fff5f5; margin-bottom: 1.5rem;">
      <h2 style="margin: 0 0 0.5rem; color: #c53030; font-size: 1rem;">⚠ Σφάλμα κατά την ανάγνωση περιεχομένου</h2>
      {errors.map((e) => (
        <details style="margin-bottom: 0.5rem;">
          <summary style="cursor: pointer; font-weight: 600; color: #c53030;">{e.name}</summary>
          <pre style="margin: 0.5rem 0 0; padding: 0.5rem; background: #fafafa; font-size: 0.75rem; overflow: auto; white-space: pre-wrap; border-radius: 4px;">{e.error}</pre>
        </details>
      ))}
    </div>
  )}

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <a href="/admin/agencies" class="card" style="display: block; color: inherit; border-left: 3px solid #10b981;">
      <div style="font-size: 0.85rem; color: #718096; margin-bottom: 0.4rem;">ΓΡΑΦΕΙΑ</div>
      <div style="font-size: 2rem; font-weight: 700; color: #10b981;">{agencies.length}</div>
      <div style="font-size: 0.85rem; color: #718096;">{activeAgencies} ενεργά{pendingAgencies > 0 ? ` · ${pendingAgencies} εκκρεμή` : ''}</div>
    </a>
    <a href="/admin/tours" class="card" style="display: block; color: inherit; border-left: 3px solid #f97a07;">
      <div style="font-size: 0.85rem; color: #718096; margin-bottom: 0.4rem;">ΕΚΔΡΟΜΕΣ</div>
      <div style="font-size: 2rem; font-weight: 700; color: #f97a07;">{tours.length}</div>
      <div style="font-size: 0.85rem; color: #718096;">{draftTours > 0 ? `${draftTours} σε draft` : tours.length === 0 ? 'καμία ακόμη' : 'όλες δημοσιευμένες'}</div>
    </a>
    <a href="/admin/destinations" class="card" style="display: block; color: inherit;">
      <div style="font-size: 0.85rem; color: #718096; margin-bottom: 0.4rem;">ΠΡΟΟΡΙΣΜΟΙ</div>
      <div style="font-size: 2rem; font-weight: 700; color: #176ba0;">{dests.length}</div>
      <div style="font-size: 0.85rem; color: #718096;">{draftDests > 0 ? `${draftDests} σε draft` : 'όλοι δημοσιευμένοι'}</div>
    </a>
    <a href="/admin/hotels" class="card" style="display: block; color: inherit;">
      <div style="font-size: 0.85rem; color: #718096; margin-bottom: 0.4rem;">ΞΕΝΟΔΟΧΕΙΑ</div>
      <div style="font-size: 2rem; font-weight: 700; color: #176ba0;">{hotels.length}</div>
      <div style="font-size: 0.85rem; color: #718096;">{draftHotels > 0 ? `${draftHotels} σε draft` : hotels.length === 0 ? 'κανένα ακόμη' : 'όλα δημοσιευμένα'}</div>
    </a>
    <a href="/admin/periods" class="card" style="display: block; color: inherit;">
      <div style="font-size: 0.85rem; color: #718096; margin-bottom: 0.4rem;">ΠΕΡΙΟΔΟΙ ΕΚΔΡΟΜΩΝ</div>
      <div style="font-size: 2rem; font-weight: 700; color: #176ba0;">{periods.length}</div>
      <div style="font-size: 0.85rem; color: #718096;">Πάσχα, Καλοκαίρι, κλπ.</div>
    </a>
    <a href="/admin/articles" class="card" style="display: block; color: inherit;">
      <div style="font-size: 0.85rem; color: #718096; margin-bottom: 0.4rem;">ΑΡΘΡΑ BLOG</div>
      <div style="font-size: 2rem; font-weight: 700; color: #176ba0;">{articles.length}</div>
      <div style="font-size: 0.85rem; color: #718096;">{draftArticles > 0 ? `${draftArticles} σε draft` : 'όλα δημοσιευμένα'}</div>
    </a>
    <a href="/admin/site" class="card" style="display: block; color: inherit;">
      <div style="font-size: 0.85rem; color: #718096; margin-bottom: 0.4rem;">ΡΥΘΜΙΣΕΙΣ SITE</div>
      <div style="font-size: 2rem; font-weight: 700; color: #176ba0;">⚙️</div>
      <div style="font-size: 0.85rem; color: #718096;">Hero αρχικής σελίδας</div>
    </a>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
    <div class="card">
      <h2 style="margin: 0 0 0.75rem; font-size: 1rem;">Γρήγορες ενέργειες</h2>
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <a href="/admin/tours/new" class="btn btn-ai">+ Νέα εκδρομή με AI</a>
        <a href="/admin/articles/new" class="btn btn-ai">+ Νέο άρθρο με AI</a>
        <a href="/admin/scrape" class="btn btn-ai">↓ Scrape εκδρομής από URL</a>
        <a href="/admin/destinations" class="btn btn-secondary">Επεξεργασία προορισμών</a>
      </div>
    </div>

    <div class="card" style="border-top: 3px solid #f97a07;">
      <h2 style="margin: 0 0 0.4rem; font-size: 1rem; display: flex; align-items: center; gap: 0.4rem;">
        <span>💳</span> Claude AI Credits
      </h2>
      <p style="margin: 0 0 0.75rem; color: #718096; font-size: 0.85rem; line-height: 1.4;">
        Όταν τα credits τελειώσουν, το AI σταματάει να γράφει εκδρομές & άρθρα. Φόρτωσε υπόλοιπο από το Anthropic Console.
      </p>
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <a href="https://console.anthropic.com/settings/billing" target="_blank" rel="noopener noreferrer" class="btn btn-ai">
          + Αγορά credits ↗
        </a>
        <a href="https://console.anthropic.com/settings/usage" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
          📊 Πόσο ξόδεψα ↗
        </a>
        <a href="https://console.anthropic.com/settings/keys" target="_blank" rel="noopener noreferrer" class="btn btn-secondary" style="font-size: 0.85rem;">
          🔑 Διαχείριση API keys ↗
        </a>
      </div>
    </div>

    <div class="card">
      <h2 style="margin: 0 0 0.75rem; font-size: 1rem;">Τελευταία άρθρα</h2>
      {articles.length === 0
        ? <p style="margin: 0; color: #718096; font-size: 0.9rem;">Δεν υπάρχουν άρθρα ακόμα.</p>
        : <ul style="list-style: none; padding: 0; margin: 0;">
            {articles.slice(0, 5).map((a) => (
              <li style="padding: 0.4rem 0; border-bottom: 1px solid #e2e8f0; font-size: 0.9rem;">
                <a href={`/admin/articles/${a.slug}`}>{a.data.title}</a>
                {a.data.draft && <span class="badge badge-draft" style="margin-left: 0.5rem;">draft</span>}
              </li>
            ))}
          </ul>
      }
    </div>
  </div>
</AdminLayout>
