---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { readSiteConfig } from '@lib/site-config';

const config = await readSiteConfig();
const initialJson = JSON.stringify(config);
---
<AdminLayout title="Ρυθμίσεις site">
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
    <a href="/admin" style="color: #718096;">← Πίσω</a>
    <h1 style="margin: 0; font-size: 1.4rem; flex: 1;">Ρυθμίσεις site</h1>
    <a href="/" target="_blank" class="btn btn-secondary">Δες την αρχική →</a>
  </div>

  <form id="editForm">
    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem;">
      <div style="display: flex; flex-direction: column; gap: 1rem;">

        <div class="card">
          <h2 style="margin: 0 0 0.75rem; font-size: 1rem;">Hero αρχικής σελίδας</h2>
          <p style="margin: 0 0 1rem; font-size: 0.85rem; color: #718096;">
            Η εικόνα-φόντο που εμφανίζεται στην κορυφή της αρχικής σελίδας.
          </p>

          <div class="field">
            <label>Hero image URL</label>
            <div style="display: flex; gap: 0.5rem; align-items: stretch;">
              <input type="text" name="homeHero" value={config.homeHero} placeholder="URL ή πάτα Upload" style="flex: 1;" />
              <input type="file" id="heroUpload" accept="image/*" style="display: none;" />
              <button type="button" id="heroUploadBtn" class="btn btn-secondary" style="white-space: nowrap;">📷 Upload</button>
            </div>
            <div class="hint" id="heroUploadStatus">Ανέβασε φωτογραφία ή κόλλα URL.</div>
          </div>

          <div class="field">
            <label>Alt text (περιγραφή για SEO/accessibility)</label>
            <input type="text" name="homeHeroAlt" value={config.homeHeroAlt} placeholder="π.χ. Λιμάνι του Πόρου με τα παραδοσιακά καΐκια" />
          </div>

          <div style="margin-top: 1rem;">
            <label style="font-weight: 600; font-size: 0.85rem; color: #4a5568; display: block; margin-bottom: 0.5rem;">
              Προεπισκόπηση
            </label>
            <div id="previewWrap" style={`position: relative; border-radius: 8px; overflow: hidden; background: #1a202c; aspect-ratio: 16/7; ${config.homeHero ? '' : 'display: none;'}`}>
              <img id="heroPreview" src={config.homeHero || ''} alt="" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
              <div style="position: absolute; inset: 0; background: linear-gradient(to right, rgba(15,23,42,0.8), rgba(15,23,42,0.55), rgba(15,23,42,0.3));"></div>
              <div style="position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: center; padding: 1.5rem; color: white;">
                <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #fbbf24; margin-bottom: 0.4rem;">Ταξιδιάρης</div>
                <div style="font-size: 1.5rem; font-weight: 700; line-height: 1.2;">Ταξιδιάρης Travel</div>
                <div style="font-size: 0.85rem; opacity: 0.9; margin-top: 0.4rem;">Οργανωμένες εκδρομές σε δεκάδες προορισμούς...</div>
              </div>
            </div>
            <div id="previewEmpty" style={`color: #a0aec0; font-size: 0.85rem; padding: 2rem; text-align: center; border: 1px dashed #cbd5e0; border-radius: 8px; ${config.homeHero ? 'display: none;' : ''}`}>
              Δεν έχει οριστεί εικόνα. Ανέβασε ή κόλλα URL παραπάνω.
            </div>
          </div>
        </div>

      </div>

      <aside style="display: flex; flex-direction: column; gap: 1rem;">
        <div class="card" style="position: sticky; top: 1rem;">
          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
            💾 Αποθήκευση
          </button>
          <div style="margin-top: 0.5rem;" id="status"></div>
          <p style="margin: 0.75rem 0 0; font-size: 0.8rem; color: #718096;">
            Στο production, η αλλαγή κάνει commit στο GitHub και χρειάζεται ~60 δευτερόλεπτα να εμφανιστεί.
          </p>
        </div>

        <div class="card">
          <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem;">Συμβουλές</h3>
          <ul style="margin: 0; padding-left: 1.2rem; font-size: 0.85rem; color: #4a5568; line-height: 1.6;">
            <li>Διάσταση: ιδανικά πλατύ (16:9 ή πιο πλατύ).</li>
            <li>Ποιότητα: τουλάχιστον 1600px πλάτος.</li>
            <li>Φωτεινότητα: όχι πολύ έντονο φως — υπάρχει σκούρο overlay για ευανάγνωστο τίτλο.</li>
          </ul>
        </div>
      </aside>
    </div>
  </form>

  <script is:inline define:vars={{ initialJson }}>
    const initial = JSON.parse(initialJson);
    const form = document.getElementById('editForm');

    function setHeroPreview(url) {
      const img = document.getElementById('heroPreview');
      const wrap = document.getElementById('previewWrap');
      const empty = document.getElementById('previewEmpty');
      if (url) {
        img.src = url;
        wrap.style.display = '';
        empty.style.display = 'none';
      } else {
        img.removeAttribute('src');
        wrap.style.display = 'none';
        empty.style.display = '';
      }
    }

    // Hero URL change → live preview
    form.querySelector('[name=homeHero]').addEventListener('input', (e) => setHeroPreview(e.target.value.trim()));

    // Upload hero image to Supabase
    async function uploadFile(file, folder) {
      const fd = new FormData();
      fd.append('file', file);
      fd.append('folder', folder);
      const r = await fetch('/api/admin/upload', { method: 'POST', body: fd });
      if (!r.ok) throw new Error(await r.text());
      return (await r.json()).url;
    }
    document.getElementById('heroUploadBtn').addEventListener('click', () => document.getElementById('heroUpload').click());
    document.getElementById('heroUpload').addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const status = document.getElementById('heroUploadStatus');
      status.innerHTML = '<span class="spinner"></span> Upload...';
      try {
        const url = await uploadFile(file, 'home');
        form.querySelector('[name=homeHero]').value = url;
        setHeroPreview(url);
        status.innerHTML = '<span style="color:#10b981;">✓ Ανέβηκε — μην ξεχάσεις Αποθήκευση</span>';
        toast('Hero ανέβηκε — πάτα Αποθήκευση', 'success');
      } catch (err) {
        status.innerHTML = `<span style="color:#c53030;">✗ ${String(err.message || err).slice(0, 200)}</span>`;
      } finally {
        e.target.value = '';
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = document.getElementById('status');
      status.innerHTML = '<span class="spinner"></span> Αποθήκευση...';
      const fd = new FormData(form);
      const r = await fetch('/api/admin/site', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          homeHero: fd.get('homeHero') || '',
          homeHeroAlt: fd.get('homeHeroAlt') || '',
        }),
      });
      if (r.ok) {
        status.innerHTML = '<span style="color: #10b981;">✓ Αποθηκεύτηκε</span>';
        setTimeout(() => status.innerHTML = '', 4000);
        toast('Αποθηκεύτηκε', 'success');
      } else {
        status.innerHTML = '<span style="color: #c53030;">✗ Σφάλμα</span>';
        toast('Σφάλμα: ' + (await r.text()).slice(0, 100), 'error');
      }
    });
  </script>
</AdminLayout>
