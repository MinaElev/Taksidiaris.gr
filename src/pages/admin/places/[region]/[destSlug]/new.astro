---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { readDestination, listPlacesForDestination, type Region } from '@lib/content-io';

const region = Astro.params.region as Region;
const destSlug = Astro.params.destSlug as string;

if (!['ellada', 'europi', 'kosmos'].includes(region)) {
  return Astro.redirect('/admin/places');
}

// Sanity check: destination must exist
let destEntry;
try {
  destEntry = await readDestination(region, destSlug);
} catch {
  return Astro.redirect('/admin/places');
}

// Existing place slugs in this destination — used for client-side collision warning
const existingPlaces = await listPlacesForDestination(destSlug);
const existingSlugs = existingPlaces.map((p) => p.placeSlug);
const existingSlugsJson = JSON.stringify(existingSlugs);

const TYPE_OPTIONS: { value: string; label: string }[] = [
  { value: 'landmark', label: 'Τοπόσημο' },
  { value: 'beach', label: 'Παραλία' },
  { value: 'monument', label: 'Μνημείο' },
  { value: 'museum', label: 'Μουσείο' },
  { value: 'village', label: 'Οικισμός' },
  { value: 'island', label: 'Νησί' },
  { value: 'park', label: 'Φυσικό Πάρκο' },
  { value: 'species', label: 'Άγρια Ζωή / Είδος' },
  { value: 'experience', label: 'Εμπειρία' },
];
---
<AdminLayout title={`Νέο place — ${destEntry.data.title}`}>
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
    <a href="/admin/places" style="color: #718096;">← Places</a>
    <h1 style="margin: 0; font-size: 1.4rem; flex: 1;">Νέο place στον προορισμό {destEntry.data.title}</h1>
  </div>

  <form id="newForm">
    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem;">
      <div style="display: flex; flex-direction: column; gap: 1rem;">

        <div class="card">
          <div class="row">
            <div class="field">
              <label>URL slug (πεζά, αγγλικά ή ελληνικά, με παύλες)</label>
              <input type="text" name="slug" required placeholder="π.χ. palia-alonnisos" pattern="[a-z0-9αβγδεζηθικλμνξοπρστυφχψω\-]+" />
              <div class="hint" id="slugHint">Θα φτιάξει το URL: /proorismoi/{region}/{destSlug}/<span id="slugPreview" style="font-family: monospace;">…</span></div>
            </div>
            <div class="field" style="max-width: 200px;">
              <label>Τύπος</label>
              <select name="type">
                {TYPE_OPTIONS.map((t) => (
                  <option value={t.value}>{t.label}</option>
                ))}
              </select>
            </div>
          </div>
          <div class="field">
            <label>Τίτλος</label>
            <input type="text" name="title" required />
          </div>
          <div class="field">
            <label>Tagline (μία γραμμή)</label>
            <input type="text" name="tagline" />
          </div>
          <div class="field">
            <label>SEO Description (140-180 χαρακτήρες)</label>
            <textarea name="description" rows="2" required></textarea>
            <div class="hint" id="descCount"></div>
          </div>
          <div class="field">
            <label>Intro (παράγραφος στην αρχή του άρθρου)</label>
            <textarea name="intro" rows="3"></textarea>
          </div>
          <div class="field">
            <label>Hero image (προαιρετικό — μπορείς να ανεβάσεις και αργότερα)</label>
            <input type="text" name="hero" placeholder="URL εικόνας" />
          </div>
        </div>

        <div class="card">
          <div class="field">
            <label>SEO Keywords (1 ανά γραμμή)</label>
            <textarea name="keywords" rows="4"></textarea>
          </div>
        </div>

        <div class="card">
          <div class="field">
            <label>Κύριο σώμα κειμένου (Markdown)</label>
            <textarea name="body" rows="18" style="font-family: ui-monospace, Menlo, monospace; font-size: 0.85rem;">## Εισαγωγή

</textarea>
            <div class="hint">Μπορείς να αφήσεις κενό προσωρινά και να το γεμίσεις μετά.</div>
          </div>
        </div>

      </div>

      <aside style="display: flex; flex-direction: column; gap: 1rem;">
        <div class="card" style="position: sticky; top: 1rem;">
          <div class="field">
            <label>
              <input type="checkbox" name="draft" style="width: auto; margin-right: 0.5rem;" checked />
              Draft (μη δημοσιευμένο)
            </label>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
            ✨ Δημιουργία
          </button>
          <div style="margin-top: 0.5rem;" id="status"></div>
          <div class="hint" style="margin-top: 0.5rem;">Μετά τη δημιουργία θα μεταφερθείς στη σελίδα επεξεργασίας όπου μπορείς να ανεβάσεις εικόνα και να προσθέσεις FAQs/sources.</div>
        </div>

        <div class="card">
          <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem;">Στοιχεία</h3>
          <div style="font-size: 0.85rem; color: #4a5568; line-height: 1.6;">
            <div><strong>Προορισμός:</strong> {destEntry.data.title}</div>
            <div><strong>Περιοχή:</strong> {region}</div>
            <div><strong>Υπάρχοντα places:</strong> {existingPlaces.length}</div>
          </div>
        </div>
      </aside>
    </div>
  </form>

  <script is:inline define:vars={{ region, destSlug, existingSlugsJson }}>
    const existing = new Set(JSON.parse(existingSlugsJson));
    const form = document.getElementById('newForm');
    const slugInput = form.querySelector('[name=slug]');
    const slugPreview = document.getElementById('slugPreview');
    const slugHint = document.getElementById('slugHint');

    slugInput.addEventListener('input', () => {
      const v = slugInput.value.trim().toLowerCase().replace(/\s+/g, '-');
      slugInput.value = v;
      slugPreview.textContent = v || '…';
      if (existing.has(v)) {
        slugHint.style.color = '#c53030';
        slugHint.innerHTML = `⚠ Το slug «${v}» υπάρχει ήδη — διάλεξε άλλο.`;
      } else if (v) {
        slugHint.style.color = '#10b981';
        slugHint.innerHTML = `URL: /proorismoi/${region}/${destSlug}/<span style="font-family: monospace;">${v}</span>`;
      } else {
        slugHint.style.color = '#718096';
        slugHint.innerHTML = `URL: /proorismoi/${region}/${destSlug}/<span style="font-family: monospace;">…</span>`;
      }
    });

    // Description char counter
    const descTa = form.querySelector('[name=description]');
    const descCount = document.getElementById('descCount');
    function updateDesc() {
      const n = descTa.value.length;
      const ok = n >= 140 && n <= 180;
      descCount.textContent = `${n} χαρακτήρες ${ok ? '✓' : '(ιδανικά 140-180)'}`;
      descCount.style.color = ok ? '#10b981' : '#718096';
    }
    descTa.addEventListener('input', updateDesc);
    updateDesc();

    // Submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = document.getElementById('status');
      const fd = new FormData(form);
      const slug = String(fd.get('slug') || '').trim();
      if (!slug) {
        status.innerHTML = '<span style="color:#c53030;">Χρειάζεται slug</span>';
        return;
      }
      if (existing.has(slug)) {
        status.innerHTML = '<span style="color:#c53030;">Το slug υπάρχει ήδη</span>';
        return;
      }
      status.innerHTML = '<span class="spinner"></span> Δημιουργία...';
      const payload = {
        title: fd.get('title'),
        description: fd.get('description'),
        type: fd.get('type') || 'landmark',
        hero: fd.get('hero') || undefined,
        intro: fd.get('intro') || undefined,
        tagline: fd.get('tagline') || undefined,
        keywords: String(fd.get('keywords') || '').split('\n').map(s => s.trim()).filter(Boolean),
        faqs: [],
        sources: [],
        relatedPlaces: [],
        draft: fd.has('draft'),
        body: fd.get('body') || '',
      };
      const r = await fetch(`/api/admin/place/${region}/${destSlug}/${slug}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (r.ok) {
        status.innerHTML = '<span style="color:#10b981;">✓ Δημιουργήθηκε, μεταφέρεσαι...</span>';
        setTimeout(() => {
          window.location.href = `/admin/places/${region}/${destSlug}/${slug}`;
        }, 500);
      } else {
        const err = await r.text();
        status.innerHTML = `<span style="color:#c53030;">✗ ${err.slice(0, 160)}</span>`;
      }
    });
  </script>
</AdminLayout>
