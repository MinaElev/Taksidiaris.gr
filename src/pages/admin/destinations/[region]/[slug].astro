---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { readDestination, type Region } from '@lib/content-io';

const region = Astro.params.region as Region;
const slug = Astro.params.slug as string;

if (!['ellada', 'europi', 'kosmos'].includes(region)) {
  return Astro.redirect('/admin/destinations');
}

let entry;
try {
  entry = await readDestination(region, slug);
} catch {
  return Astro.redirect('/admin/destinations');
}

const d = entry.data;
const initialJson = JSON.stringify({ ...d, _body: entry.body });
---
<AdminLayout title={`Επεξεργασία: ${d.title}`}>
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
    <a href="/admin/destinations" style="color: #718096;">← Πίσω</a>
    <h1 style="margin: 0; font-size: 1.4rem; flex: 1;">{d.title}</h1>
    <a href={`/proorismoi/${region}/${slug}`} target="_blank" class="btn btn-secondary">
      Δες στο site →
    </a>
  </div>

  <form id="editForm">
    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem;">
      <div style="display: flex; flex-direction: column; gap: 1rem;">

        <div class="card">
          <div class="field">
            <label>Τίτλος</label>
            <input type="text" name="title" value={d.title} required />
          </div>
          <div class="field">
            <label>SEO Description (160-180 χαρακτήρες)</label>
            <textarea name="description" rows="2" required>{d.description}</textarea>
            <div class="hint" id="descCount"></div>
          </div>
          <div class="field">
            <label>Intro (1 παράγραφος, εμφανίζεται κάτω από τον τίτλο)</label>
            <textarea name="intro" rows="3">{d.intro || ''}</textarea>
          </div>
          <div class="row">
            <div class="field">
              <label>Καλύτερη εποχή</label>
              <input type="text" name="bestTime" value={d.bestTime || ''} placeholder="π.χ. Μάιος – Σεπτέμβριος" />
            </div>
            <div class="field">
              <label>Διάρκεια</label>
              <input type="text" name="duration" value={d.duration || ''} placeholder="π.χ. 4-6 ημέρες" />
            </div>
          </div>
          <div class="field">
            <label>Hero image</label>
            <div style="display: flex; gap: 0.5rem; align-items: stretch;">
              <input type="text" name="hero" value={d.hero || ''} placeholder="URL ή πάτα Upload" style="flex: 1;" />
              <input type="file" id="heroUpload" accept="image/*" style="display: none;" />
              <button type="button" id="heroUploadBtn" class="btn btn-secondary" style="white-space: nowrap;">📷 Upload</button>
            </div>
            <img id="heroPreview" src={d.hero || ''} alt="" style={`margin-top: 0.5rem; max-height: 140px; border-radius: 6px; ${d.hero ? '' : 'display: none;'}`} />
            <div class="hint" id="heroUploadStatus">Φωτογραφία που εμφανίζεται ως φόντο στο hero και ως thumbnail στις λίστες.</div>
          </div>
        </div>

        <div class="card">
          <div class="field">
            <label>Highlights (1 ανά γραμμή)</label>
            <textarea name="highlights" rows="6">{(d.highlights || []).join('\n')}</textarea>
          </div>
        </div>

        <div class="card">
          <label style="font-weight: 600; font-size: 0.85rem; color: #4a5568; display: block; margin-bottom: 0.5rem;">
            Συχνές ερωτήσεις (FAQs)
          </label>
          <div id="faqsContainer"></div>
          <button type="button" id="addFaq" class="btn btn-secondary" style="margin-top: 0.5rem;">+ Προσθήκη FAQ</button>
        </div>

        <div class="card">
          <div class="field">
            <label>SEO Keywords (1 ανά γραμμή)</label>
            <textarea name="keywords" rows="4">{(d.keywords || []).join('\n')}</textarea>
          </div>
        </div>

        <div class="card">
          <div class="field">
            <label>Κύριο σώμα κειμένου (Markdown)</label>
            <textarea name="body" rows="22" style="font-family: ui-monospace, Menlo, monospace; font-size: 0.85rem;">{entry.body}</textarea>
            <div class="hint">Χρησιμοποίησε ## για επικεφαλίδες, **bold**, - για λίστες.</div>
          </div>
        </div>

      </div>

      <aside style="display: flex; flex-direction: column; gap: 1rem;">
        <div class="card" style="position: sticky; top: 1rem;">
          <div class="field">
            <label>
              <input type="checkbox" name="draft" checked={d.draft} style="width: auto; margin-right: 0.5rem;" />
              Draft (μη δημοσιευμένο)
            </label>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
            💾 Αποθήκευση
          </button>
          <div style="margin-top: 0.5rem;" id="status"></div>
        </div>

        <div class="card">
          <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem;">🤖 Δημιουργία με AI (web_search)</h3>
          <p style="margin: 0 0 0.75rem; font-size: 0.85rem; color: #718096;">
            Το AI ψάχνει στο web (4-6 queries) για ενημερωμένα στοιχεία και cross-link με τα ξενοδοχεία/εκδρομές μας.
          </p>
          <button type="button" id="aiGenerate" class="btn btn-ai" style="width: 100%; justify-content: center;">
            ✨ Δημιουργία περιεχομένου
          </button>
          <div style="margin-top: 0.5rem;" id="aiStatus"></div>
          <ol id="statusLog" style="margin: 0.6rem 0 0; padding-left: 1.2rem; font-size: 0.78rem; color: #4a5568; max-height: 140px; overflow-y: auto; display: none;"></ol>
          <details id="aiPreview" style="margin-top: 0.5rem; display: none;">
            <summary style="font-size: 0.78rem; color: #718096; cursor: pointer;">Προεπισκόπηση tokens AI</summary>
            <pre id="aiPreviewText" style="font-size: 0.7rem; max-height: 160px; overflow: auto; background: #f7fafc; padding: 0.5rem; border-radius: 4px; white-space: pre-wrap; word-break: break-word;"></pre>
          </details>
        </div>

        <div class="card" id="aiMissingPanel" style="display: none; border: 1px solid #fbd38d; background: #fffaf0;">
          <h3 style="margin: 0 0 0.4rem; font-size: 0.9rem; color: #c05621;">⚠ Πεδία που δεν επιβεβαιώθηκαν</h3>
          <ul id="aiMissingList" style="margin: 0; padding-left: 1.1rem; font-size: 0.78rem; color: #7b341e;"></ul>
        </div>

        <div class="card" id="aiSourcesPanel" style="display: none;">
          <h3 style="margin: 0 0 0.4rem; font-size: 0.9rem;">🔗 Πηγές AI</h3>
          <ul id="aiSourcesList" style="margin: 0; padding-left: 1.1rem; font-size: 0.78rem; color: #4a5568; word-break: break-all;"></ul>
        </div>

        <div class="card" id="aiHeroPanel" style="display: none;">
          <h3 style="margin: 0 0 0.4rem; font-size: 0.9rem;">📷 Υποψήφιες εικόνες hero</h3>
          <p style="font-size: 0.75rem; color: #718096; margin: 0 0 0.5rem;">Πάτα μία για να την κάνεις hero.</p>
          <div id="aiHeroGrid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem; max-height: 280px; overflow-y: auto;"></div>
        </div>

        <div class="card">
          <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem;">Στοιχεία</h3>
          <div style="font-size: 0.85rem; color: #4a5568;">
            <div><strong>Slug:</strong> {slug}</div>
            <div><strong>Περιοχή:</strong> {region}</div>
            <div><strong>URL:</strong> /proorismoi/{region}/{slug}</div>
          </div>
        </div>
      </aside>
    </div>
  </form>

  <script is:inline define:vars={{ region, slug, initialJson }}>
    const initial = JSON.parse(initialJson);
    const form = document.getElementById('editForm');

    // FAQs management
    const faqsContainer = document.getElementById('faqsContainer');
    function renderFaq(q = '', a = '') {
      const id = Math.random().toString(36).slice(2);
      const div = document.createElement('div');
      div.className = 'faq-item';
      div.style.cssText = 'border: 1px solid #e2e8f0; border-radius: 6px; padding: 0.75rem; margin-bottom: 0.5rem; background: #f7fafc;';
      div.innerHTML = `
        <input type="text" placeholder="Ερώτηση" value="" style="margin-bottom: 0.4rem;" data-faq-q />
        <textarea placeholder="Απάντηση" rows="3" data-faq-a></textarea>
        <button type="button" data-remove style="margin-top: 0.4rem; background: none; border: none; color: #c53030; font-size: 0.8rem; cursor: pointer;">× Αφαίρεση</button>
      `;
      div.querySelector('[data-faq-q]').value = q;
      div.querySelector('[data-faq-a]').value = a;
      div.querySelector('[data-remove]').addEventListener('click', () => div.remove());
      faqsContainer.appendChild(div);
    }
    (initial.faqs || []).forEach(f => renderFaq(f.q, f.a));
    document.getElementById('addFaq').addEventListener('click', () => renderFaq());

    // Description char counter
    const descTa = form.querySelector('[name=description]');
    const descCount = document.getElementById('descCount');
    function updateDesc() {
      const n = descTa.value.length;
      const ok = n >= 140 && n <= 180;
      descCount.textContent = `${n} χαρακτήρες ${ok ? '✓' : '(ιδανικά 140-180)'}`;
      descCount.style.color = ok ? '#10b981' : '#718096';
    }
    descTa.addEventListener('input', updateDesc);
    updateDesc();

    // Build payload
    function gatherPayload() {
      const fd = new FormData(form);
      const faqs = Array.from(faqsContainer.querySelectorAll('.faq-item'))
        .map(div => ({
          q: div.querySelector('[data-faq-q]').value.trim(),
          a: div.querySelector('[data-faq-a]').value.trim(),
        }))
        .filter(f => f.q && f.a);
      return {
        title: fd.get('title'),
        description: fd.get('description'),
        region,
        hero: fd.get('hero') || undefined,
        intro: fd.get('intro') || undefined,
        bestTime: fd.get('bestTime') || undefined,
        duration: fd.get('duration') || undefined,
        highlights: String(fd.get('highlights') || '').split('\n').map(s => s.trim()).filter(Boolean),
        faqs,
        keywords: String(fd.get('keywords') || '').split('\n').map(s => s.trim()).filter(Boolean),
        draft: fd.has('draft'),
        body: fd.get('body'),
      };
    }

    function setHeroPreview(url) {
      const img = document.getElementById('heroPreview');
      if (url) {
        img.src = url;
        img.style.display = '';
      } else {
        img.removeAttribute('src');
        img.style.display = 'none';
      }
    }

    function fillForm(data) {
      form.querySelector('[name=title]').value = data.title || '';
      form.querySelector('[name=description]').value = data.description || '';
      form.querySelector('[name=intro]').value = data.intro || '';
      form.querySelector('[name=bestTime]').value = data.bestTime || '';
      form.querySelector('[name=duration]').value = data.duration || '';
      form.querySelector('[name=hero]').value = data.hero || '';
      setHeroPreview(data.hero || '');
      form.querySelector('[name=highlights]').value = (data.highlights || []).join('\n');
      form.querySelector('[name=keywords]').value = (data.keywords || []).join('\n');
      if (data._body !== undefined) form.querySelector('[name=body]').value = data._body;
      faqsContainer.innerHTML = '';
      (data.faqs || []).forEach(f => renderFaq(f.q, f.a));
      updateDesc();
    }

    // Hero URL change → live preview
    form.querySelector('[name=hero]').addEventListener('input', (e) => setHeroPreview(e.target.value.trim()));

    // Upload hero image to Supabase
    async function uploadFile(file, folder) {
      const fd = new FormData();
      fd.append('file', file);
      fd.append('folder', folder);
      const r = await fetch('/api/admin/upload', { method: 'POST', body: fd });
      if (!r.ok) throw new Error(await r.text());
      return (await r.json()).url;
    }
    document.getElementById('heroUploadBtn').addEventListener('click', () => document.getElementById('heroUpload').click());
    document.getElementById('heroUpload').addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const status = document.getElementById('heroUploadStatus');
      status.innerHTML = '<span class="spinner"></span> Upload...';
      try {
        const url = await uploadFile(file, `destinations-${region}`);
        form.querySelector('[name=hero]').value = url;
        setHeroPreview(url);
        status.innerHTML = '<span style="color:#10b981;">✓ Ανέβηκε — μην ξεχάσεις Αποθήκευση</span>';
        toast('Hero ανέβηκε — πάτα Αποθήκευση', 'success');
      } catch (err) {
        status.innerHTML = `<span style="color:#c53030;">✗ ${String(err.message || err).slice(0, 200)}</span>`;
      } finally {
        e.target.value = '';
      }
    });

    // Save
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = document.getElementById('status');
      status.innerHTML = '<span class="spinner"></span> Αποθήκευση...';
      const payload = gatherPayload();
      const r = await fetch(`/api/admin/destination/${region}/${slug}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (r.ok) {
        status.innerHTML = '<span style="color: #10b981;">✓ Αποθηκεύτηκε</span>';
        setTimeout(() => status.innerHTML = '', 2500);
        toast('Αποθηκεύτηκε', 'success');
      } else {
        const err = await r.text();
        status.innerHTML = `<span style="color: #c53030;">✗ Σφάλμα</span>`;
        toast('Σφάλμα: ' + err.slice(0, 100), 'error');
      }
    });

    // AI generate — SSE-based with web_search grounding
    document.getElementById('aiGenerate').addEventListener('click', async () => {
      if (!confirm('Το AI θα αντικαταστήσει το τρέχον περιεχόμενο. Συνέχεια;')) return;
      const btn = document.getElementById('aiGenerate');
      const status = document.getElementById('aiStatus');
      const log = document.getElementById('statusLog');
      const preview = document.getElementById('aiPreview');
      const previewText = document.getElementById('aiPreviewText');
      const missingPanel = document.getElementById('aiMissingPanel');
      const missingList = document.getElementById('aiMissingList');
      const sourcesPanel = document.getElementById('aiSourcesPanel');
      const sourcesList = document.getElementById('aiSourcesList');
      const heroPanel = document.getElementById('aiHeroPanel');
      const heroGrid = document.getElementById('aiHeroGrid');

      btn.disabled = true;
      status.innerHTML = '<span class="spinner"></span> Έναρξη web_search…';
      log.innerHTML = '';
      log.style.display = 'block';
      preview.style.display = 'block';
      previewText.textContent = '';
      missingPanel.style.display = 'none';
      sourcesPanel.style.display = 'none';
      heroPanel.style.display = 'none';

      const addLog = (msg) => {
        const li = document.createElement('li');
        li.textContent = msg;
        log.appendChild(li);
        log.scrollTop = log.scrollHeight;
      };

      try {
        await window.streamSSE('/api/admin/ai/destination', { region, slug, name: initial.title }, {
          status: (msg) => { addLog(typeof msg === 'string' ? msg : JSON.stringify(msg)); },
          token: (delta) => {
            previewText.textContent += String(delta);
            previewText.scrollTop = previewText.scrollHeight;
          },
          done: (data) => {
            fillForm(data);
            // Sources panel
            if (Array.isArray(data.sources) && data.sources.length) {
              sourcesPanel.style.display = '';
              sourcesList.innerHTML = '';
              for (const s of data.sources) {
                const li = document.createElement('li');
                const a = document.createElement('a');
                a.href = s; a.target = '_blank'; a.rel = 'noopener';
                a.textContent = s;
                li.appendChild(a);
                sourcesList.appendChild(li);
              }
            }
            // Missing-fields panel
            if (Array.isArray(data._missing) && data._missing.length) {
              missingPanel.style.display = '';
              missingList.innerHTML = '';
              for (const f of data._missing) {
                const li = document.createElement('li');
                li.textContent = f;
                missingList.appendChild(li);
              }
            }
            // Hero candidate picker
            const candidates = Array.isArray(data._heroCandidates) ? data._heroCandidates : [];
            if (candidates.length) {
              heroPanel.style.display = '';
              heroGrid.innerHTML = '';
              for (const url of candidates) {
                const wrap = document.createElement('button');
                wrap.type = 'button';
                wrap.style.cssText = 'border: 2px solid transparent; padding: 0; background: #f7fafc; cursor: pointer; border-radius: 4px; overflow: hidden;';
                wrap.title = 'Όρισε ως hero';
                const img = document.createElement('img');
                img.src = url;
                img.loading = 'lazy';
                img.style.cssText = 'width: 100%; height: 80px; object-fit: cover; display: block;';
                img.onerror = () => { wrap.remove(); };
                wrap.appendChild(img);
                wrap.addEventListener('click', () => {
                  form.querySelector('[name=hero]').value = url;
                  setHeroPreview(url);
                  heroGrid.querySelectorAll('button').forEach((b) => b.style.borderColor = 'transparent');
                  wrap.style.borderColor = '#3b82f6';
                  toast('Hero ορίστηκε — μην ξεχάσεις Αποθήκευση', 'success');
                });
                heroGrid.appendChild(wrap);
              }
            }
            const ctx = data._dbContext || {};
            const ctxNote = (ctx.hotels || ctx.tours)
              ? ` · ${ctx.hotels || 0} ξενοδ. + ${ctx.tours || 0} εκδρ. cross-linked`
              : '';
            status.innerHTML = `<span style="color: #10b981;">✓ Έτοιμο${ctxNote}. Έλεγξε και πάτα Αποθήκευση.</span>`;
            toast('Νέο περιεχόμενο δημιουργήθηκε', 'success');
          },
          error: (err) => {
            const msg = (err && err.message) || String(err);
            status.innerHTML = `<span style="color: #c53030;">✗ ${msg.slice(0, 200)}</span>`;
            toast('AI σφάλμα', 'error');
          },
        });
      } catch (err) {
        status.innerHTML = `<span style="color: #c53030;">✗ ${(err.message || String(err)).slice(0, 200)}</span>`;
        toast('AI σφάλμα', 'error');
      } finally {
        btn.disabled = false;
      }
    });
  </script>
  <script is:inline src="/admin-sse.js"></script>
</AdminLayout>
