---
import type { TourFrontmatter } from '@lib/content-io';
import SmartImage from './SmartImage.astro';
import { isTourExpired } from '@lib/tour-status';

// Accepts both shapes:
//   • CollectionEntry<'tours'> from astro:content (`entry.id` = slug)
//   • TourRecord from tours-db.ts                  (`entry.slug` = slug)
// We prefer `slug` if present, falling back to `id`.
interface Props {
  entry: { slug?: string; id?: string; data: TourFrontmatter };
}
const { entry } = Astro.props;
const t = entry.data;
const slug = entry.slug ?? entry.id ?? '';
const href = `/ekdromi/${slug}`;

// --- Format the next upcoming departure date in Greek ---
const GR_MONTHS = ['Ιαν', 'Φεβ', 'Μαρ', 'Απρ', 'Μαϊ', 'Ιουν', 'Ιουλ', 'Αυγ', 'Σεπ', 'Οκτ', 'Νοε', 'Δεκ'];
function fmtDateRange(fromStr: string, toStr: string): string {
  const from = new Date(fromStr);
  const to = new Date(toStr);
  if (isNaN(from.getTime()) || isNaN(to.getTime())) return '';
  const d1 = from.getDate(), m1 = from.getMonth(), y1 = from.getFullYear();
  const d2 = to.getDate(),   m2 = to.getMonth(),   y2 = to.getFullYear();
  // Same month + year: "16-20 Ιουλ 2026"
  if (y1 === y2 && m1 === m2) return `${d1}-${d2} ${GR_MONTHS[m1]} ${y1}`;
  // Same year, different months: "30 Ιουλ - 3 Αυγ 2026"
  if (y1 === y2) return `${d1} ${GR_MONTHS[m1]} - ${d2} ${GR_MONTHS[m2]} ${y1}`;
  // Different years: "30 Δεκ 2026 - 3 Ιαν 2027"
  return `${d1} ${GR_MONTHS[m1]} ${y1} - ${d2} ${GR_MONTHS[m2]} ${y2}`;
}
// Pick the next upcoming date (or the first if all past)
const today = new Date();
today.setHours(0, 0, 0, 0);
const upcoming = (t.dates ?? [])
  .map((d) => ({ ...d, _from: new Date(d.from) }))
  .sort((a, b) => a._from.getTime() - b._from.getTime());
const nextDate = upcoming.find((d) => d._from >= today) ?? upcoming[0];
const dateLabel = nextDate ? fmtDateRange(nextDate.from, nextDate.to) : '';
const nightsLabel = t.duration?.nights ? `${t.duration.nights} ${t.duration.nights === 1 ? 'διανυκτέρευση' : 'διανυκτερεύσεις'}` : '';
const expired = isTourExpired(t.dates);
---
<a href={href} class="card group flex flex-col h-full overflow-hidden">
  <div class="relative aspect-[16/10] bg-gradient-to-br from-brand-300 via-brand-500 to-brand-700 overflow-hidden">
    {t.hero ? (
      <SmartImage
        src={t.hero}
        alt={t.title}
        width={800}
        height={500}
        sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        class="size-full object-cover group-hover:scale-105 transition-transform duration-700"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center text-white text-2xl font-display font-bold text-center px-6 text-balance">
        {t.destination}
      </div>
    )}

    {/* Bottom gradient for readability of overlay chips */}
    {(dateLabel || nightsLabel) && (
      <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/65 via-black/25 to-transparent pointer-events-none"></div>
    )}

    {/* Date + nights chips, bottom-left */}
    {(dateLabel || nightsLabel) && (
      <div class="absolute bottom-3 left-3 right-3 flex flex-wrap items-center gap-1.5">
        {dateLabel && (
          <span class="inline-flex items-center gap-1.5 bg-white/95 backdrop-blur-sm rounded-full pl-2 pr-2.5 py-1 text-[11px] font-semibold text-ink-900 shadow-soft">
            <svg class="size-3.5 text-brand-600" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="3" y="4.5" width="14" height="13" rx="2" stroke="currentColor" stroke-width="1.6"/>
              <path d="M3 8.5h14M7 3v3M13 3v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
            {dateLabel}
          </span>
        )}
        {nightsLabel && (
          <span class="inline-flex items-center gap-1.5 bg-white/95 backdrop-blur-sm rounded-full pl-2 pr-2.5 py-1 text-[11px] font-semibold text-ink-900 shadow-soft">
            <svg class="size-3.5 text-brand-600" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M14.5 11.5a5.5 5.5 0 1 1-6-6 4.5 4.5 0 0 0 6 6Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
            {nightsLabel}
          </span>
        )}
      </div>
    )}

    {t.priceFrom && !expired && (
      <div class="absolute top-3 right-3 bg-white/95 rounded-lg px-3 py-1.5 text-sm shadow-soft">
        <span class="text-xs text-ink-600">από</span>
        <span class="ml-1 font-display font-bold text-brand-700">{t.currency || '€'}{t.priceFrom}</span>
      </div>
    )}
    {expired && (
      <div class="absolute top-3 right-3 bg-ink-800/90 backdrop-blur-sm text-white rounded-full px-3 py-1 text-xs font-semibold shadow-soft">
        Ολοκληρώθηκε
      </div>
    )}
  </div>
  <div class="p-5 flex flex-col flex-1">
    <p class="text-xs uppercase tracking-wider text-brand-600 font-semibold mb-1.5">
      {t.destination} · {t.duration.days} ημέρες
    </p>
    <h3 class="text-lg font-semibold text-ink-950 group-hover:text-brand-700 transition-colors text-balance line-clamp-2">
      {t.title}
    </h3>
    {t.intro && (
      <p class="mt-2 text-sm text-ink-600 line-clamp-2">{t.intro}</p>
    )}
    <div class="mt-4 flex items-center justify-between">
      <span class="text-xs text-ink-500">
        {(() => {
          const cities = t.departureCities ?? [];
          return cities.length > 0 && `Από ${cities[0]}${cities.length > 1 ? ` +${cities.length - 1}` : ''}`;
        })()}
      </span>
      <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-700">
        Δες πρόγραμμα
        <svg class="size-4 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </div>
</a>
