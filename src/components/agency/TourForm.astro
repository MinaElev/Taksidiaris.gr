---
// Tour editor form for the agency portal. Handles BOTH create (no `tour`
// prop) and edit (passes `tour`). The submit handler lives in the page
// itself so we can route to POST /api/agency/tour vs PUT /api/agency/tour/[slug].
//
// Scope: this is intentionally a *minimal* editor — title, description,
// destination, region, duration, price, transport, departure cities, hero,
// body, draft. Rich JSONB fields (itinerary, hotels, pricing tables, faqs)
// are preserved server-side and editable only via Mina's admin panel for now.

import type { TourFrontmatter } from '@lib/content-io';
import { REGION_LABEL } from '@lib/site';

interface Props {
  tour?: { slug: string; data: TourFrontmatter; body: string } | null;
}
const { tour } = Astro.props;
const d = tour?.data;
const isEdit = !!tour;
---
<form id="tourForm">
  <div style="display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem;">
    <div style="display: flex; flex-direction: column; gap: 1rem;">

      <!-- Basics -->
      <div class="card">
        <h2 style="margin: 0 0 0.75rem; font-size: 1rem; color: #4a5568;">Βασικά</h2>
        <div class="field">
          <label>Τίτλος *</label>
          <input type="text" name="title" value={d?.title || ''} required placeholder="π.χ. Βουδαπέστη — Formula 1" />
        </div>
        <div class="field">
          <label>SEO Description (140-180 χαρακτήρες) *</label>
          <textarea name="description" rows="2" required placeholder="Σύντομη περιγραφή της εκδρομής για Google.">{d?.description || ''}</textarea>
          <div class="hint" id="descCount"></div>
        </div>
        <div class="row">
          <div class="field">
            <label>Προορισμός *</label>
            <input type="text" name="destination" value={d?.destination || ''} required placeholder="π.χ. Βουδαπέστη" />
            <div class="hint">Το όνομα του προορισμού όπως θα εμφανίζεται.</div>
          </div>
          <div class="field">
            <label>Περιοχή *</label>
            <select name="region" required>
              <option value="ellada" selected={d?.region === 'ellada'}>{REGION_LABEL.ellada}</option>
              <option value="europi" selected={d?.region === 'europi' || !d}>{REGION_LABEL.europi}</option>
              <option value="kosmos" selected={d?.region === 'kosmos'}>{REGION_LABEL.kosmos}</option>
            </select>
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label>Διάρκεια — ημέρες *</label>
            <input type="number" name="days" value={d?.duration.days ?? 4} min="1" required />
          </div>
          <div class="field">
            <label>Διάρκεια — νύχτες *</label>
            <input type="number" name="nights" value={d?.duration.nights ?? 3} min="0" required />
          </div>
          <div class="field">
            <label>Μεταφορά</label>
            <select name="transport">
              <option value="">— επιλογή —</option>
              <option value="αεροπορικώς" selected={d?.transport === 'αεροπορικώς'}>αεροπορικώς</option>
              <option value="οδικώς" selected={d?.transport === 'οδικώς'}>οδικώς</option>
              <option value="ακτοπλοϊκώς" selected={d?.transport === 'ακτοπλοϊκώς'}>ακτοπλοϊκώς</option>
              <option value="συνδυαστικά" selected={d?.transport === 'συνδυαστικά'}>συνδυαστικά</option>
            </select>
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label>Τιμή από</label>
            <input type="number" name="priceFrom" value={d?.priceFrom ?? ''} step="1" placeholder="π.χ. 590" />
          </div>
          <div class="field">
            <label>Νόμισμα</label>
            <input type="text" name="currency" value={d?.currency || '€'} />
          </div>
          <div class="field">
            <label>Period (slug)</label>
            <input type="text" name="period" value={d?.period || ''} placeholder="π.χ. pasxa" />
            <div class="hint">προαιρετικό</div>
          </div>
        </div>
        <div class="field">
          <label>Πόλεις αναχώρησης</label>
          <input type="text" name="departureCities" value={(d?.departureCities || []).join(', ')} placeholder="Αθήνα, Θεσσαλονίκη" />
          <div class="hint">Χωρισμένες με κόμμα.</div>
        </div>
      </div>

      <!-- Hero + intro -->
      <div class="card">
        <h2 style="margin: 0 0 0.75rem; font-size: 1rem; color: #4a5568;">Εικόνα & εισαγωγή</h2>
        <div class="field">
          <label>Hero image (URL)</label>
          <input type="text" name="hero" value={d?.hero || ''} placeholder="https://..." />
          <div class="hint">Η κύρια εικόνα στην κορυφή της σελίδας. Μπορείς να την ανεβάσεις στο Supabase Storage και να επικολλήσεις το URL.</div>
        </div>
        <div class="field">
          <label>Εισαγωγικό κείμενο (intro)</label>
          <textarea name="intro" rows="3" placeholder="Σύντομο εισαγωγικό κείμενο που εμφανίζεται κάτω από τον τίτλο.">{d?.intro || ''}</textarea>
        </div>
      </div>

      <!-- Body -->
      <div class="card">
        <h2 style="margin: 0 0 0.75rem; font-size: 1rem; color: #4a5568;">Κυρίως κείμενο (markdown)</h2>
        <div class="field">
          <textarea name="body" rows="14" placeholder="## Τι περιλαμβάνει η εκδρομή&#10;&#10;...&#10;&#10;## Πρόγραμμα&#10;&#10;...">{tour?.body || ''}</textarea>
          <div class="hint">Markdown. Επιτρέπονται τίτλοι ##, λίστες, links, **bold**, _italic_.</div>
        </div>
      </div>

      <!-- Lists -->
      <div class="card">
        <h2 style="margin: 0 0 0.75rem; font-size: 1rem; color: #4a5568;">Λίστες (μία ανά γραμμή)</h2>
        <div class="field">
          <label>Τι περιλαμβάνει</label>
          <textarea name="includes" rows="4" placeholder="Αεροπορικά εισιτήρια&#10;Διανυκτερεύσεις σε ξενοδοχείο 4*&#10;Πρωινό μπουφέ">{(d?.includes || []).join('\n')}</textarea>
        </div>
        <div class="field">
          <label>Τι δεν περιλαμβάνει</label>
          <textarea name="notIncludes" rows="4" placeholder="Φόροι αεροδρομίων&#10;Ταξιδιωτική ασφάλιση">{(d?.notIncludes || []).join('\n')}</textarea>
        </div>
        <div class="field">
          <label>Σημειώσεις</label>
          <textarea name="notes" rows="3">{(d?.notes || []).join('\n')}</textarea>
        </div>
        <div class="field">
          <label>SEO keywords</label>
          <textarea name="keywords" rows="2" placeholder="βουδαπέστη, formula 1, εκδρομή">{(d?.keywords || []).join(', ')}</textarea>
          <div class="hint">Χωρισμένα με κόμμα ή νέα γραμμή.</div>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <div class="card" style="position: sticky; top: 1rem;">
        <h3 style="margin: 0 0 0.75rem; font-size: 1rem;">Δημοσίευση</h3>
        <label style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; cursor: pointer;">
          <input type="checkbox" name="draft" checked={d?.draft ?? true} style="width: auto;" />
          <span>Draft (δεν φαίνεται δημοσίως)</span>
        </label>
        <button type="submit" id="saveBtn" class="btn btn-primary" style="width: 100%; justify-content: center;">
          {isEdit ? 'Αποθήκευση' : 'Δημιουργία εκδρομής'}
        </button>
        {isEdit && (
          <a href={`/ekdromi/${tour!.slug}`} target="_blank" class="btn btn-secondary" style="width: 100%; justify-content: center; margin-top: 0.5rem;">
            Δες στο site →
          </a>
        )}
      </div>

      {isEdit && (
        <div class="card" style="border: 1px solid #fee2e2;">
          <h3 style="margin: 0 0 0.5rem; font-size: 1rem; color: #c53030;">⚠ Διαγραφή</h3>
          <p style="margin: 0 0 0.75rem; font-size: 0.85rem; color: #4a5568;">
            Διαγραφή εκδρομής. Δεν αναιρείται.
          </p>
          <button type="button" id="deleteBtn" class="btn btn-danger" style="width: 100%; justify-content: center;">Διαγραφή</button>
        </div>
      )}

      <div class="card" style="background: #fef3c7;">
        <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem; color: #92400e;">📝 Σημείωση</h3>
        <p style="margin: 0; font-size: 0.82rem; color: #78350f; line-height: 1.5;">
          Για προχωρημένα πεδία (πρόγραμμα ημέρας-ημέρας, ξενοδοχεία, πίνακες τιμών, FAQ), επικοινώνησε με τη <strong>Mina</strong>.
          Θα προστεθούν editors σύντομα.
        </p>
      </div>
    </div>
  </div>
</form>

<script is:inline>
  // Live char counter for SEO description
  const desc = document.querySelector('textarea[name="description"]');
  const count = document.getElementById('descCount');
  function updateCount() {
    const n = desc.value.length;
    let color = '#10b981';
    if (n < 120 || n > 200) color = '#c53030';
    else if (n < 140 || n > 180) color = '#f59e0b';
    count.style.color = color;
    count.textContent = n + ' χαρακτήρες (στόχος 140-180)';
  }
  if (desc && count) {
    updateCount();
    desc.addEventListener('input', updateCount);
  }
</script>
