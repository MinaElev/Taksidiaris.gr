---
// Full-featured tour editor for the agency portal. Handles BOTH create
// (no `tour` prop) and edit (passes `tour`). The submit handler lives in
// the page itself (new.astro / [slug].astro). This component:
//   - Renders all form fields (basics + structured arrays as repeaters)
//   - Manages add/remove for repeater rows
//   - Exposes window.readTourPayload() that the page calls on submit

import type { TourFrontmatter } from '@lib/content-io';
import { DESTINATIONS } from '@lib/destinations';
import { REGION_LABEL } from '@lib/site';

interface Props {
  tour?: { slug: string; data: TourFrontmatter; body: string } | null;
}
const { tour } = Astro.props;
const d = tour?.data;
const isEdit = !!tour;

// Destination select grouped by region
const destByRegion = {
  ellada: DESTINATIONS.filter((x) => x.region === 'ellada').sort((a, b) => a.name.localeCompare(b.name, 'el')),
  europi: DESTINATIONS.filter((x) => x.region === 'europi').sort((a, b) => a.name.localeCompare(b.name, 'el')),
  kosmos: DESTINATIONS.filter((x) => x.region === 'kosmos').sort((a, b) => a.name.localeCompare(b.name, 'el')),
};

// For editing: serialize structured arrays as JSON for hydration in JS
const initialData = {
  pickupSchedule: d?.pickupSchedule ?? [],
  dates: (d?.dates ?? []).map((x) => ({ from: x.from, to: x.to, label: x.label })),
  itinerary: d?.itinerary ?? [],
  hotels: d?.hotels ?? [],
  pricing: d?.pricing ?? [],
  faqs: d?.faqs ?? [],
};

// Map of all known destinations: { name → region } — used by the
// combobox to auto-fill the region field when an existing destination
// is picked, or to know when the typed value is brand new (and we
// should offer to create it).
const destinationsMap: Record<string, string> = {};
for (const x of [...destByRegion.ellada, ...destByRegion.europi, ...destByRegion.kosmos]) {
  destinationsMap[x.name] = x.region;
}
---
<form id="tourForm">
  <div style="display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem;">
    <div style="display: flex; flex-direction: column; gap: 1rem;">

      <!-- 1. Βασικά -->
      <div class="card">
        <h2 style="margin: 0 0 0.75rem; font-size: 1rem; color: #4a5568;">Βασικά</h2>
        <div class="field">
          <label>Τίτλος *</label>
          <input type="text" name="title" value={d?.title || ''} required placeholder="π.χ. Βουδαπέστη — Formula 1" />
        </div>
        <div class="field">
          <label style="display: flex; align-items: center; justify-content: space-between;">
            <span>SEO Description (140-180 χαρακτήρες) *</span>
            <button type="button" class="btn-ai-mini" data-rewrite-target="description" data-rewrite-kind="description">✨ Βελτίωση</button>
          </label>
          <textarea name="description" rows="2" required placeholder="Σύντομη περιγραφή της εκδρομής για Google.">{d?.description || ''}</textarea>
          <div class="hint" id="descCount"></div>
        </div>
        <div class="row">
          <div class="field">
            <label>Προορισμός *</label>
            <input
              type="text"
              name="destination"
              id="destInput"
              list="destOptions"
              required
              autocomplete="off"
              placeholder="Πληκτρολόγησε ή διάλεξε από τη λίστα..."
              value={d?.destination || ''}
            />
            <datalist id="destOptions">
              {destByRegion.ellada.map((x) => (
                <option value={x.name}>{REGION_LABEL.ellada}</option>
              ))}
              {destByRegion.europi.map((x) => (
                <option value={x.name}>{REGION_LABEL.europi}</option>
              ))}
              {destByRegion.kosmos.map((x) => (
                <option value={x.name}>{REGION_LABEL.kosmos}</option>
              ))}
            </datalist>
            <div id="destStatus" class="hint" style="min-height: 1.2rem;"></div>

            <!-- New-destination inline creator (hidden by default) -->
            <div id="destCreatePanel" style="display: none; margin-top: 0.5rem; padding: 0.75rem; background: #fffaf0; border: 1px solid #fed7aa; border-radius: 6px;">
              <div style="font-size: 0.85rem; color: #9a3412; margin-bottom: 0.5rem; font-weight: 600;">
                ⚡ Δημιουργία νέου προορισμού
              </div>
              <p style="margin: 0 0 0.6rem; font-size: 0.78rem; color: #9a3412;">
                Θα δημιουργηθεί ως <strong>draft</strong> — δεν θα φαίνεται δημόσια μέχρι ο admin να το επιβεβαιώσει.
              </p>
              <div style="display: flex; gap: 0.4rem; align-items: end;">
                <div style="flex: 1;">
                  <label style="font-size: 0.75rem; font-weight: 600; color: #9a3412; display: block; margin-bottom: 0.25rem;">Σε ποια περιοχή ανήκει;</label>
                  <select id="newDestRegion" style="width: 100%;">
                    <option value="ellada">Ελλάδα</option>
                    <option value="europi">Ευρώπη</option>
                    <option value="kosmos" selected>Κόσμος</option>
                  </select>
                </div>
                <button type="button" id="createDestBtn" class="btn btn-primary" style="white-space: nowrap;">
                  Δημιουργία
                </button>
                <button type="button" id="cancelDestBtn" class="btn btn-secondary" style="white-space: nowrap;">
                  Ακύρωση
                </button>
              </div>
              <div id="newDestStatus" style="margin-top: 0.5rem; font-size: 0.8rem; min-height: 1rem;"></div>
            </div>
          </div>
          <div class="field">
            <label>Περιοχή <span class="hint" style="font-weight: normal;">(αυτόματα)</span></label>
            <input type="text" id="regionDisplay" value={d?.region ? REGION_LABEL[d.region] : ''} readonly style="background: #f7fafc;" />
            <input type="hidden" name="region" id="regionField" value={d?.region || ''} />
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label>Διάρκεια — ημέρες *</label>
            <input type="number" name="days" value={d?.duration.days ?? 4} min="1" required />
          </div>
          <div class="field">
            <label>Διάρκεια — νύχτες *</label>
            <input type="number" name="nights" value={d?.duration.nights ?? 3} min="0" required />
          </div>
          <div class="field">
            <label>Μεταφορά</label>
            <select name="transport">
              <option value="">— επιλογή —</option>
              <option value="αεροπορικώς" selected={d?.transport === 'αεροπορικώς'}>αεροπορικώς</option>
              <option value="οδικώς" selected={d?.transport === 'οδικώς'}>οδικώς</option>
              <option value="ακτοπλοϊκώς" selected={d?.transport === 'ακτοπλοϊκώς'}>ακτοπλοϊκώς</option>
              <option value="συνδυαστικά" selected={d?.transport === 'συνδυαστικά'}>συνδυαστικά</option>
            </select>
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label>Τιμή από</label>
            <input type="number" name="priceFrom" value={d?.priceFrom ?? ''} step="1" placeholder="π.χ. 590" />
          </div>
          <div class="field">
            <label>Νόμισμα</label>
            <input type="text" name="currency" value="€" readonly style="background: #f7fafc;" />
          </div>
          <div class="field">
            <label>Period (slug)</label>
            <input type="text" name="period" value={d?.period || ''} placeholder="π.χ. pasxa" />
            <div class="hint">προαιρετικό</div>
          </div>
        </div>
      </div>

      <!-- 2. Hero & intro -->
      <div class="card">
        <h2 style="margin: 0 0 0.75rem; font-size: 1rem; color: #4a5568;">Hero image & εισαγωγή</h2>
        <div class="field">
          <label>Hero image</label>
          <div style="display: flex; gap: 1rem; align-items: start;">
            <div id="heroPreview" style="flex-shrink: 0; width: 160px; height: 100px; border-radius: 8px; border: 2px dashed #cbd5e0; background: #f7fafc center/cover no-repeat; display: flex; align-items: center; justify-content: center; color: #a0aec0; font-size: 0.75rem; text-align: center;" data-current={d?.hero || ''}>
              {d?.hero ? '' : 'χωρίς εικόνα'}
            </div>
            <div style="flex: 1; display: flex; flex-direction: column; gap: 0.5rem;">
              <input type="file" id="heroFile" accept="image/jpeg,image/png,image/webp,image/gif" style="font-size: 0.85rem;" />
              <button type="button" id="heroUploadBtn" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.8rem; align-self: flex-start;" disabled>Ανέβασμα</button>
              <input type="hidden" name="hero" id="heroUrlField" value={d?.hero || ''} />
              <div class="hint">Max 10MB. Resize σε 1920px JPEG @80.</div>
              <div id="heroStatus" style="font-size: 0.85rem; min-height: 1.2rem;"></div>
            </div>
          </div>
        </div>
        <div class="field">
          <label style="display: flex; align-items: center; justify-content: space-between;">
            <span>Εισαγωγικό κείμενο (intro)</span>
            <button type="button" class="btn-ai-mini" data-rewrite-target="intro" data-rewrite-kind="intro">✨ Βελτίωση</button>
          </label>
          <textarea name="intro" rows="3" placeholder="Σύντομο εισαγωγικό κείμενο που εμφανίζεται κάτω από τον τίτλο.">{d?.intro || ''}</textarea>
        </div>
      </div>

      <!-- 3. Πόλεις αναχώρησης -->
      <div class="card">
        <h2 style="margin: 0 0 0.75rem; font-size: 1rem; color: #4a5568;">Πόλεις αναχώρησης</h2>
        <div class="field">
          <textarea name="departureCities" rows="3" placeholder="Αθήνα&#10;Θεσσαλονίκη&#10;Λάρισα">{(d?.departureCities || []).join('\n')}</textarea>
          <div class="hint">Μία πόλη ανά γραμμή.</div>
        </div>
      </div>

      <!-- 4. Pickup schedule (repeater) -->
      <div class="card">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h2 style="margin: 0; font-size: 1rem; color: #4a5568;">Ώρες & σημεία αναχώρησης</h2>
          <button type="button" class="btn btn-secondary" data-add="pickupSchedule" style="font-size: 0.8rem; padding: 0.3rem 0.7rem;">+ Προσθήκη</button>
        </div>
        <div id="pickupScheduleRows" data-repeater></div>
      </div>

      <!-- 5. Dates (repeater) -->
      <div class="card">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h2 style="margin: 0; font-size: 1rem; color: #4a5568;">Ημερομηνίες αναχωρήσεων</h2>
          <button type="button" class="btn btn-secondary" data-add="dates" style="font-size: 0.8rem; padding: 0.3rem 0.7rem;">+ Προσθήκη</button>
        </div>
        <div id="datesRows" data-repeater></div>
      </div>

      <!-- 6. Itinerary (repeater) -->
      <div class="card">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h2 style="margin: 0; font-size: 1rem; color: #4a5568;">Πρόγραμμα ημέρας-ημέρας</h2>
          <button type="button" class="btn btn-secondary" data-add="itinerary" style="font-size: 0.8rem; padding: 0.3rem 0.7rem;">+ Προσθήκη ημέρας</button>
        </div>
        <div id="itineraryRows" data-repeater></div>
      </div>

      <!-- 7. Hotels (repeater) -->
      <div class="card">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h2 style="margin: 0; font-size: 1rem; color: #4a5568;">Ξενοδοχεία</h2>
          <button type="button" class="btn btn-secondary" data-add="hotels" style="font-size: 0.8rem; padding: 0.3rem 0.7rem;">+ Προσθήκη ξενοδοχείου</button>
        </div>
        <div id="hotelsRows" data-repeater></div>
      </div>

      <!-- 8. Pricing (repeater) -->
      <div class="card">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h2 style="margin: 0; font-size: 1rem; color: #4a5568;">Τιμές ανά πόλη αναχώρησης</h2>
          <button type="button" class="btn btn-secondary" data-add="pricing" style="font-size: 0.8rem; padding: 0.3rem 0.7rem;">+ Προσθήκη τιμής</button>
        </div>
        <div id="pricingRows" data-repeater></div>
      </div>

      <!-- 9. Body markdown -->
      <div class="card">
        <div style="display: flex; align-items: center; justify-content: space-between; margin: 0 0 0.75rem;">
          <h2 style="margin: 0; font-size: 1rem; color: #4a5568;">Κυρίως κείμενο (markdown)</h2>
          <button type="button" class="btn-ai-mini" data-rewrite-target="body" data-rewrite-kind="body">✨ Βελτίωση με AI</button>
        </div>
        <div class="field">
          <textarea name="body" rows="10" placeholder="## Γιατί αυτή η εκδρομή&#10;&#10;...&#10;&#10;## Διαμονή&#10;&#10;...">{tour?.body || ''}</textarea>
          <div class="hint">Markdown. Επιτρέπονται τίτλοι ##, λίστες, links, **bold**, _italic_.</div>
        </div>
      </div>

      <!-- 10. Λίστες -->
      <div class="card">
        <h2 style="margin: 0 0 0.75rem; font-size: 1rem; color: #4a5568;">Λίστες (μία ανά γραμμή)</h2>
        <div class="field">
          <label>Περιλαμβάνει</label>
          <textarea name="includes" rows="4" placeholder="Αεροπορικά εισιτήρια&#10;Διανυκτερεύσεις σε ξενοδοχείο 4*&#10;Πρωινό μπουφέ">{(d?.includes || []).join('\n')}</textarea>
        </div>
        <div class="field">
          <label>Δεν περιλαμβάνει</label>
          <textarea name="notIncludes" rows="4" placeholder="Φόροι αεροδρομίων&#10;Ταξιδιωτική ασφάλιση">{(d?.notIncludes || []).join('\n')}</textarea>
        </div>
        <div class="field">
          <label>Διαδικασία κράτησης</label>
          <textarea name="bookingProcess" rows="3" placeholder="Επικοινωνία με το γραφείο για διαθεσιμότητα&#10;Προκαταβολή 30%&#10;Αποστολή διαβατηρίου">{(d?.bookingProcess || []).join('\n')}</textarea>
          <div class="hint">Ένα βήμα ανά γραμμή.</div>
        </div>
        <div class="field">
          <label>Πολιτική ακύρωσης</label>
          <textarea name="cancellationPolicy" rows="3" placeholder="Έως 30 ημέρες πριν: παρακράτηση προκαταβολής&#10;Από 29 έως 15 ημέρες: 50% παρακράτηση">{(d?.cancellationPolicy || []).join('\n')}</textarea>
        </div>
        <div class="field">
          <label>Σημειώσεις</label>
          <textarea name="notes" rows="3">{(d?.notes || []).join('\n')}</textarea>
        </div>
        <div class="field">
          <label>SEO keywords</label>
          <textarea name="keywords" rows="2" placeholder="βουδαπέστη, formula 1, εκδρομή">{(d?.keywords || []).join(', ')}</textarea>
          <div class="hint">Χωρισμένα με κόμμα ή νέα γραμμή.</div>
        </div>
      </div>

      <!-- 11. FAQs (repeater) -->
      <div class="card">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h2 style="margin: 0; font-size: 1rem; color: #4a5568;">Συχνές ερωτήσεις</h2>
          <button type="button" class="btn btn-secondary" data-add="faqs" style="font-size: 0.8rem; padding: 0.3rem 0.7rem;">+ Προσθήκη ερώτησης</button>
        </div>
        <div id="faqsRows" data-repeater></div>
      </div>
    </div>

    <!-- Sidebar -->
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <div class="card" style="position: sticky; top: 1rem;">
        <h3 style="margin: 0 0 0.75rem; font-size: 1rem;">Δημοσίευση</h3>
        <label style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; cursor: pointer;">
          <input type="checkbox" name="draft" checked={d?.draft ?? true} style="width: auto;" />
          <span>Draft (δεν φαίνεται δημοσίως)</span>
        </label>
        <button type="submit" id="saveBtn" class="btn btn-primary" style="width: 100%; justify-content: center;">
          {isEdit ? 'Αποθήκευση' : 'Δημιουργία εκδρομής'}
        </button>
        {isEdit && (
          <a href={`/ekdromi/${tour!.slug}`} target="_blank" class="btn btn-secondary" style="width: 100%; justify-content: center; margin-top: 0.5rem;">
            Δες στο site →
          </a>
        )}
      </div>

      {isEdit && (
        <div class="card" style="border: 1px solid #fee2e2;">
          <h3 style="margin: 0 0 0.5rem; font-size: 1rem; color: #c53030;">⚠ Διαγραφή</h3>
          <p style="margin: 0 0 0.75rem; font-size: 0.85rem; color: #4a5568;">
            Διαγραφή εκδρομής. Δεν αναιρείται.
          </p>
          <button type="button" id="deleteBtn" class="btn btn-danger" style="width: 100%; justify-content: center;">Διαγραφή</button>
        </div>
      )}
    </div>
  </div>
</form>

<script is:inline define:vars={{ initialData, destinationsMap }}>
  // ----- Char counter for SEO description -----
  (() => {
    const desc = document.querySelector('textarea[name="description"]');
    const count = document.getElementById('descCount');
    function update() {
      const n = desc.value.length;
      let color = '#10b981';
      if (n < 120 || n > 200) color = '#c53030';
      else if (n < 140 || n > 180) color = '#f59e0b';
      count.style.color = color;
      count.textContent = n + ' χαρακτήρες (στόχος 140-180)';
    }
    if (desc && count) { update(); desc.addEventListener('input', update); }
  })();

  // ----- Destination combobox + new-destination creation -----
  (() => {
    const input = document.getElementById('destInput');
    const display = document.getElementById('regionDisplay');
    const field = document.getElementById('regionField');
    const status = document.getElementById('destStatus');
    const createPanel = document.getElementById('destCreatePanel');
    const newDestRegion = document.getElementById('newDestRegion');
    const createBtn = document.getElementById('createDestBtn');
    const cancelBtn = document.getElementById('cancelDestBtn');
    const newDestStatus = document.getElementById('newDestStatus');
    const datalist = document.getElementById('destOptions');
    const labels = { ellada: 'Ελλάδα', europi: 'Ευρώπη', kosmos: 'Κόσμος' };

    function setRegion(region) {
      field.value = region || '';
      display.value = labels[region] || '';
    }

    function refresh() {
      const v = input.value.trim();
      if (!v) {
        setRegion('');
        status.textContent = '';
        createPanel.style.display = 'none';
        return;
      }
      // Exact match (case-insensitive) against known destinations
      const exactKey = Object.keys(destinationsMap).find(
        (k) => k.toLowerCase() === v.toLowerCase(),
      );
      if (exactKey) {
        const r = destinationsMap[exactKey];
        setRegion(r);
        // Normalize the input to the canonical casing
        if (input.value !== exactKey) input.value = exactKey;
        status.style.color = '#10b981';
        status.textContent = `✓ Υπάρχων προορισμός — ${labels[r]}`;
        createPanel.style.display = 'none';
        return;
      }
      // No match → offer to create (only if value is at least 2 chars)
      setRegion('');
      if (v.length < 2) {
        status.textContent = '';
        createPanel.style.display = 'none';
        return;
      }
      status.style.color = '#92400e';
      status.innerHTML = `Δεν υπάρχει «<strong>${v.replace(/</g, '&lt;')}</strong>» στη λίστα.
        <button type="button" id="openCreateDest" class="btn-link" style="background: transparent; border: 0; color: #c05621; cursor: pointer; font-weight: 600; padding: 0; margin-left: 0.4rem; text-decoration: underline; font-size: inherit;">
          + Δημιούργησε νέο προορισμό «${v.replace(/</g, '&lt;')}»
        </button>`;
      const openBtn = document.getElementById('openCreateDest');
      if (openBtn) {
        openBtn.addEventListener('click', () => {
          createPanel.style.display = '';
          newDestStatus.textContent = '';
          newDestRegion.focus();
        });
      }
    }

    input.addEventListener('input', refresh);
    input.addEventListener('change', refresh);

    cancelBtn.addEventListener('click', () => {
      createPanel.style.display = 'none';
      newDestStatus.textContent = '';
    });

    createBtn.addEventListener('click', async () => {
      const title = input.value.trim();
      const region = newDestRegion.value;
      if (!title) {
        newDestStatus.style.color = '#c53030';
        newDestStatus.textContent = 'Συμπλήρωσε πρώτα τον προορισμό.';
        return;
      }
      createBtn.disabled = true;
      createBtn.textContent = '...';
      newDestStatus.style.color = '#4a5568';
      newDestStatus.textContent = 'Δημιουργία...';
      try {
        const r = await fetch('/api/agency/destination/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, region }),
        });
        const j = await r.json().catch(() => ({}));
        if (!r.ok) throw new Error(j.error || ('HTTP ' + r.status));
        // Hydrate the local map so the combobox treats it as known immediately
        destinationsMap[j.title] = j.region;
        // Add to datalist so future typing autocompletes against it
        const opt = document.createElement('option');
        opt.value = j.title;
        opt.textContent = labels[j.region];
        datalist.appendChild(opt);
        // Update form: input → canonical title, region → new
        input.value = j.title;
        setRegion(j.region);
        const verb = j.alreadyExists ? 'Υπήρχε ήδη' : 'Δημιουργήθηκε ✓';
        status.style.color = '#10b981';
        status.textContent = `${verb} ως draft — ${labels[j.region]} / ${j.title}`;
        createPanel.style.display = 'none';
        if (window.toast) window.toast(`Προορισμός: ${verb}`, 'success');
      } catch (e) {
        newDestStatus.style.color = '#c53030';
        newDestStatus.textContent = '✗ ' + String(e.message || e).slice(0, 200);
      } finally {
        createBtn.disabled = false;
        createBtn.textContent = 'Δημιουργία';
      }
    });

    // Run once on load (handles edit mode where destination is already set)
    refresh();
  })();

  // ----- Hero image upload -----
  (() => {
    const preview = document.getElementById('heroPreview');
    const fileInput = document.getElementById('heroFile');
    const uploadBtn = document.getElementById('heroUploadBtn');
    const status = document.getElementById('heroStatus');
    const urlField = document.getElementById('heroUrlField');
    function setPreview(url) {
      if (url) { preview.style.backgroundImage = `url('${url}')`; preview.textContent = ''; }
      else { preview.style.backgroundImage = ''; preview.textContent = 'χωρίς εικόνα'; }
    }
    setPreview(preview.dataset.current);
    fileInput.addEventListener('change', () => {
      uploadBtn.disabled = !fileInput.files.length;
      status.textContent = '';
      if (fileInput.files.length) {
        const reader = new FileReader();
        reader.onload = (e) => { preview.style.backgroundImage = `url('${e.target.result}')`; preview.textContent = ''; };
        reader.readAsDataURL(fileInput.files[0]);
      }
    });
    uploadBtn.addEventListener('click', async () => {
      if (!fileInput.files.length) return;
      uploadBtn.disabled = true;
      uploadBtn.textContent = 'Ανέβασμα…';
      status.style.color = '#4a5568';
      status.textContent = '';
      const fd = new FormData();
      fd.append('file', fileInput.files[0]);
      try {
        const r = await fetch('/api/agency/upload-hero', { method: 'POST', body: fd });
        const j = await r.json().catch(() => ({}));
        if (r.ok && j.url) {
          urlField.value = j.url;
          setPreview(j.url);
          status.style.color = '#10b981';
          status.textContent = `✓ Ανέβηκε (${j.sizeKb}KB)`;
        } else {
          status.style.color = '#c53030';
          status.textContent = j.error || `Σφάλμα ${r.status}`;
        }
      } catch (e) {
        status.style.color = '#c53030';
        status.textContent = 'Πρόβλημα δικτύου';
      }
      uploadBtn.disabled = !fileInput.files.length;
      uploadBtn.textContent = 'Ανέβασμα';
    });
  })();

  // ----- Repeaters -----
  const repeaterTemplates = {
    pickupSchedule: (i, v = {}) => `
      <div class="repeater-row" style="display: grid; grid-template-columns: 1fr 1fr 100px 32px; gap: 0.5rem; margin-bottom: 0.5rem; align-items: end;">
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Πόλη</label><input type="text" data-key="city" value="${(v.city || '').replace(/"/g, '&quot;')}" placeholder="π.χ. Αθήνα" /></div>
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Σημείο</label><input type="text" data-key="location" value="${(v.location || '').replace(/"/g, '&quot;')}" placeholder="π.χ. Πλατεία Συντάγματος" /></div>
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Ώρα</label><input type="text" data-key="time" value="${(v.time || '').replace(/"/g, '&quot;')}" placeholder="06:00" /></div>
        <button type="button" class="repeater-remove" style="height: 36px; background: white; border: 1px solid #cbd5e0; border-radius: 6px; cursor: pointer; color: #c53030;">×</button>
      </div>`,
    dates: (i, v = {}) => `
      <div class="repeater-row" style="display: grid; grid-template-columns: 140px 140px 1fr 32px; gap: 0.5rem; margin-bottom: 0.5rem; align-items: end;">
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Από</label><input type="date" data-key="from" value="${v.from || ''}" /></div>
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Έως</label><input type="date" data-key="to" value="${v.to || ''}" /></div>
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Ετικέτα (προαιρετικό)</label><input type="text" data-key="label" value="${(v.label || '').replace(/"/g, '&quot;')}" placeholder="π.χ. Αναχώρηση Πάσχα" /></div>
        <button type="button" class="repeater-remove" style="height: 36px; background: white; border: 1px solid #cbd5e0; border-radius: 6px; cursor: pointer; color: #c53030;">×</button>
      </div>`,
    itinerary: (i, v = {}) => `
      <div class="repeater-row" style="margin-bottom: 0.75rem; padding: 0.75rem; background: #f7fafc; border-radius: 6px;">
        <div style="display: grid; grid-template-columns: 80px 1fr 32px; gap: 0.5rem; margin-bottom: 0.5rem; align-items: end;">
          <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Ημέρα</label><input type="number" data-key="day" value="${v.day || i + 1}" min="1" /></div>
          <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Τίτλος</label><input type="text" data-key="title" value="${(v.title || '').replace(/"/g, '&quot;')}" placeholder="π.χ. Άφιξη — ξενάγηση πόλης" /></div>
          <button type="button" class="repeater-remove" style="height: 36px; background: white; border: 1px solid #cbd5e0; border-radius: 6px; cursor: pointer; color: #c53030;">×</button>
        </div>
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Περιγραφή</label><textarea data-key="description" rows="3" placeholder="Τι θα κάνετε αυτή τη μέρα.">${v.description || ''}</textarea></div>
      </div>`,
    hotels: (i, v = {}) => `
      <div class="repeater-row" style="margin-bottom: 0.5rem; padding: 0.6rem; background: #f7fafc; border-radius: 6px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr 80px 32px; gap: 0.5rem; align-items: end;">
          <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Όνομα *</label><input type="text" data-key="name" value="${(v.name || '').replace(/"/g, '&quot;')}" placeholder="π.χ. Astoria Grand" /></div>
          <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Τοποθεσία</label><input type="text" data-key="location" value="${(v.location || '').replace(/"/g, '&quot;')}" placeholder="κέντρο πόλης" /></div>
          <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Αστέρια</label><input type="number" data-key="stars" value="${v.stars || ''}" min="1" max="5" /></div>
          <button type="button" class="repeater-remove" style="height: 36px; background: white; border: 1px solid #cbd5e0; border-radius: 6px; cursor: pointer; color: #c53030;">×</button>
        </div>
        <div style="display: grid; grid-template-columns: 80px 1fr; gap: 0.5rem; margin-top: 0.5rem; align-items: end;">
          <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Διανυκτ.</label><input type="number" data-key="nights" value="${v.nights || ''}" min="0" /></div>
          <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Διατροφή</label><input type="text" data-key="board" value="${(v.board || '').replace(/"/g, '&quot;')}" placeholder="π.χ. Πρωινό μπουφέ" /></div>
        </div>
      </div>`,
    pricing: (i, v = {}) => `
      <div class="repeater-row" style="display: grid; grid-template-columns: 1fr 100px 100px 1fr 32px; gap: 0.5rem; margin-bottom: 0.5rem; align-items: end;">
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Από πόλη</label><input type="text" data-key="fromCity" value="${(v.fromCity || '').replace(/"/g, '&quot;')}" placeholder="π.χ. Αθήνα" /></div>
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">€/άτομο</label><input type="number" data-key="perPerson" value="${v.perPerson || ''}" /></div>
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Επιβ. μονόκλ.</label><input type="number" data-key="singleSupplement" value="${v.singleSupplement || ''}" /></div>
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Έκπτωση παιδιού</label><input type="text" data-key="childDiscount" value="${(v.childDiscount || '').replace(/"/g, '&quot;')}" placeholder="π.χ. -50€ έως 12 ετών" /></div>
        <button type="button" class="repeater-remove" style="height: 36px; background: white; border: 1px solid #cbd5e0; border-radius: 6px; cursor: pointer; color: #c53030;">×</button>
      </div>`,
    faqs: (i, v = {}) => `
      <div class="repeater-row" style="margin-bottom: 0.6rem; padding: 0.6rem; background: #f7fafc; border-radius: 6px;">
        <div style="display: grid; grid-template-columns: 1fr 32px; gap: 0.5rem; margin-bottom: 0.4rem; align-items: end;">
          <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Ερώτηση</label><input type="text" data-key="q" value="${(v.q || '').replace(/"/g, '&quot;')}" placeholder="π.χ. Χρειάζομαι διαβατήριο;" /></div>
          <button type="button" class="repeater-remove" style="height: 36px; background: white; border: 1px solid #cbd5e0; border-radius: 6px; cursor: pointer; color: #c53030;">×</button>
        </div>
        <div class="field" style="margin: 0;"><label style="font-size: 0.75rem;">Απάντηση</label><textarea data-key="a" rows="2" placeholder="Απάντηση σε 1-3 προτάσεις.">${v.a || ''}</textarea></div>
      </div>`,
  };

  function setupRepeater(name) {
    const container = document.getElementById(name + 'Rows');
    if (!container) return;
    const tmpl = repeaterTemplates[name];
    function add(value = {}) {
      const idx = container.children.length;
      const wrap = document.createElement('div');
      wrap.innerHTML = tmpl(idx, value);
      const row = wrap.firstElementChild;
      row.querySelector('.repeater-remove').addEventListener('click', () => row.remove());
      container.appendChild(row);
    }
    // Hydrate existing data
    (initialData[name] || []).forEach((v) => add(v));
    // Wire add button
    document.querySelector(`[data-add="${name}"]`).addEventListener('click', () => add({}));
  }
  ['pickupSchedule', 'dates', 'itinerary', 'hotels', 'pricing', 'faqs'].forEach(setupRepeater);

  // ----- Read row data from a repeater -----
  function readRepeater(name) {
    const container = document.getElementById(name + 'Rows');
    if (!container) return [];
    return [...container.querySelectorAll('.repeater-row')].map((row) => {
      const obj = {};
      row.querySelectorAll('[data-key]').forEach((el) => {
        const k = el.dataset.key;
        obj[k] = el.value;
      });
      return obj;
    });
  }

  // ----- Public API: read full payload (used by new.astro / [slug].astro submit) -----
  window.readTourPayload = function () {
    const f = document.getElementById('tourForm');
    const fd = new FormData(f);
    return {
      title:           fd.get('title'),
      description:     fd.get('description'),
      destination:     fd.get('destination'),
      region:          fd.get('region'),
      days:            Number(fd.get('days')),
      nights:          Number(fd.get('nights')),
      transport:       fd.get('transport') || undefined,
      priceFrom:       fd.get('priceFrom') || undefined,
      currency:        '€',
      period:          fd.get('period') || undefined,
      departureCities: fd.get('departureCities'),
      hero:            fd.get('hero') || undefined,
      intro:           fd.get('intro') || undefined,
      body:            fd.get('body') || '',
      pickupSchedule:  readRepeater('pickupSchedule'),
      dates:           readRepeater('dates'),
      itinerary:       readRepeater('itinerary'),
      hotels:          readRepeater('hotels'),
      pricing:         readRepeater('pricing'),
      faqs:            readRepeater('faqs'),
      includes:        fd.get('includes'),
      notIncludes:     fd.get('notIncludes'),
      bookingProcess:  fd.get('bookingProcess'),
      cancellationPolicy: fd.get('cancellationPolicy'),
      notes:           fd.get('notes'),
      keywords:        fd.get('keywords'),
      draft:           fd.get('draft') === 'on',
    };
  };
</script>
