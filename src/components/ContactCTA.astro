---
import { SITE } from '@lib/site';
interface Props {
  title?: string;
  text?: string;
  context?: string;
}
const {
  title = 'Έτοιμοι να ταξιδέψετε;',
  text = 'Επικοινωνήστε μαζί μας για περισσότερες πληροφορίες, διαθεσιμότητα και προσωποποιημένη πρόταση. Εξυπηρέτηση από έμπειρους ταξιδιωτικούς συμβούλους.',
  context,
} = Astro.props;
const subject = context ? `Ενδιαφέρον για ${context}` : 'Ενδιαφέρον για ταξίδι';
---
<section class="section">
  <div class="container-x">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-800 to-brand-950 px-6 py-12 md:px-14 md:py-16 text-white shadow-lift">
      <div class="absolute -top-24 -right-24 size-72 rounded-full bg-accent-500/20 blur-3xl" aria-hidden="true"></div>
      <div class="absolute -bottom-32 -left-20 size-80 rounded-full bg-brand-400/20 blur-3xl" aria-hidden="true"></div>

      <div class="relative grid gap-8 md:grid-cols-2 md:items-center">
        <div>
          <h2 class="text-white text-balance">{title}</h2>
          <p class="mt-4 text-brand-50/90 text-pretty">{text}</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 md:justify-end">
          <a href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`} class="btn-accent">
            <svg class="size-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M2 4.5C2 3.12 3.12 2 4.5 2h1.86c.5 0 .94.34 1.06.83l.92 3.7a1.1 1.1 0 0 1-.3 1.06L6.6 9.04a11 11 0 0 0 4.36 4.36l1.45-1.45c.27-.27.68-.39 1.06-.3l3.7.92c.49.12.83.56.83 1.06v1.86c0 1.38-1.12 2.5-2.5 2.5h-.5C8.39 18 2 11.61 2 3.5v-.5z"/>
            </svg>
            {SITE.contact.phoneDisplay}
          </a>
          <a href={`/epikoinonia?subject=${encodeURIComponent(subject)}`} class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-colors">
            Φόρμα Επικοινωνίας
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
